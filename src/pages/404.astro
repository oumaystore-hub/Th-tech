---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>404 - الصفحة غير موجودة | Th.Tech</title>
  <meta name="description" content="عذراً، الصفحة التي تبحث عنها غير موجودة. عد إلى الصفحة الرئيسية أو استخدم البحث." />
</head>
<body>
  <Header />
  <main class="error-page">
    <div class="container">
      <div class="error-content">
        <div class="error-code">404</div>
        <div class="error-icon">🔍</div>
        <h1>عذراً، الصفحة غير موجودة</h1>
        <p>يبدو أن الرابط الذي تبحث عنه قد تم نقله أو حذفه. لا تقلق، نحن هنا لمساعدتك!</p>
        
        <div class="error-actions">
          <a href="/Th-tech/" class="btn-primary">
            <span>🏠</span>
            <span>العودة للصفحة الرئيسية</span>
          </a>
          <a href="/Th-tech/category/" class="btn-secondary">
            <span>📂</span>
            <span>تصفح التصنيفات</span>
          </a>
        </div>

        <div class="suggestions">
          <h3>هل تبحث عن:</h3>
          <ul>
            <li><a href="/Th-tech/ai/">الذكاء الاصطناعي</a></li>
            <li><a href="/Th-tech/programming/">البرمجة</a></li>
            <li><a href="/Th-tech/data-science/">علم البيانات</a></li>
            <li><a href="/Th-tech/contact/">اتصل بنا</a></li>
          </ul>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</body>
</html>

<style>
  :root { --bg: #f8fafc; --card: #fff; --text: #0f172a; --text-sec: #64748b; --primary: #0284c7; --border: rgba(2,132,199,0.2); }
  html.dark-mode { --bg: #0b1120; --card: #1e293b; --text: #f1f5f9; --text-sec: #94a3b8; --primary: #38bdf8; --border: rgba(56,189,248,0.2); }
  body { background: var(--bg); color: var(--text); font-family: system-ui, sans-serif; margin: 0; min-height: 100vh; }
  
  .error-page { min-height: 70vh; display: flex; align-items: center; justify-content: center; padding: 4rem 1.5rem; }
  .container { max-width: 800px; margin: 0 auto; }
  .error-content { text-align: center; }
  
  .error-code { font-size: 8rem; font-weight: 900; color: var(--primary); line-height: 1; margin-bottom: 1rem; opacity: 0.3; }
  .error-icon { font-size: 5rem; margin-bottom: 2rem; }
  .error-content h1 { font-size: 2rem; margin-bottom: 1rem; color: var(--text); }
  .error-content p { font-size: 1.1rem; color: var(--text-sec); margin-bottom: 2.5rem; line-height: 1.8; }
  
  .error-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-bottom: 3rem; }
  .btn-primary, .btn-secondary { display: flex; align-items: center; gap: 0.5rem; padding: 1rem 2rem; border-radius: 10px; text-decoration: none; font-weight: 600; transition: all 0.3s; }
  .btn-primary { background: linear-gradient(135deg, var(--primary), #00d4ff); color: white; }
  .btn-primary:hover { transform: translateY(-3px); box-shadow: 0 8px 20px rgba(2,132,199,0.3); }
  .btn-secondary { background: var(--card); color: var(--text); border: 2px solid var(--border); }
  .btn-secondary:hover { border-color: var(--primary); color: var(--primary); transform: translateY(-3px); }
  
  .suggestions { background: var(--card); border: 2px solid var(--border); border-radius: 16px; padding: 2rem; text-align: right; }
  .suggestions h3 { color: var(--primary); margin-bottom: 1rem; font-size: 1.2rem; }
  .suggestions ul { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 0.8rem; }
  .suggestions li a { color: var(--text-sec); text-decoration: none; padding: 0.8rem; border-radius: 8px; display: block; transition: all 0.3s; border: 1px solid transparent; }
  .suggestions li a:hover { background: var(--bg); border-color: var(--border); color: var(--primary); padding-right: 1.2rem; }
  
  @media (max-width: 768px) {
    .error-code { font-size: 5rem; }
    .error-icon { font-size: 3rem; }
    .error-content h1 { font-size: 1.5rem; }
    .error-actions { flex-direction: column; }
    .btn-primary, .btn-secondary { justify-content: center; }
  }
</style>
