---
import { getCollection } from 'astro:content';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const cats = [...new Set(posts.map(p => p.data.category))];
  return cats.map(c => ({ params: { slug: c.toLowerCase().replace(/\s+/g, '-') }, props: { category: c } }));
}
const { category } = Astro.props;
const posts = await getCollection('blog');
const filtered = posts.filter(p => p.data.category === category);
---
<html lang="ar" dir="rtl" data-theme="dark">
  <head><title>{category} - Th.Tech</title></head>
  <body>
    <Header />
    <main class="main">
      <h1>تصنيف: {category}</h1>
      <div class="grid">
        {filtered.map(p => (
          <article class="card">
            <h2><a href={`/articles/${p.slug}/`}>{p.data.title}</a></h2>
            <p>{p.data.description}</p>
          </article>
        ))}
      </div>
      {filtered.length === 0 && <p style="text-align:center;padding:3rem;color:#666">لا توجد مقالات حالياً</p>}
    </main>
    <Footer />
  </body>
</html>

<style>
  :root{--bg:#0a0a0a;--text:#fff;--card:#1a1a2e}
  body{background:var(--bg);color:var(--text);margin:0;font-family:system-ui}
  .main{max-width:1000px;margin:0 auto;padding:2rem 1rem}
  h1{text-align:center;margin-bottom:2rem}
  .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.5rem}
  .card{background:var(--card);padding:1.5rem;border-radius:12px}
  h2 a{color:#fff;text-decoration:none}
  h2 a:hover{color:#3b82f6}
</style>
