---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  return [
    { params: { slug: 'ai' }, props: { name: 'ذكاء اصطناعي', icon: '🤖' }},
    { params: { slug: 'tech' }, props: { name: 'تقنية', icon: '📱' }},
    { params: { slug: 'programming' }, props: { name: 'برمجة', icon: '💻' }},
    { params: { slug: 'tools' }, props: { name: 'أدوات', icon: '🛠️' }}
  ];
}

const { name, icon } = Astro.props;
---

<html lang="ar" dir="rtl">
<head><meta charset="UTF-8" /><title>{name}</title></head>
<body style="background:#0a0e27; color:#fff; font-family:sans-serif; margin:0;">
  <Header />
  <main style="max-width:1200px; margin:0 auto; padding:2rem 1rem;">
    <h1 style="color:#00d4ff; margin-bottom:2rem;"><span style="font-size:2rem;">{icon}</span> {name}</h1>
    <div style="background:#1e293b; padding:3rem; border-radius:14px; text-align:center; border:1px solid rgba(0,212,255,0.2);">
      <p style="color:#94a3b8; font-size:1.1rem;">قريباً مقالات في هذا التصنيف</p>
    </div>
    <a href="/Th-tech/category/" style="display:inline-block; margin-top:2rem; color:#00d4ff; text-decoration:none;">← جميع التصنيفات</a>
  </main>
  <Footer />
</body>
</html>
