---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>التصنيفات - Th.Tech</title>
</head>
<body>
  <Header />
  
  <main class="category-page">
    <div class="page-header">
      <h1>🗂️ استكشف التصنيفات</h1>
      <p>اختر المجال التقني الذي يهمك للدخول إلى مقالاته المتخصصة</p>
    </div>

    <div class="categories-grid">
      <!-- الذكاء الاصطناعي -->
      <a href="/Th-tech/ai/" class="cat-card">
        <div class="cat-icon">🤖</div>
        <h3>الذكاء الاصطناعي</h3>
        <p>تعلم الآلة، الشبكات العصبية، والنماذج التوليدية</p>
        <span class="cat-count">📄 15 مقال</span>
      </a>

      <!-- البرمجة -->
      <a href="/Th-tech/programming/" class="cat-card">
        <div class="cat-icon">💻</div>
        <h3>البرمجة والتطوير</h3>
        <p>لغات البرمجة، أطر العمل، وهندسة البرمجيات</p>
        <span class="cat-count">📄 20 مقال</span>
      </a>

      <!-- علم البيانات -->
      <a href="/Th-tech/data-science/" class="cat-card">
        <div class="cat-icon">📊</div>
        <h3>علم البيانات</h3>
        <p>تحليل البيانات، التعلم الآلي، والذكاء الأعمال</p>
        <span class="cat-count">📄 12 مقال</span>
      </a>

      <!-- إنترنت الأشياء -->
      <a href="/Th-tech/iot/" class="cat-card">
        <div class="cat-icon">📡</div>
        <h3>إنترنت الأشياء</h3>
        <p>الأجهزة الذكية، المنازل الذكية، والمدن المتصلة</p>
        <span class="cat-count">📄 10 مقالات</span>
      </a>

      <!-- DevOps -->
      <a href="/Th-tech/devops/" class="cat-card">
        <div class="cat-icon">🔄</div>
        <h3>DevOps</h3>
        <p>التكامل المستمر، النشر، والأتمتة</p>
        <span class="cat-count">📄 8 مقالات</span>
      </a>

      <!-- تطوير الجوال -->
      <a href="/Th-tech/mobile/" class="cat-card">
        <div class="cat-icon">📱</div>
        <h3>تطوير الجوال</h3>
        <p>تطبيقات iOS، Android، Flutter و React Native</p>
        <span class="cat-count">📄 11 مقال</span>
      </a>

      <!-- الشبكات -->
      <a href="/Th-tech/networks/" class="cat-card">
        <div class="cat-icon">🌐</div>
        <h3>الشبكات</h3>
        <p>إدارة الشبكات، بروتوكولات الاتصال، والأمان الشبكي</p>
        <span class="cat-count">📄 10 مقالات</span>
      </a>

      <!-- الحوسبة السحابية -->
      <a href="/Th-tech/cloud/" class="cat-card">
        <div class="cat-icon">️</div>
        <h3>الحوسبة السحابية</h3>
        <p>AWS، Azure، Google Cloud، والبنية التحتية الحديثة</p>
        <span class="cat-count">📄 14 مقال</span>
      </a>

      <!-- الأمن السيبراني -->
      <a href="/Th-tech/security/" class="cat-card">
        <div class="cat-icon">🔒</div>
        <h3>الأمن السيبراني</h3>
        <p>حماية البيانات، الاختراق الأخلاقي، والتشفير</p>
        <span class="cat-count">📄 13 مقال</span>
      </a>

      <!-- البلوك تشين -->
      <a href="/Th-tech/blockchain/" class="cat-card">
        <div class="cat-icon">⛓️</div>
        <h3>البلوك تشين</h3>
        <p>العملات الرقمية، العقود الذكية، وتطبيقات Web3</p>
        <span class="cat-count">📄 9 مقالات</span>
      </a>
    </div>
  </main>

  <Footer />
</body>
</html>

<style>
  :root { 
    --bg: #f8fafc; 
    --card: #ffffff; 
    --text: #0f172a; 
    --text-sec: #64748b; 
    --primary: #0284c7; 
    --border: rgba(2,132,199,0.2); 
  }
  
  html.dark-mode { 
    --bg: #0b1120; 
    --card: #1e293b; 
    --text: #f1f5f9; 
    --text-sec: #94a3b8; 
    --primary: #38bdf8; 
    --border: rgba(56,189,248,0.2); 
  }
  
  body { 
    background: var(--bg); 
    color: var(--text); 
    font-family: system-ui, sans-serif; 
    margin: 0; 
  }
  
  .category-page { 
    max-width: 1200px; 
    margin: 0 auto; 
    padding: 4rem 1.5rem 6rem; 
  }
  
  .page-header { 
    text-align: center; 
    margin-bottom: 3.5rem; 
  }
  
  .page-header h1 { 
    color: var(--primary); 
    font-size: 2.5rem; 
    margin-bottom: 0.8rem; 
  }
  
  .page-header p { 
    color: var(--text-sec); 
    font-size: 1.15rem; 
  }
  
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
  }
  
  .cat-card {
    background: var(--card);
    border: 2px solid var(--border);
    border-radius: 16px;
    padding: 2.5rem 2rem;
    text-align: center;
    text-decoration: none;
    color: var(--text);
    transition: all 0.3s;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  
  .cat-card:hover {
    transform: translateY(-8px);
    border-color: var(--primary);
    box-shadow: 0 10px 30px rgba(2,132,199,0.2);
  }
  
  .cat-icon { font-size: 4rem; margin-bottom: 1rem; }
  
  .cat-card h3 { 
    color: var(--primary); 
    font-size: 1.3rem; 
    margin-bottom: 0.8rem; 
  }
  
  .cat-card p { 
    color: var(--text-sec); 
    font-size: 0.95rem; 
    line-height: 1.6; 
    margin-bottom: 1.2rem; 
  }
  
  .cat-count { 
    background: rgba(2,132,199,0.1); 
    color: var(--primary); 
    padding: 0.4rem 1.2rem; 
    border-radius: 50px; 
    font-size: 0.9rem; 
    font-weight: 600;
  }
  
  @media (max-width: 768px) {
    .categories-grid { 
      grid-template-columns: 1fr; 
    }
    .category-page { 
      padding: 3rem 1rem 4rem; 
    }
  }
</style>
