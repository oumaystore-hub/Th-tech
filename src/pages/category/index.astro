---
import { getCollection } from 'astro:content';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const posts = await getCollection('blog');
const categories = [...new Set(posts.map(p => p.data.category))];
const categoryCounts = categories.reduce((acc, cat) => {
  acc[cat] = posts.filter(p => p.data.category === cat).length;
  return acc;
}, {});
---

<html lang="ar" dir="rtl" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>التصنيفات | Th.Tech</title>
</head>
<body>
  <Header />
  <main class="container">
    <h1 class="page-title">📂 جميع التصنيفات</h1>
    <div class="categories-grid">
      {categories.map(cat => (
        <a href={`/Th-tech/category/${cat.toLowerCase().replace(/\s+/g, '-')}/`} class="category-card">
          <div class="category-icon">
            {cat.includes('ذكاء') ? '🤖' : 
             cat.includes('برمجة') ? '💻' : 
             cat.includes('تقنية') ? '📱' : 
             cat.includes('أدوات') ? '🛠️' : '📁'}
          </div>
          <h3>{cat}</h3>
          <span class="count">{categoryCounts[cat]} مقال</span>
        </a>
      ))}
    </div>
  </main>
  <Footer />
</body>
</html>

<style>
  :root { --bg: #0f172a; --card: #1e293b; --text: #f1f5f9; --primary: #3b82f6; }
  [data-theme="light"] { --bg: #f8fafc; --card: #ffffff; --text: #0f172a; }
  body { margin: 0; font-family: 'Tajawal', sans-serif; background: var(--bg); color: var(--text); }
  .container { max-width: 1200px; margin: 0 auto; padding: 2rem 1rem; min-height: 80vh; }
  .page-title { text-align: center; font-size: 2.5rem; margin-bottom: 3rem; }  .categories-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 2rem; }
  .category-card {
    background: var(--card);
    padding: 2rem;
    border-radius: 16px;
    text-decoration: none;
    color: var(--text);
    text-align: center;
    transition: all 0.3s;
    border: 2px solid rgba(255,255,255,0.1);
  }
  .category-card:hover {
    transform: translateY(-8px);
    border-color: var(--primary);
    box-shadow: 0 10px 30px rgba(59, 130, 246, 0.3);
  }
  .category-icon { font-size: 3rem; margin-bottom: 1rem; }
  .category-card h3 { font-size: 1.3rem; margin-bottom: 0.5rem; }
  .count {
    display: inline-block;
    background: rgba(59, 130, 246, 0.2);
    color: var(--primary);
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-size: 0.9rem;
    font-weight: bold;
  }
</style>
