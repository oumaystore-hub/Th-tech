---
import { getCollection } from 'astro:content';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const posts = await getCollection('blog');
const categories = [...new Set(posts.map(p => p.data.category))];
---

<html lang="ar" dir="rtl" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <title>التصنيفات | Th.Tech</title>
</head>
<body>
  <Header />
  <main class="container">
    <h1>📂 جميع التصنيفات</h1>
    <div class="grid">
      {categories.map(cat => {
        const count = posts.filter(p => p.data.category === cat).length;
        return (
          <a href={`/Th-tech/category/${cat.toLowerCase().replace(/\s+/g, '-')}/`} class="cat-card">
            <div class="icon">
              {cat.includes('ذكاء') ? '🤖' : cat.includes('برمجة') ? '💻' : cat.includes('تقنية') ? '📱' : '📁'}
            </div>
            <h3>{cat}</h3>
            <span class="count">{count} مقال</span>
          </a>
        );
      })}
    </div>
  </main>
  <Footer />
</body>
</html>

<style>
  :root { --bg: #0a0e27; --card: #1e293b; --text: #f1f5f9; --primary: #00d4ff; }  body { margin: 0; font-family: 'Segoe UI', sans-serif; background: var(--bg); color: var(--text); font-size: 0.85rem; }
  .container { max-width: 1200px; margin: 0 auto; padding: 2rem 1rem; }
  h1 { color: var(--primary); text-align: center; margin-bottom: 2rem; }
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 1.5rem; }
  .cat-card { background: var(--card); padding: 2rem; border-radius: 14px; text-decoration: none; text-align: center; border: 1px solid rgba(0,212,255,0.2); transition: 0.3s; }
  .cat-card:hover { transform: translateY(-5px); border-color: var(--primary); }
  .icon { font-size: 3rem; margin-bottom: 1rem; }
  h3 { color: var(--text); margin-bottom: 0.5rem; }
  .count { display: inline-block; background: rgba(0,212,255,0.2); color: var(--primary); padding: 0.4rem 1rem; border-radius: 50px; font-size: 0.8rem; }
</style>
