---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---
<html lang="ar" dir="rtl">
<head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title>التصنيفات - Th.Tech</title></head>
<body>
  <Header />
  <main style="padding:6rem 1rem 4rem; min-height:70vh; background:var(--bg); color:var(--text);">
    <div style="max-width:1200px; margin:0 auto;">
      <h1 style="color:var(--primary); text-align:center; font-size:2.5rem; margin-bottom:3rem;">📂 التصنيفات</h1>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:2rem;">
        
        <!-- التصنيف يفتح صفحة المقالات -->
        <a href="/Th-tech/articles/" style="background:var(--card); padding:2rem; border-radius:15px; border:1px solid var(--border); text-align:center; text-decoration:none; transition:0.3s;">
          <div style="font-size:3rem; margin-bottom:1rem;">🤖</div>
          <h3 style="color:var(--primary); margin-bottom:1rem;">ذكاء اصطناعي</h3>
          <p style="color:var(--text-sec);">عرض المقالات</p>
        </a>
        
        <a href="/Th-tech/articles/" style="background:var(--card); padding:2rem; border-radius:15px; border:1px solid var(--border); text-align:center; text-decoration:none; transition:0.3s;">
          <div style="font-size:3rem; margin-bottom:1rem;">💻</div>
          <h3 style="color:var(--primary); margin-bottom:1rem;">برمجة</h3>
          <p style="color:var(--text-sec);">عرض المقالات</p>
        </a>
        
        <a href="/Th-tech/articles/" style="background:var(--card); padding:2rem; border-radius:15px; border:1px solid var(--border); text-align:center; text-decoration:none; transition:0.3s;">
          <div style="font-size:3rem; margin-bottom:1rem;">🔒</div>
          <h3 style="color:var(--primary); margin-bottom:1rem;">أمن سيبراني</h3>
          <p style="color:var(--text-sec);">عرض المقالات</p>
        </a>

      </div>
    </div>
  </main>
  <Footer />
</body>
</html>
