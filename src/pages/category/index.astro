---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>التصنيفات - Th.Tech</title>
</head>
<body>
  <Header />
  
  <main class="category-page">
    <div class="page-header">
      <h1>📂 استكشف التصنيفات</h1>
      <p>اختر المجال التقني الذي يهمك لعرض المقالات</p>
    </div>

    <div class="categories-grid">
      <!-- تصنيف الذكاء الاصطناعي (رابط) -->
      <a href="/Th-tech/articles/" class="category-card">
        <div class="cat-icon">🤖</div>
        <h3>الذكاء الاصطناعي</h3>
        <p>تعلم الآلة، الشبكات العصبية، والمعالجة اللغوية</p>
        <div class="cat-stats"> 12 مقال</div>
      </a>

      <!-- تصنيف البرمجة (رابط) -->
      <a href="/Th-tech/articles/" class="category-card">
        <div class="cat-icon">💻</div>
        <h3>البرمجة</h3>
        <p>لغات البرمجة، أطر العمل، وهندسة البرمجيات</p>
        <div class="cat-stats">📄 18 مقال</div>
      </a>

      <!-- تصنيف الأمن السيبراني (رابط) -->
      <a href="/Th-tech/articles/" class="category-card">
        <div class="cat-icon"></div>
        <h3>الأمن السيبراني</h3>
        <p>حماية البيانات، الشبكات الآمنة، والاختراق الأخلاقي</p>
        <div class="cat-stats">📄 9 مقالات</div>
      </a>

      <!-- تصنيف الحوسبة السحابية (رابط) -->
      <a href="/Th-tech/articles/" class="category-card">
        <div class="cat-icon">☁️</div>
        <h3>الحوسبة السحابية</h3>
        <p>AWS، Azure، Google Cloud، والبنية التحتية</p>
        <div class="cat-stats"> 10 مقالات</div>
      </a>

      <!-- تصنيف إنترنت الأشياء (رابط) -->
      <a href="/Th-tech/articles/" class="category-card">
        <div class="cat-icon">📡</div>
        <h3>إنترنت الأشياء</h3>
        <p>الأجهزة الذكية، المنازل الذكية، والمدن المتصلة</p>
        <div class="cat-stats">📄 7 مقالات</div>
      </a>

      <!-- تصنيف البلوك تشين (رابط) -->
      <a href="/Th-tech/articles/" class="category-card">
        <div class="cat-icon">⛓️</div>
        <h3>البلوك تشين</h3>
        <p>العملات الرقمية، العقود الذكية، والتطبيقات اللامركزية</p>
        <div class="cat-stats">📄 5 مقالات</div>
      </a>
    </div>
  </main>

  <Footer />
</body>
</html>

<style>
  :root { --bg: #f8fafc; --card: #ffffff; --text: #0f172a; --text-sec: #64748b; --primary: #0284c7; --border: rgba(2,132,199,0.2); }
  html.dark-mode { --bg: #0b1120; --card: #1e293b; --text: #f1f5f9; --text-sec: #94a3b8; --primary: #38bdf8; --border: rgba(56,189,248,0.2); }
  body { background: var(--bg); color: var(--text); font-family: system-ui, sans-serif; margin: 0; }
  
  .category-page { max-width: 1200px; margin: 0 auto; padding: 4rem 1.5rem 6rem; }
  .page-header { text-align: center; margin-bottom: 3rem; }
  .page-header h1 { color: var(--primary); font-size: 2.2rem; margin-bottom: 0.5rem; }
  .page-header p { color: var(--text-sec); font-size: 1.1rem; }
  
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }
  
  /* تنسيق البطاقة كرابط */
  .category-card {
    background: var(--card);
    border: 2px solid var(--border);
    border-radius: 16px;
    padding: 2.5rem 2rem;
    text-align: center;
    text-decoration: none; /* إزالة الخط من الرابط */
    color: var(--text); /* توريث لون النص */
    transition: all 0.3s;
    display: flex;
    flex-direction: column;
    align-items: center;
    cursor: pointer;
  }
  
  .category-card:hover {
    transform: translateY(-8px);
    border-color: var(--primary);
    box-shadow: 0 10px 30px rgba(2,132,199,0.2);
  }
  
  .cat-icon { font-size: 4.5rem; margin-bottom: 1rem; }
  .category-card h3 { color: var(--primary); font-size: 1.4rem; margin-bottom: 0.8rem; }
  .category-card p { color: var(--text-sec); font-size: 0.95rem; line-height: 1.6; margin-bottom: 1.5rem; }
  
  .cat-stats { 
    display: inline-block; 
    background: rgba(2,132,199,0.1); 
    color: var(--primary); 
    padding: 0.5rem 1.2rem; 
    border-radius: 50px; 
    font-size: 0.9rem; 
    font-weight: 700;
  }
  
  @media (max-width: 768px) {
    .categories-grid { grid-template-columns: 1fr; }
    .category-page { padding: 3rem 1rem 4rem; }
  }
</style>
