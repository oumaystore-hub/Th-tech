---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <title>التصنيفات - Th.Tech</title>
</head>
<body>
  <Header />
  
  <main class="categories-page">
    <h1>📂 جميع التصنيفات</h1>
    
    <div class="categories-grid">
      
      <!-- الذكاء الاصطناعي -->
      <article class="category-card">
        <div class="category-icon ai">
          <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2a2 2 0 0 1 2 2c0 .74-.4 1.39-1 1.73V7h1a7 7 0 0 1 7 7h1a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-1v1a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-1H2a1 1 0 0 1-1-1v-3a1 1 0 0 1 1-1h1a7 7 0 0 1 7-7h1V5.73c-.6-.34-1-.99-1-1.73a2 2 0 0 1 2-2z"></path>
            <circle cx="7.5" cy="14.5" r="1.5"></circle>
            <circle cx="16.5" cy="14.5" r="1.5"></circle>
          </svg>
        </div>
        <h2>الذكاء الاصطناعي</h2>
        <p>تعلم الآلة، الشبكات العصبية، والنماذج التوليدية</p>
        <a href="/ai/" class="card-link">تصفح المقالات ←</a>
      </article>

      <!-- البرمجة -->
      <article class="category-card">
        <div class="category-icon programming">
          <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="16 18 22 12 16 6"></polyline>
            <polyline points="8 6 2 12 8 18"></polyline>
          </svg>
        </div>
        <h2>البرمجة</h2>
        <p>لغات التطوير، هندسة البرمجيات، وأفضل الممارسات</p>
        <a href="/programming/" class="card-link">تصفح المقالات ←</a>
      </article>

      <!-- الأمن السيبراني -->
      <article class="category-card">
        <div class="category-icon security">
          <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
          </svg>
        </div>
        <h2>الأمن السيبراني</h2>
        <p>حماية الأنظمة، الاختراق الأخلاقي، والأمان الرقمي</p>
        <a href="/security/" class="card-link">تصفح المقالات ←</a>
      </article>

      <!-- الحوسبة السحابية -->
      <article class="category-card">
        <div class="category-icon cloud">
          <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"></path>
          </svg>
        </div>
        <h2>الحوسبة السحابية</h2>
        <p>AWS، Azure، Google Cloud والبنية التحتية الحديثة</p>
        <a href="/cloud/" class="card-link">تصفح المقالات ←</a>
      </article>

      <!-- البلوك تشين -->
      <article class="category-card">
        <div class="category-icon blockchain">
          <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
            <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
            <line x1="12" y1="22.08" x2="12" y2="12"></line>
          </svg>
        </div>
        <h2>البلوك تشين</h2>
        <p>العملات الرقمية، العقود الذكية، والتقنيات الموزعة</p>
        <a href="/blockchain/" class="card-link">تصفح المقالات ←</a>
      </article>

      <!-- علم البيانات -->
      <article class="category-card">
        <div class="category-icon data">
          <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <ellipse cx="12" cy="5" rx="9" ry="3"></ellipse>
            <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path>
            <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path>
          </svg>
        </div>
        <h2>علم البيانات</h2>
        <p>التحليل الإحصائي، التصور البياني، والبيانات الضخمة</p>
        <a href="/data-science/" class="card-link">تصفح المقالات ←</a>
      </article>

    </div>
  </main>
  
  <Footer />
</body>
</html>

<style>
  .categories-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }
  .categories-page h1 {
    text-align: center;
    color: var(--primary, #38bdf8);
    font-size: 2.5rem;
    margin-bottom: 3rem;
  }
  
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }
  
  .category-card {
    background: var(--card, #1e293b);
    border: 2px solid var(--border, #334155);
    border-radius: 16px;
    padding: 2rem;
    text-align: center;
    transition: all 0.3s ease;
  }
  .category-card:hover {
    transform: translateY(-8px);
    border-color: var(--primary, #38bdf8);
    box-shadow: 0 12px 40px rgba(56, 189, 248, 0.2);
  }
  
  .category-icon {
    width: 100px;
    height: 100px;
    margin: 0 auto 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(56, 189, 248, 0.1);
  }
  .category-icon svg {
    width: 64px;
    height: 64px;
    color: var(--primary, #38bdf8);
  }
  
  .category-card h2 {
    color: var(--text, #f1f5f9);
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .category-card p {
    color: var(--text-sec, #94a3b8);
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }
  
  .card-link {
    display: inline-block;
    padding: 0.6rem 1.5rem;
    background: var(--primary, #38bdf8);
    color: #0f172a;
    text-decoration: none;
    border-radius: 8px;
    font-weight: 600;
    transition: all 0.3s ease;
  }
  .card-link:hover {
    transform: scale(1.05);
    box-shadow: 0 4px 12px rgba(56, 189, 248, 0.4);
  }
  
  @media (max-width: 768px) {
    .categories-grid {
      grid-template-columns: 1fr;
    }
    .category-icon {
      width: 80px;
      height: 80px;
    }
    .category-icon svg {
      width: 48px;
      height: 48px;
    }
  }
</style>
