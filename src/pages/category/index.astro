---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// التصنيفات يدوياً
const categories = [
  { name: 'ذكاء اصطناعي', slug: 'ai', icon: '🤖', count: 1 },
  { name: 'تقنية', slug: 'tech', icon: '📱', count: 1 },
  { name: 'برمجة', slug: 'programming', icon: '💻', count: 0 },
  { name: 'أدوات', slug: 'tools', icon: '🛠️', count: 0 }
];
---

<html lang="ar" dir="rtl">
<head>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" /><meta charset="UTF-8" /><title>التصنيفات</title></head>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<body style="background:#0a0e27; color:#fff; font-family:sans-serif; margin:0;">
  <Header />
  <main style="max-width:1200px; margin:0 auto; padding:2rem 1rem;">
    <h1 style="color:#00d4ff; text-align:center; margin-bottom:2rem;">📂 جميع التصنيفات</h1>
    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(250px, 1fr)); gap:1.5rem;">
      {categories.map(cat => (
        <a href={`/Th-tech/category/${cat.slug}/`} style="background:#1e293b; padding:2rem; border-radius:14px; text-decoration:none; text-align:center; border:1px solid rgba(0,212,255,0.2); transition:0.3s;">
          <div style="font-size:3rem; margin-bottom:1rem;">{cat.icon}</div>
          <h3 style="color:#fff; margin-bottom:0.5rem;">{cat.name}</h3>
          <span style="display:inline-block; background:rgba(0,212,255,0.2); color:#00d4ff; padding:0.4rem 1rem; border-radius:50px; font-size:0.8rem;">{cat.count} مقال</span>
        </a>
      ))}
    </div>
  </main>
  <Footer />
</body>
</html>
