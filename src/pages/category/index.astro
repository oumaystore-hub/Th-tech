---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>التصنيفات - Th.Tech</title>
</head>
<body>
  <Header />
  
  <main class="category-page">
    <div class="page-header">
      <h1>🗂️ استكشف التصنيفات</h1>
      <p>اختر المجال التقني الذي يهمك للدخول إلى مقالاته المتخصصة</p>
    </div>

    <div class="categories-grid">
      <!-- الذكاء الاصطناعي -->
      <a href="/Th-tech/ai/" class="cat-card">
        <div class="cat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2a2 2 0 0 1 2 2c0 .74-.4 1.39-1 1.73V7h1a7 7 0 0 1 7 7h1a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-1v1a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-1H2a1 1 0 0 1-1-1v-3a1 1 0 0 1 1-1h1a7 7 0 0 1 7-7h1V5.73c-.6-.34-1-.99-1-1.73a2 2 0 0 1 2-2z"/>
            <circle cx="12" cy="12" r="3"/>
          </svg>
        </div>
        <h3>الذكاء الاصطناعي</h3>
        <p>تعلم الآلة، الشبكات العصبية، والنماذج التوليدية</p>
        <span class="cat-count">📄 15 مقال</span>
      </a>

      <!-- البرمجة -->
      <a href="/Th-tech/programming/" class="cat-card">
        <div class="cat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="16 18 22 12 16 6"/>
            <polyline points="8 6 2 12 8 18"/>
          </svg>
        </div>
        <h3>البرمجة والتطوير</h3>
        <p>لغات البرمجة، أطر العمل، وهندسة البرمجيات</p>
        <span class="cat-count"> 20 مقال</span>
      </a>

      <!-- علم البيانات -->
      <a href="/Th-tech/data-science/" class="cat-card">
        <div class="cat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="20" x2="18" y2="10"/>
            <line x1="12" y1="20" x2="12" y2="4"/>
            <line x1="6" y1="20" x2="6" y2="14"/>
          </svg>
        </div>
        <h3>علم البيانات</h3>
        <p>تحليل البيانات، التعلم الآلي، والذكاء الأعمال</p>
        <span class="cat-count">📄 12 مقال</span>
      </a>

      <!-- إنترنت الأشياء -->
      <a href="/Th-tech/iot/" class="cat-card">
        <div class="cat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
            <line x1="8" y1="21" x2="16" y2="21"/>
            <line x1="12" y1="17" x2="12" y2="21"/>
          </svg>
        </div>
        <h3>إنترنت الأشياء</h3>
        <p>الأجهزة الذكية، المنازل الذكية، والمدن المتصلة</p>
        <span class="cat-count"> 10 مقالات</span>
      </a>

      <!-- DevOps -->
      <a href="/Th-tech/devops/" class="cat-card">
        <div class="cat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="23 4 23 10 17 10"/>
            <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
          </svg>
        </div>
        <h3>DevOps</h3>
        <p>التكامل المستمر، النشر، والأتمتة</p>
        <span class="cat-count">📄 8 مقالات</span>
      </a>

      <!-- تطوير الجوال -->
      <a href="/Th-tech/mobile/" class="cat-card">
        <div class="cat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="5" y="2" width="14" height="20" rx="2" ry="2"/>
            <line x1="12" y1="18" x2="12.01" y2="18"/>
          </svg>
        </div>
        <h3>تطوير الجوال</h3>
        <p>تطبيقات iOS، Android، Flutter و React Native</p>
        <span class="cat-count">📄 11 مقال</span>
      </a>

      <!-- الشبكات -->
      <a href="/Th-tech/networks/" class="cat-card">
        <div class="cat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <line x1="2" y1="12" x2="22" y2="12"/>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
        </div>
        <h3>الشبكات</h3>
        <p>إدارة الشبكات، بروتوكولات الاتصال، والأمان الشبكي</p>
        <span class="cat-count">📄 10 مقالات</span>
      </a>

      <!-- الحوسبة السحابية -->
      <a href="/Th-tech/cloud/" class="cat-card">
        <div class="cat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/>
          </svg>
        </div>
        <h3>الحوسبة السحابية</h3>
        <p>AWS، Azure، Google Cloud، والبنية التحتية الحديثة</p>
        <span class="cat-count">📄 14 مقال</span>
      </a>

      <!-- الأمن السيبراني -->
      <a href="/Th-tech/security/" class="cat-card">
        <div class="cat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </div>
        <h3>الأمن السيبراني</h3>
        <p>حماية البيانات، الاختراق الأخلاقي، والتشفير</p>
        <span class="cat-count">📄 13 مقال</span>
      </a>

      <!-- البلوك تشين -->
      <a href="/Th-tech/blockchain/" class="cat-card">
        <div class="cat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
            <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
            <line x1="12" y1="22.08" x2="12" y2="12"/>
          </svg>
        </div>
        <h3>البلوك تشين</h3>
        <p>العملات الرقمية، العقود الذكية، وتطبيقات Web3</p>
        <span class="cat-count">📄 9 مقالات</span>
      </a>

      <!-- الحوسبة الكمية -->
      <a href="/Th-tech/quantum-computing/" class="cat-card">
        <div class="cat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3"/>
            <path d="M12 1v6M12 17v6M4.22 4.22l4.24 4.24M15.54 15.54l4.24 4.24M1 12h6M17 12h6M4.22 19.78l4.24-4.24M15.54 8.46l4.24-4.24"/>
          </svg>
        </div>
        <h3>الحوسبة الكمية</h3>
        <p>الكيوبتات، التراكب الكمي، والخوارزميات المتقدمة</p>
        <span class="cat-count">📄 1 مقال</span>
      </a>

      <!-- الحوسبة الطرفية -->
      <a href="/Th-tech/edge-computing/" class="cat-card">
        <div class="cat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
            <line x1="8" y1="21" x2="16" y2="21"/>
            <line x1="12" y1="17" x2="12" y2="21"/>
            <circle cx="12" cy="10" r="2"/>
          </svg>
        </div>
        <h3>الحوسبة الطرفية</h3>
        <p>معالجة البيانات بالقرب من المصدر مع إنترنت الأشياء</p>
        <span class="cat-count"> قريباً</span>
      </a>

      <!-- تقنية 5G -->
      <a href="/Th-tech/5g-technology/" class="cat-card">
        <div class="cat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12.55a11 11 0 0 1 14.08 0"/>
            <path d="M1.42 9a16 16 0 0 1 21.16 0"/>
            <path d="M8.53 16.11a6 6 0 0 1 6.95 0"/>
            <line x1="12" y1="20" x2="12.01" y2="20"/>
          </svg>
        </div>
        <h3>تقنية 5G المتقدمة</h3>
        <p>الجيل الخامس، Network Slicing، والتطبيقات الذكية</p>
        <span class="cat-count"> قريباً</span>
      </a>
    </div>
  </main>

  <Footer />
</body>
</html>

<style>
  :root { 
    --bg: #f8fafc; 
    --card: #ffffff; 
    --text: #0f172a; 
    --text-sec: #64748b; 
    --primary: #0284c7; 
    --border: rgba(2,132,199,0.2); 
  }
  
  html.dark-mode { 
    --bg: #0b1120; 
    --card: #1e293b; 
    --text: #f1f5f9; 
    --text-sec: #94a3b8; 
    --primary: #38bdf8; 
    --border: rgba(56,189,248,0.2); 
  }
  
  body { 
    background: var(--bg); 
    color: var(--text); 
    font-family: system-ui, sans-serif; 
    margin: 0; 
  }
  
  .category-page { 
    max-width: 1200px; 
    margin: 0 auto; 
    padding: 4rem 1.5rem 6rem; 
  }
  
  .page-header { 
    text-align: center; 
    margin-bottom: 3.5rem; 
  }
  
  .page-header h1 { 
    color: var(--primary); 
    font-size: 2.5rem; 
    margin-bottom: 0.8rem; 
  }
  
  .page-header p { 
    color: var(--text-sec); 
    font-size: 1.15rem; 
  }
  
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
  }
  
  .cat-card {
    background: var(--card);
    border: 2px solid var(--border);
    border-radius: 16px;
    padding: 2.5rem 2rem;
    text-align: center;
    text-decoration: none;
    color: var(--text);
    transition: all 0.3s;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  
  .cat-card:hover {
    transform: translateY(-8px);
    border-color: var(--primary);
    box-shadow: 0 10px 30px rgba(2,132,199,0.2);
  }
  
  .cat-icon { 
    width: 4rem;
    height: 4rem;
    margin-bottom: 1rem;
    color: var(--primary);
  }

  .cat-icon svg {
    width: 100%;
    height: 100%;
  }
  
  .cat-card h3 { 
    color: var(--primary); 
    font-size: 1.3rem; 
    margin-bottom: 0.8rem; 
  }
  
  .cat-card p { 
    color: var(--text-sec); 
    font-size: 0.95rem; 
    line-height: 1.6; 
    margin-bottom: 1.2rem; 
  }
  
  .cat-count { 
    background: rgba(2,132,199,0.1); 
    color: var(--primary); 
    padding: 0.4rem 1.2rem; 
    border-radius: 50px; 
    font-size: 0.9rem; 
    font-weight: 600;
  }
  
  @media (max-width: 768px) {
    .categories-grid { 
      grid-template-columns: 1fr; 
    }
    .category-page { 
      padding: 3rem 1rem 4rem; 
    }
    .cat-icon {
      width: 3.5rem;
      height: 3.5rem;
    }
  }
</style>
