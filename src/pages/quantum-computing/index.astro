---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export const title = "الحوسبة الكمية";
---

<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <title>{title} - Th.Tech</title>
</head>
<body>
  <Header />
  <main class="category-page">
    <div class="category-header">
      <h1>⚛️ الحوسبة الكمية</h1>
      <p>استكشف عالم الكيوبتات والتراكب الكمي</p>
    </div>
    <div class="articles-grid">
      <article class="article-card">
        <h2>الحوسبة الكمية: الدليل الشامل</h2>
        <p>من الأساسيات إلى التطبيقات المتقدمة</p>
        <a href="/Th-tech/quantum-computing/quantum-computing-guide/" class="read-more">اقرأ المقال 📖</a>
      </article>
    </div>
  </main>
  <Footer />
</body>
</html>

<style>
  .category-page { max-width: 950px; margin: 0 auto; padding: 4rem 1.5rem; }
  .category-header { text-align: center; margin-bottom: 3rem; }
  .category-header h1 { color: var(--primary); font-size: 2.5rem; }
  .articles-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; }
  .article-card { background: var(--card); border: 2px solid var(--border); border-radius: 12px; padding: 2rem; }
  .read-more { display: inline-block; margin-top: 1rem; color: var(--primary); text-decoration: none; font-weight: 600; }
  :root { --bg: #f8fafc; --card: #fff; --primary: #0284c7; --border: rgba(2,132,199,0.2); }
  html.dark-mode { --bg: #0b1120; --card: #1e293b; --primary: #38bdf8; }
</style>
