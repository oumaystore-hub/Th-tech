---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ShareButtons from '../../components/ShareButtons.astro';

export const title = "الحوسبة الكمية";
export const pubDate = "2026-07-20";
export const description = "دليل شامل عن الحوسبة الكمية من الأساسيات إلى التطبيقات المتقدمة";
---

<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} - Th.Tech</title>
  <meta name="description" content={description} />
</head>
<body>
  <Header />
  
  <main class="category-page">
    <div class="page-header">
      <h1>⚛️ الحوسبة الكمية</h1>
      <p>استكشف عالم الكيوبتات، التراكب الكمي، والخوارزميات المتقدمة</p>
    </div>

    <div class="tabs-nav">
      <button class="tab-btn active" data-tab="basic">📜 أساسيات الحوسبة الكمية</button>
      <button class="tab-btn" data-tab="advanced">🚀 دليل متقدم شامل</button>
    </div>

    <div id="basic" class="tab-content active">
      <article class="article" id="art1">
        <span class="badge">مستوى أساسي</span>
        <h2>مقدمة في الحوسبة الكمية وميكانيكا الكم</h2>
        <div class="meta"> 20 يوليو 2026 | ⏱️ 30 دقيقة</div>
        <p class="intro">الحوسبة الكمية هي نموذج حسابي ثوري يعتمد على مبادئ ميكانيكا الكم بدلاً من الفيزياء الكلاسيكية، مما يسمح بحل مشاكل معقدة بشكل أسي أسرع من الحواسيب التقليدية.</p>
        
        <h3>📚 ما هي الحوسبة الكمية؟</h3>
        <ul>
          <li><strong>الكيوبت (Qubit):</strong> الوحدة الأساسية للمعلومات الكمية، يمكن أن تكون في حالة 0، 1، أو تراكب بينهما.</li>
          <li><strong>التراكب (Superposition):</strong> قدرة الكيوبت على وجود حالات متعددة في نفس الوقت حتى يتم قياسه.</li>
          <li><strong>التشابك (Entanglement):</strong> ارتباط كيوبتين أو أكثر بحيث يؤثر قياس أحدهما على الآخر فورياً.</li>
        </ul>

        <h3>⚙️ كيف تختلف عن الحوسبة الكلاسيكية؟</h3>
        <ul>
          <li>الحواسيب الكلاسيكية تستخدم البتات (0 أو 1)، بينما الكمية تستخدم الكيوبتات.</li>
          <li>المعالجة المتوازية الطبيعية تجعلها مناسبة لمشاكل محددة مثل التشفير والمحاكاة.</li>
          <li>تحتاج إلى بيئات خاصة (تبريد شديد، عزل عن الضوضاء).</li>
        </ul>

        <div class="conclusion" style="background:linear-gradient(135deg,#0284c7,#00d4ff);color:white;padding:2rem;border-radius:12px;margin:2rem 0">
          <h3>💡 الخلاصة:</h3>
          <ul style="list-style:none;padding:0">
            <li>✅ الحوسبة الكمية ليست بديلاً عن الكلاسيكية، بل مكملة لها.</li>
            <li>✅ التركيز حالياً على التطبيقات المتخصصة وليس الحوسبة العامة.</li>
            <li>✅ فهم الأساسيات الكمية هو الخطوة الأولى لدخول هذا المجال.</li>
          </ul>
        </div>
      </article>
    </div>

    <div id="advanced" class="tab-content">
      <div style="text-align:center;padding:3rem 2rem">
        <h2 style="color:var(--primary);margin-bottom:1rem">⚛️ دليل الحوسبة الكمية المتقدم الشامل</h2>
        <p style="color:var(--text-sec);font-size:1.1rem;margin-bottom:2rem">مقال متعمق جداً (3000+ كلمة) يغطي الأسس الرياضية، بناء الكيوبتات، الخوارزميات الكمية، التصحيح الكمي، والتطبيقات العملية</p>
        <!-- ✅ الرابط الصحيح -->
        <a href="/Th-tech/quantum-computing/advanced/" style="display:inline-flex;align-items:center;gap:0.5rem;padding:1rem 2rem;background:var(--primary);color:white;border-radius:10px;text-decoration:none;font-weight:700;font-size:1.1rem;transition:all 0.3s" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 10px 30px rgba(2,132,199,0.4)'" onmouseout="this.style.transform='none';this.style.boxShadow='none'">
          اقرأ الدليل المتقدم الكامل 📖
        </a>
      </div>
    </div>

    <ShareButtons />
  </main>
  
  <Footer />
</body>
</html>

<style>
  :root { --bg: #f8fafc; --card: #fff; --text: #0f172a; --text-sec: #64748b; --primary: #0284c7; --border: rgba(2,132,199,0.2); }
  html.dark-mode { --bg: #0b1120; --card: #1e293b; --text: #f1f5f9; --text-sec: #94a3b8; --primary: #38bdf8; --border: rgba(56,189,248,0.2); }
  body { background: var(--bg); color: var(--text); font-family: system-ui, sans-serif; margin: 0; }
  .category-page { max-width: 950px; margin: 0 auto; padding: 4rem 1.5rem 6rem; }
  .page-header { text-align: center; margin-bottom: 3rem; padding-bottom: 2rem; border-bottom: 2px solid var(--border); }
  .page-header h1 { color: var(--primary); font-size: 2.2rem; margin-bottom: 0.5rem; }
  .page-header p { color: var(--text-sec); font-size: 1.1rem; }
  .tabs-nav { display: flex; gap: 1rem; margin-bottom: 2rem; border-bottom: 2px solid var(--border); padding-bottom: 0.5rem; }
  .tab-btn { background: transparent; border: none; color: var(--text-sec); font-size: 1.1rem; font-weight: 600; padding: 0.8rem 1.5rem; cursor: pointer; border-radius: 8px 8px 0 0; transition: all 0.3s; }
  .tab-btn:hover { color: var(--primary); background: rgba(2,132,199,0.05); }
  .tab-btn.active { color: var(--primary); background: var(--card); box-shadow: 0 -2px 0 var(--primary) inset; }
  .tab-content { display: none; animation: fadeIn 0.4s ease; }
  .tab-content.active { display: block; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  .article { background: var(--card); border: 2px solid var(--border); border-radius: 16px; padding: 2.5rem 2rem; margin-bottom: 3rem; }
  .badge { display: inline-block; background: var(--primary); color: white; padding: 0.4rem 1.2rem; border-radius: 50px; font-size: 0.85rem; margin-bottom: 1rem; }
  .article h2 { color: var(--primary); font-size: 1.8rem; margin: 2rem 0 1rem; }
  .article h3 { color: var(--text); font-size: 1.5rem; margin: 2.5rem 0 1rem; border-bottom: 2px solid var(--border); padding-bottom: 0.5rem; }
  .meta { color: var(--text-sec); font-size: 0.9rem; margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1px dashed var(--border); }
  .intro { font-size: 1.15rem; color: var(--text-sec); margin-bottom: 2.5rem; padding: 2rem; background: rgba(2,132,199,0.05); border-right: 4px solid var(--primary); border-radius: 8px; line-height: 1.9; }
  .article ul { padding-right: 1.5rem; margin: 1.5rem 0; }
  .article li { margin-bottom: 0.8rem; line-height: 1.9; color: var(--text-sec); }
  .article li strong { color: var(--primary); }
  .conclusion ul { list-style: none !important; padding: 0; }
  .conclusion li { color: white !important; font-size: 1.05rem; margin: 0.8rem 0; line-height: 1.8; }
  @media (max-width: 768px) {
    .category-page { padding: 2rem 1rem 3rem !important; }
    .page-header h1 { font-size: 1.6rem !important; }
    .tabs-nav { gap: 0.5rem; flex-direction: column; }
    .tab-btn { font-size: 0.95rem; padding: 0.8rem; text-align: right; border-radius: 8px; }
    .article { padding: 1.5rem 1.2rem !important; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var tabs = document.querySelectorAll('.tab-btn');
    var contents = document.querySelectorAll('.tab-content');
    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        tabs.forEach(function(t) { t.classList.remove('active'); });
        contents.forEach(function(c) { c.classList.remove('active'); });
        tab.classList.add('active');
        document.getElementById(tab.dataset.tab).classList.add('active');
      });
    });
  });
</script>
