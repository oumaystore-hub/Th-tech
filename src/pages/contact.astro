---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>اتصل بنا - Th.Tech</title>
</head>
<body>
  <Header />
  
  <main class="page-main">
    <div class="container">
      <h1 class="page-title">📧 اتصل بنا</h1>
      <p class="page-subtitle">نحن هنا لمساعدتك. لا تتردد في التواصل معنا</p>
      
      <div class="contact-card">
        <div class="contact-info">
          <div class="info-item">
            <span class="info-icon">📧</span>
            <div>
              <h3>البريد الإلكتروني</h3>
              <p>info@thtech.com</p>
            </div>
          </div>
          <div class="info-item">
            <span class="info-icon">📱</span>
            <div>
              <h3>التواصل الاجتماعي</h3>
              <p>تابعنا على منصات التواصل</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</body>
</html>

<style>
  :root {
    --bg-primary: #020617;
    --bg-card: #1e293b;
    --text-primary: #f8fafc;
    --text-secondary: #94a3b8;
    --accent: #00d4ff;
    --border: rgba(0, 212, 255, 0.2);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: 'Segoe UI', system-ui, sans-serif; background: var(--bg-primary); color: var(--text-primary); }
  .container { max-width: 800px; margin: 0 auto; padding: 0 2rem; }
  
  .page-main { padding: 6rem 0 4rem; min-height: 70vh; }
  .page-title { font-size: 2.5rem; text-align: center; margin-bottom: 1rem; color: var(--accent); }
  .page-subtitle { text-align: center; color: var(--text-secondary); margin-bottom: 3rem; font-size: 1.1rem; }
  
  .contact-card {
    background: var(--bg-card);
    padding: 3rem;
    border-radius: 16px;
    border: 1px solid var(--border);
  }
  
  .info-item {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 2rem;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }
  
  .info-item:last-child { border-bottom: none; }
  .info-icon { font-size: 3rem; }
  .info-item h3 { color: var(--accent); margin-bottom: 0.5rem; }
  .info-item p { color: var(--text-secondary); }
  
  @media (max-width: 768px) {
    .container { padding: 0 1.5rem; }
    .contact-card { padding: 2rem 1.5rem; }
  }
</style>
