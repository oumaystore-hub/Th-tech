    align-items: center; 
    justify-content: center; 
    padding: 6rem 1.5rem 1.5rem; 
    animation: fadeIn 0.3s ease;
  }
  .toc-modal.active { display: flex; }
  
  .toc-box { 
    background: var(--card); 
