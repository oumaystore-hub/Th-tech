---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<html lang="ar" dir="rtl" data-theme="dark">
  <head><meta charset="UTF-8" /><title>من نحن - Th.Tech</title></head>
  <body>
    <Header />
    <main class="main">
      <h1>من نحن</h1>
      <p>فريق متخصص في التكنولوجيا والذكاء الاصطناعي.</p>
    </main>
    <Footer />
  </body>
</html>

<style>
  :root{--bg:#0a0a0a;--text:#fff}
  body{background:var(--bg);color:var(--text);margin:0;font-family:system-ui}
  .main{max-width:800px;margin:0 auto;padding:3rem 1rem;text-align:center}
  h1{margin-bottom:1rem}
  p{color:#aaa;line-height:1.8}
</style>
