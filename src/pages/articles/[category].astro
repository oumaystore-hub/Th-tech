---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return ['الكل', 'ذكاء-اصطناعي', 'تقنية', 'ربح-رقمي', 'أداء'].map(c => ({ params: { category: c } }));
}

const { category } = Astro.params;
const all = await getCollection('articles');
const norm = (s) => s.trim().replace(/\s+/g, '-').replace(/^ال/, '');
const current = category === 'الكل' ? null : decodeURIComponent(category);
const filtered = current ? all.filter(a => norm(a.data.category) === norm(current)) : all;
const sorted = filtered.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
const title = current ? current.replace(/-/g, ' ') : 'جميع المقالات';
---

<BaseLayout title={`${title} | Th-tech`}>
  <Header />
  <main class="container">
    <div class="page-header">
      <h1>{title}</h1>
      <p>{sorted.length} مقال متخصص</p>
      <div class="filters">
        {['الكل', 'ذكاء-اصطناعي', 'تقنية', 'ربح-رقمي', 'أداء'].map(c => (
          <a href={`/articles/${c}`} class:list={['chip', { active: norm(c) === norm(category) }]}>
            {c.replace(/-/g, ' ')}
          </a>
        ))}
      </div>
    </div>

    {sorted.length > 0 ? (
      <div class="grid">
        {sorted.map(p => (
          <article class="card">
            <div class="glow-line"></div>
            <div class="info">
              <span class="cat">{p.data.category}</span>
              <time>{p.data.publishDate.toLocaleDateString('ar-EG')}</time>
            </div>
            <h3><a href={`/articles/${p.slug}`}>{p.data.title}</a></h3>
            <p>{p.data.description || 'اقرأ المزيد عن هذا الموضوع المتخصص.'}</p>
          </article>
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <p>لا توجد مقالات في هذا التصنيف حالياً.</p>
      </div>
    )}
  </main>
</BaseLayout>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 4rem 1.5rem; min-height: 70vh; }
  .page-header { text-align: center; margin-bottom: 4rem; }
  .page-header h1 { font-size: 3rem; margin-bottom: 0.5rem; background: linear-gradient(to right, #fff, #94a3b8); -webkit-background-clip: text; color: transparent; }
  .page-header p { color: var(--muted); font-size: 1.1rem; }
  .filters { display: flex; gap: 0.8rem; justify-content: center; flex-wrap: wrap; margin-top: 2.5rem; }
  .chip { padding: 0.6rem 1.5rem; border-radius: 50px; background: var(--surface); border: 1px solid var(--border); color: var(--muted); font-weight: 600; transition: all 0.3s; }
  .chip.active, .chip:hover { background: var(--primary); border-color: var(--primary); color: white; box-shadow: var(--glow); }
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 2rem; }
  .card { position: relative; background: var(--surface); border: 1px solid var(--border); border-radius: 20px; padding: 2rem; transition: 0.4s; overflow: hidden; }
  .card:hover { border-color: rgba(6,182,212,0.4); transform: translateY(-5px); }
  .glow-line { position: absolute; bottom: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, var(--accent), transparent); opacity: 0; transition: 0.4s; }
  .card:hover .glow-line { opacity: 1; }
  .info { display: flex; justify-content: space-between; margin-bottom: 1rem; font-size: 0.8rem; }
  .cat { color: var(--accent); font-weight: 700; letter-spacing: 0.5px; }
  time { color: var(--muted); }
  .card h3 { font-size: 1.3rem; margin-bottom: 0.8rem; line-height: 1.4; }
  .card h3 a { color: var(--text); }
  .card p { color: var(--muted); font-size: 0.95rem; line-height: 1.7; }
  .empty-state { text-align: center; padding: 4rem; color: var(--muted); background: var(--surface); border-radius: 20px; border: 1px dashed var(--border); }
</style>
