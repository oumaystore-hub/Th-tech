---
import { getCollection } from 'astro:content';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const valid = posts.filter(p => p.slug && p.slug.length > 0);
  if (valid.length === 0) return [];
  return valid.map(p => ({ params: { slug: p.slug }, props: { post: p } }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();
const toc = headings.filter(h => h.depth <= 3);

const allPosts = await getCollection('blog');
const related = allPosts.filter(p => p.slug !== post.slug && p.data.category === post.data.category).slice(0, 3);
---

<html lang="ar" dir="rtl" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{post.data.title} - Th.Tech</title>
  </head>
  <body>
    <Header />
    <main class="main">
      <article class="post">
        <span class="tag">{post.data.category}</span>
        <h1>{post.data.title}</h1>
        <div class="meta">
          <time>📅 {post.data.pubDate.toLocaleDateString('ar-SA')}</time>
          <span>✍️ {post.data.author || 'Th.Tech'}</span>
        </div>
        
        <button id="toc-toggle" class="toc-btn">📑 فهرس المقال</button>
        <div id="toc-panel" class="toc-panel">
          <h3>محتويات المقال</h3>
          <ul>
            {toc.map(h => <li><a href={`#${h.slug}`}>{h.text}</a></li>)}
          </ul>
        </div>

        <div class="content"><Content /></div>
      </article>
      
      {related.length > 0 && (
        <section class="related">          <h2>📖 مقالات ذات صلة</h2>
          <div class="grid">
            {related.map(r => <a class="card" href={`/articles/${r.slug}/`}><h3>{r.data.title}</h3></a>)}
          </div>
        </section>
      )}
      <a href="/articles/" class="back">← العودة للمقالات</a>
    </main>
    <Footer />
  </body>
</html>

<style>
  :root{--bg:#0a0a0a;--text:#fff;--card:#1a1a2e}
  body{background:var(--bg);color:var(--text);margin:0;font-family:system-ui}
  .main{max-width:800px;margin:0 auto;padding:2rem 1rem}
  .post{background:var(--card);padding:2rem;border-radius:12px;margin-bottom:2rem;position:relative}
  .tag{background:#3b82f6;color:#fff;padding:0.3rem 0.8rem;border-radius:20px;font-size:0.85rem;font-weight:bold;display:inline-block;margin-bottom:1rem}
  h1{font-size:2rem;margin:0.5rem 0;line-height:1.3}
  .meta{display:flex;gap:1rem;color:#888;font-size:0.9rem;margin-bottom:1.5rem;padding-bottom:1rem;border-bottom:1px solid #333}
  .content{line-height:1.8;color:#ddd}
  .content h2{border-right:4px solid #3b82f6;padding-right:1rem;margin:2rem 0 1rem}
  .content pre{background:#1e1e2e;color:#cdd6f4;padding:1rem;border-radius:8px;overflow-x:auto;direction:ltr;text-align:left}
  
  .toc-btn{
    position:fixed; bottom:20px; right:20px; z-index:999;
    background:linear-gradient(135deg, #3b82f6, #8b5cf6);
    color:#fff; border:none; padding:12px 18px; border-radius:50px;
    font-weight:bold; cursor:pointer; box-shadow:0 4px 15px rgba(59,130,246,0.4);
    animation: glow 2s infinite alternate; font-size:1rem;
  }
  @keyframes glow{from{box-shadow:0 4px 15px rgba(59,130,246,0.4)}to{box-shadow:0 4px 25px rgba(139,92,246,0.7)}}
  
  .toc-panel{
    display:none; position:fixed; top:0; right:0; width:280px; height:100%;
    background:var(--card); padding:2rem; box-shadow:-5px 0 20px rgba(0,0,0,0.3);
    z-index:1000; overflow-y:auto;
  }
  .toc-panel.open{display:block}
  .toc-panel h3{margin-top:0;color:#3b82f6}
  .toc-panel ul{list-style:none;padding:0}
  .toc-panel li{margin:0.75rem 0}
  .toc-panel a{color:#ddd;text-decoration:none}
  .toc-panel a:hover{color:#3b82f6}
  
  .related h2{text-align:center;margin-bottom:1.5rem}
  .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem}
  .card{background:var(--card);padding:1rem;border-radius:8px;text-decoration:none;color:inherit;box-shadow:0 2px 8px rgba(0,0,0,0.3)}
  .card h3{margin:0;font-size:1rem}
  .back{display:inline-block;margin-top:2rem;color:#3b82f6;text-decoration:none;font-weight:bold}</style>

<script is:inline>
  document.getElementById('toc-toggle')?.addEventListener('click', ()=>{
    document.getElementById('toc-panel')?.classList.toggle('open');
  });
  document.addEventListener('click', e=>{
    if(!e.target.closest('.toc-panel') && !e.target.closest('.toc-btn')){
      document.getElementById('toc-panel')?.classList.remove('open');
    }
  });
</script>
