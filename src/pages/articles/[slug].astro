---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  return [
    { params: { slug: 'test' }, props: { 
      title: 'مقال تجريبي',
      category: 'تقنية',
      content: '<h1>مرحباً!</h1><p>هذا مقال تجريبي.</p>'
    }},
    { params: { slug: 'ai-tools-2026' }, props: {
      title: 'أدوات الذكاء الاصطناعي 2026',
      category: 'ذكاء اصطناعي',
      content: '<h1>أدوات الذكاء الاصطناعي</h1><p>محتوى المقال هنا...</p>'
    }}
  ];
}

const { slug } = Astro.params;
const { title, category, content } = Astro.props;
---

<html lang="ar" dir="rtl">
<head><meta charset="UTF-8" /><title>{title}</title></head>
<body style="background:#0a0e27; color:#fff; font-family:sans-serif; margin:0;">
  <Header />
  <main style="max-width:800px; margin:2rem auto; padding:0 1rem;">
    <span style="background:#00d4ff33; color:#00d4ff; padding:0.3rem 0.8rem; border-radius:50px; font-size:0.8rem;">{category}</span>
    <h1 style="margin:1rem 0; color:#00d4ff;">{title}</h1>
    <article style="line-height:1.8; margin-top:2rem;" set:html={content}></article>
    <a href="/Th-tech/articles/" style="display:inline-block; margin-top:3rem; color:#00d4ff; text-decoration:none;">← العودة للمقالات</a>
  </main>
  <Footer />
</body>
</html>
