---
import { getCollection } from 'astro:content';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  // فلتر أمان: نتأكد أن كل مقال له رابط (slug) صحيح
  const validPosts = posts.filter(p => p.slug);
  return validPosts.map(post => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---
<html lang="ar" dir="rtl"><head><meta charset="UTF-8"/><title>{post.data.title}</title></head>
<body style="font-family:sans-serif;background:#0f172a;color:#fff;margin:0">
<Header/>
<main style="max-width:800px;margin:0 auto;padding:2rem">
<a href="/" style="color:#3b82f6">← العودة</a>
<article style="background:#1e293b;padding:2rem;margin-top:2rem;border-radius:12px">
<h1 style="color:#3b82f6">{post.data.title}</h1>
<div style="color:#94a3b8;margin:1rem 0"><Content/></div>
</article>
</main>
<Footer/>
</body></html>
