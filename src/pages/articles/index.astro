---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---
<html lang="ar" dir="rtl">
<head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title>المقالات - Th.Tech</title></head>
<body>
  <Header />
  <main style="padding:6rem 1rem 4rem; min-height:70vh; background:var(--bg); color:var(--text);">
    <div style="max-width:1200px; margin:0 auto;">
      <h1 style="color:var(--primary); text-align:center; font-size:3rem; margin-bottom:1rem; font-weight:800;">📚 مكتبة المقالات</h1>
      <p style="text-align:center; color:var(--text-sec); margin-bottom:4rem; font-size:1.2rem;">استكشف مجموعتنا الشاملة من المقالات التقنية المتخصصة</p>
      
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(380px,1fr)); gap:3rem;">
        
        <!-- مقال 1 -->
        <article style="background:var(--card); border-radius:20px; border:2px solid var(--border); overflow:hidden; transition:0.3s; box-shadow:0 5px 20px rgba(0,0,0,0.1);">
          <img src="https://picsum.photos/seed/ai2026/600/400" alt="مقال" style="width:100%; height:250px; object-fit:cover;" />
          <div style="padding:2.5rem;">
            <span style="display:inline-block; background:var(--primary); color:white; padding:0.5rem 1.5rem; border-radius:50px; font-size:0.9rem; margin-bottom:1.2rem; font-weight:600;">ذكاء اصطناعي</span>
            <h3 style="color:var(--text); margin-bottom:1.2rem; font-size:1.6rem; font-weight:700; line-height:1.3;">مستقبل الذكاء الاصطناعي في 2026 وما بعده</h3>
            <p style="color:var(--text-sec); line-height:2; margin-bottom:1.5rem; font-size:1.05rem;">يستكشف هذا المقال الشامل أحدث التطورات الثورية في مجال الذكاء الاصطناعي وتأثيرها العميق على حياتنا اليومية والمستقبلية. من السيارات ذاتية القيادة المتطورة إلى المساعدات الذكية القادرة على فهم المشاعر الإنسانية، والتشخيص الطبي بدقة تفوق الأطباء البشر. سنتناول أيضاً الأخلاقيات والتحديات التي تواجه هذا المجال الحيوي.</p>
            <div style="margin-top:2rem; padding-top:1.5rem; border-top:2px solid var(--border); font-size:0.95rem; color:var(--text-sec); display:flex; justify-content:space-between; align-items:center;">
              <span style="display:flex; align-items:center; gap:0.5rem;">📅 15 يناير 2026</span>
              <span style="display:flex; align-items:center; gap:0.5rem;">✍️ Th.Tech</span>
            </div>
          </div>
        </article>

        <!-- مقال 2 -->
        <article style="background:var(--card); border-radius:20px; border:2px solid var(--border); overflow:hidden; transition:0.3s; box-shadow:0 5px 20px rgba(0,0,0,0.1);">
          <img src="https://picsum.photos/seed/coding2026/600/400" alt="مقال" style="width:100%; height:250px; object-fit:cover;" />
          <div style="padding:2.5rem;">
            <span style="display:inline-block; background:var(--primary); color:white; padding:0.5rem 1.5rem; border-radius:50px; font-size:0.9rem; margin-bottom:1.2rem; font-weight:600;">برمجة وتطوير</span>
            <h3 style="color:var(--text); margin-bottom:1.2rem; font-size:1.6rem; font-weight:700; line-height:1.3;">الدليل الشامل لاحتراف البرمجة من الصفر</h3>
            <p style="color:var(--text-sec); line-height:2; margin-bottom:1.5rem; font-size:1.05rem;">دليلك المتكامل لبدء رحلة احتراف البرمجة بخطوات عملية مدروسة. سنتعرف على أفضل لغات البرمجة للمبتدئين مثل Python وJavaScript، كيفية بناء مشاريع عملية تعزز مهاراتك، وأهم المصادر التعليمية المجانية. كما سنشرح مفاهيم البرمجة الكائنية، الخوارزميات الأساسية، وكيفية التفكير كمبرمج محترف.</p>
            <div style="margin-top:2rem; padding-top:1.5rem; border-top:2px solid var(--border); font-size:0.95rem; color:var(--text-sec); display:flex; justify-content:space-between; align-items:center;">
              <span>📅 20 فبراير 2026</span>
              <span>✍️ Th.Tech</span>
            </div>
          </div>
        </article>

        <!-- مقال 3 -->
        <article style="background:var(--card); border-radius:20px; border:2px solid var(--border); overflow:hidden; transition:0.3s; box-shadow:0 5px 20px rgba(0,0,0,0.1);">
          <img src="https://picsum.photos/seed/security2026/600/400" alt="مقال" style="width:100%; height:250px; object-fit:cover;" />
          <div style="padding:2.5rem;">
            <span style="display:inline-block; background:var(--primary); color:white; padding:0.5rem 1.5rem; border-radius:50px; font-size:0.9rem; margin-bottom:1.2rem; font-weight:600;">أمن سيبراني</span>
            <h3 style="color:var(--text); margin-bottom:1.2rem; font-size:1.6rem; font-weight:700; line-height:1.3;">الحماية الشاملة لبياناتك في العالم الرقمي</h3>
            <p style="color:var(--text-sec); line-height:2; margin-bottom:1.5rem; font-size:1.05rem;">تعلم استراتيجيات الحماية المتقدمة لبياناتك الشخصية والمهنية من التهديدات السيبرانية المتزايدة. سنشرح كيفية إنشاء كلمات مرور قوية، استخدام المصادقة الثنائية، التعرف على هجمات التصيد الاحتيالي، وتشفير بياناتك الحساسة. بالإضافة إلى أفضل الأدوات والبرامج المجانية والمدفوعة لحماية خصوصيتك.</p>
            <div style="margin-top:2rem; padding-top:1.5rem; border-top:2px solid var(--border); font-size:0.95rem; color:var(--text-sec); display:flex; justify-content:space-between; align-items:center;">
              <span>📅 5 مارس 2026</span>
              <span>✍️ Th.Tech</span>
            </div>
          </div>
        </article>

        <!-- مقال 4 -->
        <article style="background:var(--card); border-radius:20px; border:2px solid var(--border); overflow:hidden; transition:0.3s; box-shadow:0 5px 20px rgba(0,0,0,0.1);">
          <img src="https://picsum.photos/seed/cloud2026/600/400" alt="مقال" style="width:100%; height:250px; object-fit:cover;" />
          <div style="padding:2.5rem;">
            <span style="display:inline-block; background:var(--primary); color:white; padding:0.5rem 1.5rem; border-radius:50px; font-size:0.9rem; margin-bottom:1.2rem; font-weight:600;">حوسبة سحابية</span>
            <h3 style="color:var(--text); margin-bottom:1.2rem; font-size:1.6rem; font-weight:700; line-height:1.3;">الثورة السحابية: مستقبل الأعمال الرقمية</h3>
            <p style="color:var(--text-sec); line-height:2; margin-bottom:1.5rem; font-size:1.05rem;">اكتشف كيف تُحدث الحوسبة السحابية ثورة في طريقة عمل الشركات الحديثة. من AWS وAzure إلى Google Cloud، سنتناول مقارنة شاملة لأفضل المنصات السحابية، كيفية اختيار الأنسب لاحتياجاتك، تقليل التكاليف التشغيلية، وزيادة الإنتاجية بنسبة تصل إلى 300%. حالات دراسية واقعية لشركات نجحت في التحول السحابي.</p>
            <div style="margin-top:2rem; padding-top:1.5rem; border-top:2px solid var(--border); font-size:0.95rem; color:var(--text-sec); display:flex; justify-content:space-between; align-items:center;">
              <span>📅 12 مارس 2026</span>
              <span>✍️ Th.Tech</span>
            </div>
          </div>
        </article>

        <!-- مقال 5 -->
        <article style="background:var(--card); border-radius:20px; border:2px solid var(--border); overflow:hidden; transition:0.3s; box-shadow:0 5px 20px rgba(0,0,0,0.1);">
          <img src="https://picsum.photos/seed/iot2026/600/400" alt="مقال" style="width:100%; height:250px; object-fit:cover;" />
          <div style="padding:2.5rem;">
            <span style="display:inline-block; background:var(--primary); color:white; padding:0.5rem 1.5rem; border-radius:50px; font-size:0.9rem; margin-bottom:1.2rem; font-weight:600;">إنترنت الأشياء IoT</span>
            <h3 style="color:var(--text); margin-bottom:1.2rem; font-size:1.6rem; font-weight:700; line-height:1.3;">المدن الذكية: إنترنت الأشياء يغير حياتنا</h3>
            <p style="color:var(--text-sec); line-height:2; margin-bottom:1.5rem; font-size:1.05rem;">رحلة استكشافية في عالم المدن الذكية وكيف يحوّل إنترنت الأشياء (IoT) البنية التحتية الحضرية. من أنظمة إدارة المرور الذكية التي تقلل الازدحام، إلى شبكات الطاقة المتجددة الذكية، والمباني التي تتكيف تلقائياً مع احتياجات السكان. تقنيات متقدمة تجعل حياتنا أكثر راحة واستدامة.</p>
            <div style="margin-top:2rem; padding-top:1.5rem; border-top:2px solid var(--border); font-size:0.95rem; color:var(--text-sec); display:flex; justify-content:space-between; align-items:center;">
              <span>📅 18 مارس 2026</span>
              <span>✍️ Th.Tech</span>
            </div>
          </div>
        </article>

        <!-- مقال 6 -->
        <article style="background:var(--card); border-radius:20px; border:2px solid var(--border); overflow:hidden; transition:0.3s; box-shadow:0 5px 20px rgba(0,0,0,0.1);">
          <img src="https://picsum.photos/seed/blockchain2026/600/400" alt="مقال" style="width:100%; height:250px; object-fit:cover;" />
          <div style="padding:2.5rem;">
            <span style="display:inline-block; background:var(--primary); color:white; padding:0.5rem 1.5rem; border-radius:50px; font-size:0.9rem; margin-bottom:1.2rem; font-weight:600;">بلوك تشين</span>
            <h3 style="color:var(--text); margin-bottom:1.2rem; font-size:1.6rem; font-weight:700; line-height:1.3;">تقنية البلوك تشين: أبعد من العملات المشفرة</h3>
            <p style="color:var(--text-sec); line-height:2; margin-bottom:1.5rem; font-size:1.05rem;">استكشاف متعمق لتطبيقات البلوك تشين الثورية في قطاعات متعددة. من الرعاية الصحية وحماية السجلات الطبية، إلى سلاسل التوريد الشفافة، وأنظمة التصويت الإلكتروني الآمنة. كيف تُحدث هذه التقنية ثورة في الثقة الرقمية وتقلل من الحاجة للوسطاء. مشاريع ناجحة حول العالم تستخدم البلوك تشين لحل مشاكل حقيقية.</p>
            <div style="margin-top:2rem; padding-top:1.5rem; border-top:2px solid var(--border); font-size:0.95rem; color:var(--text-sec); display:flex; justify-content:space-between; align-items:center;">
              <span>📅 25 مارس 2026</span>
              <span>✍️ Th.Tech</span>
            </div>
          </div>
        </article>

      </div>
    </div>
  </main>
  <Footer />
</body>
</html>
