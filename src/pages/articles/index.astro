---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// قائمة المقالات يدوياً (بسيط ومضمون)
const posts = [
  {
    slug: 'test',
    title: 'مقال تجريبي',
    description: 'هذا مقال اختبار',
    category: 'تقنية',
    pubDate: new Date('2026-01-15'),
    author: 'Th.Tech'
  },
  {
    slug: 'ai-tools-2026',
    title: 'أدوات الذكاء الاصطناعي 2026',
    description: 'أفضل الأدوات',
    category: 'ذكاء اصطناعي',
    pubDate: new Date('2026-06-18'),
    author: 'Th.Tech'
  }
];
---

<html lang="ar" dir="rtl">
<head>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" /><meta charset="UTF-8" /><title>المقالات</title></head>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<body style="background:#0a0e27; color:#fff; font-family:sans-serif; margin:0;">
  <Header />
  <main style="max-width:1200px; margin:0 auto; padding:2rem 1rem;">
    <h1 style="color:#00d4ff; text-align:center;">📚 المقالات</h1>
    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(300px, 1fr)); gap:1.5rem; margin-top:2rem;">
      {posts.map(post => (
        <article style="background:#1e293b; padding:1.5rem; border-radius:12px; border:1px solid rgba(0,212,255,0.2);">
          <span style="background:rgba(0,212,255,0.2); color:#00d4ff; padding:0.3rem 0.8rem; border-radius:50px; font-size:0.75rem; display:inline-block; margin-bottom:0.8rem;">{post.category}</span>
          <h3 style="margin:0.5rem 0;"><a href={`/Th-tech/articles/${post.slug}/`} style="color:#fff; text-decoration:none;">{post.title}</a></h3>
          <p style="color:#94a3b8; font-size:0.85rem;">{post.description}</p>
          <small style="color:#64748b;">📅 {post.pubDate.toLocaleDateString('en-US', {year:'numeric', month:'short', day:'numeric'})}</small>
        </article>
      ))}
    </div>
  </main>
  <Footer />
</body>
</html>
