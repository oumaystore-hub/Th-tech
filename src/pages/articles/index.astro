---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>المقالات - Th.Tech</title>
</head>
<body>
  <Header />
  
  <main class="articles-container" id="articlesMain">
    <header class="page-header">
      <h1>📚 المكتبة التقنية الشاملة</h1>
      <p>مقالات معمّقة، شروحات تقنية مفصّلة، وتحليلات مستقبلية</p>
    </header>

    <!-- قائمة العناوين العائمة -->
    <div class="toc-float-btn" id="tocBtn" title="قائمة العناوين">📑</div>
    
    <div class="toc-modal" id="tocModal">
      <div class="toc-content">
        <div class="toc-header">
          <h3>📑 قائمة العناوين</h3>
          <button class="close-toc" id="closeToc">✕</button>
        </div>
        <nav class="toc-nav" id="tocNav">
          <!-- سيتم ملؤها بالجافاسكريبت -->
        </nav>
      </div>
    </div>

    <!-- مقال 1 -->
    <article class="long-article" id="article1">
      <div class="article-header">
        <span class="category-badge">البرمجة والتطوير</span>
        <h2>البرمجة الكائنية المتقدمة: من المفاهيم الأساسية إلى تصميم الأنظمة المعقدة</h2>
        <div class="meta">
          <span>📅 25 يونيو 2026</span>
          <span>⏱️ 25 دقيقة قراءة</span>
          <span>✍️ فريق التطوير</span>
        </div>
      </div>
      
      <div class="article-content">
        <p class="intro">تُعد البرمجة الكائنية (Object-Oriented Programming - OOP) أحد أهم الركائز الأساسية في هندسة البرمجيات الحديثة.</p>

        <h3>1. المبادئ الأربعة الأساسية للـ OOP</h3>
        <ul class="tech-list">
          <li><strong>التغليف (Encapsulation):</strong> حماية البيانات الداخلية للكائنات ومنع الوصول المباشر إليها.</li>
          <li><strong>الوراثة (Inheritance):</strong> إنشاء تسلسل هرمي للفئات يسمح بإعادة استخدام الكود.</li>
          <li><strong>تعدد الأشكال (Polymorphism):</strong> قدرة الكائنات المختلفة على الاستجابة لنفس الاستدعاء بطرق مختلفة.</li>
          <li><strong>التجريد (Abstraction):</strong> إخفاء التعقيدات الداخلية وعرض الوظائف الأساسية فقط.</li>
        </ul>

        <h3>2. مبادئ SOLID الخمسة</h3>
        <p>تُشكل مبادئ SOLID الركيزة الأساسية لكتابة كود نظيف وقابل للصيانة:</p>
        <ul class="tech-list">
          <li><strong>S - Single Responsibility:</strong> كل كلاس يجب أن يكون له مسؤولية واحدة فقط.</li>
          <li><strong>O - Open/Closed:</strong> الكيانات البرمجية يجب أن تكون مفتوحة للتوسيع لكن مغلقة للتعديل.</li>
          <li><strong>L - Liskov Substitution:</strong> الكائنات الفرعية يجب أن تكون قابلة للاستبدال.</li>
          <li><strong>I - Interface Segregation:</strong> الواجهات الصغيرة المتخصصة أفضل.</li>
          <li><strong>D - Dependency Inversion:</strong> الاعتماد على التجريدات وليس على التطبيقات الملموسة.</li>
        </ul>

        <h3>3. أنماط التصميم (Design Patterns)</h3>
        <p>أنماط التصميم هي حلول مجرّبة لمشاكل متكررة في هندسة البرمجيات:</p>
        <ul class="tech-list">
          <li><strong>أنماط الإنشاء:</strong> Singleton، Factory، Builder</li>
          <li><strong>أنماط الهيكلية:</strong> Adapter، Decorator، Facade</li>
          <li><strong>أنماط السلوكية:</strong> Observer، Strategy، Command</li>
        </ul>
      </div>
    </article>

    <!-- مقال 2 -->
    <article class="long-article" id="article2">
      <div class="article-header">
        <span class="category-badge">الشبكات والبنية التحتية</span>
        <h2>الشبكات المعرفة بالبرمجيات (SDN): ثورة في إدارة البنية التحتية</h2>
        <div class="meta">
          <span>📅 28 يونيو 2026</span>
          <span>⏱️ 20 دقيقة قراءة</span>
          <span>✍️ فريق الشبكات</span>
        </div>
      </div>
      
      <div class="article-content">
        <p class="intro">تشهد إدارة الشبكات تحولاً جذرياً مع ظهور تقنية الشبكات المعرفة بالبرمجيات.</p>

        <h3>1. البنية المعمارية لـ SDN</h3>
        <ul class="tech-list">
          <li><strong>طبقة التطبيقات:</strong> برامج إدارة الشبكة، الأمان، التحليلات.</li>
          <li><strong>طبقة التحكم:</strong> المتحكم المركزي (SDN Controller).</li>
          <li><strong>طبقة البنية التحتية:</strong> المفاتيح والموجهات.</li>
        </ul>

        <h3>2. المزايا الاستراتيجية</h3>
        <ul class="tech-list">
          <li>المركزية والبرمجة</li>
          <li>المرونة والتكيّف</li>
          <li>تقليل التكاليف</li>
          <li>الابتكار السريع</li>
        </ul>
      </div>
    </article>

    <!-- مقال 3 -->
    <article class="long-article" id="article3">
      <div class="article-header">
        <span class="category-badge">تحليل البيانات</span>
        <h2>علم البيانات التطبيقي: من جمع البيانات إلى نماذج التنبؤ</h2>
        <div class="meta">
          <span>📅 1 يوليو 2026</span>
          <span>⏱️ 28 دقيقة قراءة</span>
          <span>✍️ فريق البيانات</span>
        </div>
      </div>
      
      <div class="article-content">
        <p class="intro">في عصر البيانات الضخمة، يُعد علم البيانات أحد أهم المهارات المطلوبة.</p>

        <h3>1. دورة حياة مشروع علم البيانات</h3>
        <ul class="tech-list">
          <li>فهم المشكلة والأهداف</li>
          <li>جمع البيانات</li>
          <li>التنظيف والمعالجة المسبقة</li>
          <li>الاستكشاف والتحليل (EDA)</li>
          <li>هندسة الخصائص</li>
          <li>النمذجة والتدريب</li>
        </ul>

        <h3>2. الخوارزميات الأساسية</h3>
        <ul class="tech-list">
          <li><strong>التعلم الموجّه:</strong> الانحدار، أشجار القرار، الشبكات العصبية</li>
          <li><strong>التعلم غير الموجّه:</strong> التجميع، PCA</li>
        </ul>
      </div>
    </article>

  </main>

  <Footer />
</body>
</html>

<style>
  :root {
    --bg: #f8fafc;
    --card: #ffffff;
    --text: #0f172a;
    --text-sec: #64748b;
    --primary: #0284c7;
    --border: rgba(2,132,199,0.2);
  }

  html.dark-mode {
    --bg: #0b1120;
    --card: #1e293b;
    --text: #f1f5f9;
    --text-sec: #94a3b8;
    --primary: #38bdf8;
    --border: rgba(56,189,248,0.2);
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: system-ui, sans-serif;
  }

  .articles-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 4rem 1.5rem 6rem;
  }
  
  .page-header {
    text-align: center;
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 2px solid var(--border);
  }
  .page-header h1 {
    font-size: 2.5rem;
    color: var(--primary);
    margin-bottom: 1rem;
  }
  .page-header p {
    font-size: 1.2rem;
    color: var(--text-sec);
  }

  /* زر قائمة العناوين */
  .toc-float-btn {
    position: fixed;
    bottom: 30px;
    left: 30px;
    width: 60px;
    height: 60px;
    background: linear-gradient(135deg, var(--primary), #00d4ff);
    border: none;
    border-radius: 50%;
    color: white;
    font-size: 1.6rem;
    cursor: pointer;
    box-shadow: 0 0 20px rgba(2,132,199,0.6);
    z-index: 998;
    transition: all 0.3s;
  }
  
  .toc-float-btn:hover {
    transform: scale(1.1);
    box-shadow: 0 0 30px rgba(2,132,199,0.8);
  }

  /* نافذة قائمة العناوين */
  .toc-modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0,0,0,0.7);
    z-index: 999;
    align-items: center;
    justify-content: center;
  }

  .toc-modal.active {
    display: flex;
  }

  .toc-content {
    background: var(--card);
    border-radius: 20px;
    max-width: 500px;
    width: 90%;
    max-height: 80vh;
    overflow-y: auto;
    padding: 2rem;
  }

  .toc-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid var(--border);
  }

  .toc-header h3 {
    color: var(--primary);
    font-size: 1.5rem;
  }

  .close-toc {
    background: none;
    border: none;
    color: var(--text);
    font-size: 1.8rem;
    cursor: pointer;
    padding: 0.5rem;
  }

  .toc-nav a {
    display: block;
    padding: 1rem;
    color: var(--text);
    text-decoration: none;
    border-bottom: 1px solid var(--border);
    transition: all 0.3s;
  }

  .toc-nav a:hover {
    background: var(--bg);
    color: var(--primary);
    padding-right: 1.5rem;
  }

  .long-article {
    background: var(--card);
    border: 2px solid var(--border);
    border-radius: 20px;
    padding: 2.5rem;
    margin-bottom: 3rem;
  }

  .article-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 2px solid var(--border);
  }

  .category-badge {
    display: inline-block;
    background: var(--primary);
    color: white;
    padding: 0.5rem 1.2rem;
    border-radius: 50px;
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .long-article h2 {
    font-size: 1.8rem;
    color: var(--text);
    margin-bottom: 1rem;
  }

  .meta {
    display: flex;
    gap: 1.5rem;
    color: var(--text-sec);
    font-size: 0.95rem;
  }

  .article-content {
    font-size: 1.05rem;
    line-height: 1.9;
  }

  .intro {
    font-size: 1.15rem;
    color: var(--text-sec);
    margin-bottom: 2rem;
    padding-right: 1rem;
    border-right: 3px solid var(--primary);
  }

  .article-content h3 {
    font-size: 1.4rem;
    color: var(--primary);
    margin: 2rem 0 1rem;
  }

  .tech-list {
    margin: 1.5rem 0;
    padding-right: 1.5rem;
  }
  .tech-list li {
    margin-bottom: 0.8rem;
    line-height: 1.8;
  }

  @media (max-width: 768px) {
    .articles-container { padding: 3rem 1rem 4rem; }
    .long-article { padding: 1.5rem; }
    .toc-float-btn {
      width: 50px;
      height: 50px;
      bottom: 20px;
      left: 20px;
      font-size: 1.4rem;
    }
  }
</style>

<script>
  // قائمة العناوين
  const tocBtn = document.getElementById('tocBtn');
  const tocModal = document.getElementById('tocModal');
  const closeToc = document.getElementById('closeToc');
  const tocNav = document.getElementById('tocNav');

  // بناء قائمة العناوين تلقائياً
  const articles = document.querySelectorAll('.long-article');
  articles.forEach((article, index) => {
    const title = article.querySelector('h2');
    if (title) {
      const link = document.createElement('a');
      link.href = `#article${index + 1}`;
      link.textContent = title.textContent;
      link.addEventListener('click', (e) => {
        e.preventDefault();
        article.scrollIntoView({ behavior: 'smooth', block: 'start' });
        tocModal.classList.remove('active');
      });
      tocNav.appendChild(link);
    }
  });

  if (tocBtn) {
    tocBtn.addEventListener('click', () => {
      tocModal.classList.add('active');
    });
  }

  if (closeToc) {
    closeToc.addEventListener('click', () => {
      tocModal.classList.remove('active');
    });
  }

  if (tocModal) {
    tocModal.addEventListener('click', (e) => {
      if (e.target === tocModal) {
        tocModal.classList.remove('active');
      }
    });
  }
</script>
