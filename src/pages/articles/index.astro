---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>المقالات - Th.Tech</title>
</head>
<body>
  <Header />
  
  <main class="articles-wrapper">
    <header class="page-header">
      <h1>📚 المكتبة التقنية الشاملة</h1>
      <p>مقالات معمّقة، شروحات تقنية مفصّلة، وتحليلات مستقبلية</p>
    </header>

    <!-- زر العناوين المنسق -->
    <button class="toc-btn" id="tocBtn" aria-label="قائمة العناوين">
      <span class="toc-icon">📑</span>
    </button>
    
    <!-- نافذة العناوين المنسقة -->
    <div class="toc-modal" id="tocModal">
      <div class="toc-card">
        <div class="toc-header">
          <h3>📑 فهرس المقالات</h3>
          <button class="toc-close" id="tocClose"></button>
        </div>
        <nav class="toc-links" id="tocLinks"></nav>
      </div>
    </div>

    <!-- المقالات -->
    <article class="article-block" id="art1">
      <span class="badge">البرمجة</span>
      <h2>البرمجة الكائنية المتقدمة: المفاهيم الأساسية وتصميم الأنظمة</h2>
      <div class="meta"> 25 يونيو 2026 | ⏱️ 15 دقيقة</div>
      <p class="lead">تُعد البرمجة الكائنية ركيزة أساسية في هندسة البرمجيات الحديثة...</p>
      <h3>1. المبادئ الأربعة</h3>
      <ul><li>التغليف، الوراثة، تعدد الأشكال، التجريد.</li></ul>
      <h3>2. مبادئ SOLID</h3>
      <p>قواعد تصميمية تضمن كوداً نظيفاً وقابلاً للصيانة.</p>
    </article>

    <article class="article-block" id="art2">
      <span class="badge">الشبكات</span>
      <h2>الشبكات المعرفة بالبرمجيات (SDN): ثورة الإدارة</h2>
      <div class="meta">📅 28 يونيو 2026 | ⏱️ 12 دقيقة</div>
      <p class="lead">فصل مستوى التحكم عن مستوى البيانات يغير قواعد اللعبة...</p>
      <h3>1. البنية المعمارية</h3>
      <ul><li>طبقة التطبيقات، التحكم، البنية التحتية.</li></ul>
    </article>

    <article class="article-block" id="art3">
      <span class="badge">البيانات</span>
      <h2>علم البيانات التطبيقي: من الجمع إلى النماذج التنبؤية</h2>
      <div class="meta">📅 1 يوليو 2026 | ⏱️ 18 دقيقة</div>
      <p class="lead">دورة حياة مشروع البيانات تتطلب دقة في كل مرحلة...</p>
      <h3>1. مراحل المشروع</h3>
      <ul><li>الفهم، الجمع، التنظيف، النمذجة، النشر.</li></ul>
    </article>
  </main>

  <Footer />
</body>
</html>

<style>
  :root { --bg: #f8fafc; --card: #ffffff; --text: #0f172a; --text-sec: #64748b; --primary: #0284c7; --border: rgba(2,132,199,0.2); }
  html.dark-mode { --bg: #0b1120; --card: #1e293b; --text: #f1f5f9; --text-sec: #94a3b8; --primary: #38bdf8; --border: rgba(56,189,248,0.2); }
  body { background: var(--bg); color: var(--text); font-family: system-ui, sans-serif; margin: 0; }
  .articles-wrapper { max-width: 900px; margin: 0 auto; padding: 4rem 1.5rem 6rem; }
  .page-header { text-align: center; margin-bottom: 3rem; border-bottom: 2px solid var(--border); padding-bottom: 2rem; }
  .page-header h1 { color: var(--primary); font-size: 2.2rem; margin-bottom: 0.5rem; }
  .page-header p { color: var(--text-sec); font-size: 1.1rem; }
  
  /* زر العناوين الأنيق */
  .toc-btn {
    position: fixed; bottom: 25px; left: 25px;
    width: 48px; height: 48px; border-radius: 50%;
    background: var(--primary); border: none; cursor: pointer;
    box-shadow: 0 4px 15px rgba(2,132,199,0.4);
    display: flex; align-items: center; justify-content: center;
    transition: all 0.3s; z-index: 998;
  }
  .toc-btn:hover { transform: scale(1.1); box-shadow: 0 6px 20px rgba(2,132,199,0.6); }
  .toc-icon { font-size: 1.4rem; }
  
  /* نافذة العناوين المتناسقة */
  .toc-modal { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 999; align-items: center; justify-content: center; backdrop-filter: blur(4px); }
  .toc-modal.active { display: flex; }
  .toc-card { background: var(--card); width: 90%; max-width: 450px; border-radius: 16px; padding: 1.5rem; box-shadow: 0 10px 30px rgba(0,0,0,0.3); border: 1px solid var(--border); }
  .toc-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.2rem; padding-bottom: 0.8rem; border-bottom: 1px solid var(--border); }
  .toc-header h3 { color: var(--primary); font-size: 1.3rem; margin: 0; }
  .toc-close { background: none; border: none; color: var(--text-sec); font-size: 1.5rem; cursor: pointer; padding: 0.2rem; }
  .toc-links { display: flex; flex-direction: column; gap: 0.5rem; max-height: 60vh; overflow-y: auto; }
  .toc-links a {
    color: var(--text); text-decoration: none; padding: 0.8rem 1rem;
    border-radius: 8px; border-right: 3px solid transparent;
    transition: all 0.2s; font-size: 0.95rem; line-height: 1.4;
  }
  .toc-links a:hover { background: var(--bg); border-right-color: var(--primary); color: var(--primary); padding-right: 1.2rem; }
  
  /* تنسيق المقالات */
  .article-block { background: var(--card); border: 1px solid var(--border); border-radius: 16px; padding: 2rem; margin-bottom: 2.5rem; }
  .badge { display: inline-block; background: var(--primary); color: white; padding: 0.3rem 1rem; border-radius: 50px; font-size: 0.85rem; margin-bottom: 1rem; }
  .article-block h2 { color: var(--text); font-size: 1.6rem; margin-bottom: 0.5rem; }
  .meta { color: var(--text-sec); font-size: 0.9rem; margin-bottom: 1.5rem; }
  .lead { font-size: 1.1rem; color: var(--text-sec); border-right: 3px solid var(--primary); padding-right: 1rem; margin-bottom: 1.5rem; line-height: 1.6; }
  .article-block h3 { color: var(--primary); margin: 1.5rem 0 0.8rem; font-size: 1.25rem; }
  .article-block ul { padding-right: 1.5rem; margin-bottom: 1rem; }
  .article-block li { margin-bottom: 0.5rem; line-height: 1.6; }
  
  @media (max-width: 768px) {
    .articles-wrapper { padding: 3rem 1rem 4rem; }
    .toc-btn { width: 44px; height: 44px; bottom: 20px; left: 20px; }
    .article-block { padding: 1.5rem; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('tocBtn');
    const modal = document.getElementById('tocModal');
    const close = document.getElementById('tocClose');
    const linksContainer = document.getElementById('tocLinks');
    
    // بناء القائمة تلقائياً
    document.querySelectorAll('.article-block').forEach(art => {
      const title = art.querySelector('h2');
      if(title) {
        const a = document.createElement('a');
        a.href = '#' + art.id;
        a.textContent = title.textContent;
        a.onclick = (e) => { e.preventDefault(); art.scrollIntoView({behavior:'smooth'}); modal.classList.remove('active'); };
        linksContainer.appendChild(a);
      }
    });
    
    btn.onclick = () => modal.classList.add('active');
    close.onclick = () => modal.classList.remove('active');
    modal.onclick = (e) => { if(e.target === modal) modal.classList.remove('active'); };
  });
</script>
