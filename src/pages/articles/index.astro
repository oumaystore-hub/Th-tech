---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---
<html lang="ar" dir="rtl">
<head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title>المقالات - Th.Tech</title></head>
<body>
  <Header />
  <main style="padding:6rem 1rem 4rem; min-height:70vh; background:var(--bg); color:var(--text);">
    <div style="max-width:1200px; margin:0 auto;">
      <h1 style="color:var(--primary); text-align:center; font-size:2.5rem; margin-bottom:3rem;">📚 جميع المقالات</h1>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(320px,1fr)); gap:2rem;">
        
        <article style="background:var(--card); border-radius:15px; border:1px solid var(--border); overflow:hidden;">
          <!-- صورة توضيحية -->
          <img src="https://picsum.photos/seed/ai/600/400" alt="مقال" style="width:100%; height:200px; object-fit:cover;" />
          <div style="padding:1.5rem;">
            <span style="display:inline-block; background:var(--primary); color:white; padding:0.3rem 1rem; border-radius:50px; font-size:0.85rem; margin-bottom:1rem;">ذكاء اصطناعي</span>
            <h3 style="color:var(--text); margin-bottom:1rem;">مستقبل الذكاء الاصطناعي في 2026</h3>
            <p style="color:var(--text-sec); line-height:1.6;">هذا مقال تجريبي يشرح أحدث تطورات الذكاء الاصطناعي وتأثيرها على حياتنا اليومية.</p>
            <div style="margin-top:1.5rem; padding-top:1rem; border-top:1px solid var(--border); font-size:0.9rem; color:var(--text-sec);"> 15 يناير 2026 | ️ Th.Tech</div>
          </div>
        </article>

        <article style="background:var(--card); border-radius:15px; border:1px solid var(--border); overflow:hidden;">
          <!-- صورة توضيحية -->
          <img src="https://picsum.photos/seed/coding/600/400" alt="مقال" style="width:100%; height:200px; object-fit:cover;" />
          <div style="padding:1.5rem;">
            <span style="display:inline-block; background:var(--primary); color:white; padding:0.3rem 1rem; border-radius:50px; font-size:0.85rem; margin-bottom:1rem;">برمجة</span>
            <h3 style="color:var(--text); margin-bottom:1rem;">تعلم البرمجة في أسبوع</h3>
            <p style="color:var(--text-sec); line-height:1.6;">دليل شامل للمبتدئين لتعلم أساسيات البرمجة وتطوير تطبيقات الويب.</p>
            <div style="margin-top:1.5rem; padding-top:1rem; border-top:1px solid var(--border); font-size:0.9rem; color:var(--text-sec);">📅 20 فبراير 2026 | ✍️ Th.Tech</div>
          </div>
        </article>

      </div>
    </div>
  </main>
  <Footer />
</body>
</html>
