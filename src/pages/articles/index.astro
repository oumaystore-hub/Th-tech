---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>المقالات - Th.Tech</title>
</head>
<body>
  <Header />
  
  <main class="articles-main">
    <div class="page-title">
      <h1>📚 جميع المقالات</h1>
      <p>محتوى تقني معمّق وشامل</p>
    </div>

    <!-- زر الفهرس -->
    <button class="index-btn" id="indexBtn">📑</button>
    
    <!-- نافذة الفهرس -->
    <div class="index-modal" id="indexModal">
      <div class="index-box">
        <div class="index-head">
          <h3>📑 فهرس المقالات</h3>
          <button class="close-index" id="closeIndex">✕</button>
        </div>
        <div class="index-list" id="indexList"></div>
      </div>
    </div>

    <!-- المقالات -->
    <article class="article-card" id="art1">
      <span class="tag">البرمجة</span>
      <h2>البرمجة الكائنية المتقدمة</h2>
      <div class="article-meta">📅 25 يونيو | ⏱️ 15 دقيقة</div>
      <p class="summary">شرح مفصل لمبادئ OOP وSOLID وأنماط التصميم...</p>
      <h3>المحتوى:</h3>
      <ul>
        <li>المبادئ الأربعة: التغليف، الوراثة، تعدد الأشكال، التجريد</li>
        <li>مبادئ SOLID الخمسة</li>
        <li>أنماط التصميم الشائعة</li>
      </ul>
    </article>

    <article class="article-card" id="art2">
      <span class="tag">الشبكات</span>
      <h2>الشبكات المعرفة بالبرمجيات (SDN)</h2>
      <div class="article-meta">📅 28 يونيو | ⏱️ 12 دقيقة</div>
      <p class="summary">كيف تُحدث SDN ثورة في إدارة البنية التحتية...</p>
      <h3>المحتوى:</h3>
      <ul>
        <li>البنية المعمارية لـ SDN</li>
        <li>المزايا والتطبيقات</li>
        <li>أدوات ومشاريع عملية</li>
      </ul>
    </article>

    <article class="article-card" id="art3">
      <span class="tag">البيانات</span>
      <h2>علم البيانات التطبيقي</h2>
      <div class="article-meta">📅 1 يوليو | ⏱️ 18 دقيقة</div>
      <p class="summary">من جمع البيانات إلى بناء النماذج التنبؤية...</p>
      <h3>المحتوى:</h3>
      <ul>
        <li>دورة حياة مشروع البيانات</li>
        <li>الخوارزميات الأساسية</li>
        <li>الأدوات والتقنيات</li>
      </ul>
    </article>
  </main>

  <Footer />
</body>
</html>

<style>
  :root { --bg: #f8fafc; --card: #ffffff; --text: #0f172a; --text-sec: #64748b; --primary: #0284c7; --border: rgba(2,132,199,0.2); }
  html.dark-mode { --bg: #0b1120; --card: #1e293b; --text: #f1f5f9; --text-sec: #94a3b8; --primary: #38bdf8; --border: rgba(56,189,248,0.2); }
  body { background: var(--bg); color: var(--text); font-family: system-ui, sans-serif; margin: 0; }
  
  .articles-main { max-width: 900px; margin: 0 auto; padding: 4rem 1.5rem 6rem; }
  .page-title { text-align: center; margin-bottom: 3rem; border-bottom: 2px solid var(--border); padding-bottom: 2rem; }
  .page-title h1 { color: var(--primary); font-size: 2rem; margin-bottom: 0.5rem; }
  .page-title p { color: var(--text-sec); }
  
  /* زر الفهرس المنسق */
  .index-btn {
    position: fixed; bottom: 30px; left: 30px;
    width: 50px; height: 50px; border-radius: 50%;
    background: var(--primary); border: none; cursor: pointer;
    box-shadow: 0 4px 15px rgba(2,132,199,0.4);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.5rem; transition: all 0.3s; z-index: 998;
  }
  .index-btn:hover { transform: scale(1.1); box-shadow: 0 6px 20px rgba(2,132,199,0.6); }
  
  /* نافذة الفهرس المتناسقة */
  .index-modal {
    display: none; position: fixed; inset: 0;
    background: rgba(0,0,0,0.7); z-index: 999;
    align-items: center; justify-content: center;
    backdrop-filter: blur(5px);
  }
  .index-modal.active { display: flex; }
  
  .index-box {
    background: var(--card);
    width: 90%; max-width: 500px;
    border-radius: 20px;
    padding: 2rem;
    border: 1px solid var(--border);
    box-shadow: 0 15px 40px rgba(0,0,0,0.4);
  }
  
  .index-head {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 1.5rem; padding-bottom: 1rem;
    border-bottom: 2px solid var(--border);
  }
  .index-head h3 { color: var(--primary); font-size: 1.4rem; margin: 0; }
  .close-index {
    background: none; border: none; color: var(--text-sec);
    font-size: 1.8rem; cursor: pointer; padding: 0.3rem;
    transition: 0.3s;
  }
  .close-index:hover { color: #ef4444; transform: rotate(90deg); }
  
  .index-list { display: flex; flex-direction: column; gap: 0.6rem; }
  .index-list a {
    color: var(--text); text-decoration: none;
    padding: 1rem 1.2rem; border-radius: 10px;
    background: var(--bg); border-right: 3px solid transparent;
    transition: all 0.25s; font-size: 0.95rem;
    display: flex; align-items: center; gap: 0.8rem;
  }
  .index-list a::before { content: '📄'; font-size: 1.2rem; }
  .index-list a:hover {
    background: rgba(2,132,199,0.1);
    border-right-color: var(--primary);
    color: var(--primary);
    padding-right: 1.5rem;
  }
  
  /* تنسيق المقالات */
  .article-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem;
    margin-bottom: 2.5rem;
  }
  .tag {
    display: inline-block; background: var(--primary);
    color: white; padding: 0.3rem 1rem; border-radius: 50px;
    font-size: 0.85rem; margin-bottom: 1rem;
  }
  .article-card h2 { color: var(--text); font-size: 1.5rem; margin-bottom: 0.5rem; }
  .article-meta { color: var(--text-sec); font-size: 0.9rem; margin-bottom: 1.5rem; }
  .summary { font-size: 1.05rem; color: var(--text-sec); border-right: 3px solid var(--primary); padding-right: 1rem; margin-bottom: 1.5rem; line-height: 1.6; }
  .article-card h3 { color: var(--primary); margin: 1.5rem 0 1rem; font-size: 1.2rem; }
  .article-card ul { padding-right: 1.5rem; margin-bottom: 1rem; }
  .article-card li { margin-bottom: 0.6rem; line-height: 1.6; }
  
  @media (max-width: 768px) {
    .articles-main { padding: 3rem 1rem 4rem; }
    .index-btn { width: 46px; height: 46px; bottom: 20px; left: 20px; font-size: 1.3rem; }
    .index-box { padding: 1.5rem; }
    .article-card { padding: 1.5rem; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('indexBtn');
    const modal = document.getElementById('indexModal');
    const close = document.getElementById('closeIndex');
    const list = document.getElementById('indexList');
    
    // بناء الفهرس تلقائياً
    document.querySelectorAll('.article-card').forEach(art => {
      const title = art.querySelector('h2');
      if(title) {
        const link = document.createElement('a');
        link.href = '#' + art.id;
        link.textContent = title.textContent;
        link.onclick = (e) => {
          e.preventDefault();
          art.scrollIntoView({behavior: 'smooth', block: 'start'});
          modal.classList.remove('active');
        };
        list.appendChild(link);
      }
    });
    
    btn.onclick = () => modal.classList.add('active');
    close.onclick = () => modal.classList.remove('active');
    modal.onclick = (e) => { if(e.target === modal) modal.classList.remove('active'); };
  });
</script>
