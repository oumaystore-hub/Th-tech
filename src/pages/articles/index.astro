---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---
<html lang="ar" dir="rtl">
<head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title>المقالات - Th.Tech</title></head>
<body>
  <Header />
  <main style="padding:6rem 1rem 4rem; min-height:70vh; background:var(--bg); color:var(--text);">
    <div style="max-width:1200px; margin:0 auto;">
      <h1 style="color:var(--primary); text-align:center; font-size:2.5rem; margin-bottom:1rem;">📚 جميع المقالات</h1>
      <p style="text-align:center; color:var(--text-sec); margin-bottom:3rem;">استكشف أحدث المقالات في عالم التكنولوجيا والذكاء الاصطناعي</p>
      
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(350px,1fr)); gap:2.5rem;">
        
        <!-- مقال 1 -->
        <article style="background:var(--card); border-radius:15px; border:1px solid var(--border); overflow:hidden; transition:0.3s;">
          <img src="https://picsum.photos/seed/ai2026/600/400" alt="مقال" style="width:100%; height:220px; object-fit:cover;" />
          <div style="padding:2rem;">
            <span style="display:inline-block; background:var(--primary); color:white; padding:0.4rem 1.2rem; border-radius:50px; font-size:0.85rem; margin-bottom:1rem;">ذكاء اصطناعي</span>
            <h3 style="color:var(--text); margin-bottom:1rem; font-size:1.4rem;">مستقبل الذكاء الاصطناعي في 2026</h3>
            <p style="color:var(--text-sec); line-height:1.8; margin-bottom:1.5rem;">يستكشف هذا المقال أحدث التطورات في مجال الذكاء الاصطناعي وتأثيرها على حياتنا اليومية، من السيارات ذاتية القيادة إلى المساعدات الذكية والتشخيص الطبي المتقدم.</p>
            <div style="margin-top:1.5rem; padding-top:1rem; border-top:1px solid var(--border); font-size:0.9rem; color:var(--text-sec); display:flex; justify-content:space-between;">
              <span>📅 15 يناير 2026</span>
              <span>✍️ Th.Tech</span>
            </div>
          </div>
        </article>

        <!-- مقال 2 -->
        <article style="background:var(--card); border-radius:15px; border:1px solid var(--border); overflow:hidden; transition:0.3s;">
          <img src="https://picsum.photos/seed/coding2026/600/400" alt="مقال" style="width:100%; height:220px; object-fit:cover;" />
          <div style="padding:2rem;">
            <span style="display:inline-block; background:var(--primary); color:white; padding:0.4rem 1.2rem; border-radius:50px; font-size:0.85rem; margin-bottom:1rem;">برمجة</span>
            <h3 style="color:var(--text); margin-bottom:1rem; font-size:1.4rem;">دليلك الشامل لتعلم البرمجة</h3>
            <p style="color:var(--text-sec); line-height:1.8; margin-bottom:1.5rem;">دليل شامل للمبتدئين يشرح أساسيات البرمجة، أفضل اللغات للبدء، وكيفية بناء مشاريع عملية لتطوير مهاراتك البرمجية خطوة بخطوة.</p>
            <div style="margin-top:1.5rem; padding-top:1rem; border-top:1px solid var(--border); font-size:0.9rem; color:var(--text-sec); display:flex; justify-content:space-between;">
              <span>📅 20 فبراير 2026</span>
              <span>✍️ Th.Tech</span>
            </div>
          </div>
        </article>

        <!-- مقال 3 -->
        <article style="background:var(--card); border-radius:15px; border:1px solid var(--border); overflow:hidden; transition:0.3s;">
          <img src="https://picsum.photos/seed/security2026/600/400" alt="مقال" style="width:100%; height:220px; object-fit:cover;" />
          <div style="padding:2rem;">
            <span style="display:inline-block; background:var(--primary); color:white; padding:0.4rem 1.2rem; border-radius:50px; font-size:0.85rem; margin-bottom:1rem;">أمن سيبراني</span>
            <h3 style="color:var(--text); margin-bottom:1rem; font-size:1.4rem;">حماية بياناتك في العصر الرقمي</h3>
            <p style="color:var(--text-sec); line-height:1.8; margin-bottom:1.5rem;">تعلم كيفية حماية بياناتك الشخصية من الاختراقات، أفضل ممارسات الأمان السيبراني، والأدوات الأساسية لحماية خصوصيتك على الإنترنت.</p>
            <div style="margin-top:1.5rem; padding-top:1rem; border-top:1px solid var(--border); font-size:0.9rem; color:var(--text-sec); display:flex; justify-content:space-between;">
              <span>📅 5 مارس 2026</span>
              <span>✍️ Th.Tech</span>
            </div>
          </div>
        </article>

        <!-- مقال 4 -->
        <article style="background:var(--card); border-radius:15px; border:1px solid var(--border); overflow:hidden; transition:0.3s;">
          <img src="https://picsum.photos/seed/cloud2026/600/400" alt="مقال" style="width:100%; height:220px; object-fit:cover;" />
          <div style="padding:2rem;">
            <span style="display:inline-block; background:var(--primary); color:white; padding:0.4rem 1.2rem; border-radius:50px; font-size:0.85rem; margin-bottom:1rem;">حوسبة سحابية</span>
            <h3 style="color:var(--text); margin-bottom:1rem; font-size:1.4rem;">الحوسبة السحابية للشركات</h3>
            <p style="color:var(--text-sec); line-height:1.8; margin-bottom:1.5rem;">كيف تستفيد الشركات من الحوسبة السحابية لزيادة الكفاءة، تقليل التكاليف، وتحسين التعاون بين الفرق العاملة عن بُعد.</p>
            <div style="margin-top:1.5rem; padding-top:1rem; border-top:1px solid var(--border); font-size:0.9rem; color:var(--text-sec); display:flex; justify-content:space-between;">
              <span>📅 12 مارس 2026</span>
              <span>✍️ Th.Tech</span>
            </div>
          </div>
        </article>

        <!-- مقال 5 -->
        <article style="background:var(--card); border-radius:15px; border:1px solid var(--border); overflow:hidden; transition:0.3s;">
          <img src="https://picsum.photos/seed/iot2026/600/400" alt="مقال" style="width:100%; height:220px; object-fit:cover;" />
          <div style="padding:2rem;">
            <span style="display:inline-block; background:var(--primary); color:white; padding:0.4rem 1.2rem; border-radius:50px; font-size:0.85rem; margin-bottom:1rem;">إنترنت الأشياء</span>
            <h3 style="color:var(--text); margin-bottom:1rem; font-size:1.4rem;">المدن الذكية وإنترنت الأشياء</h3>
            <p style="color:var(--text-sec); line-height:1.8; margin-bottom:1.5rem;">استكشاف تطبيقات إنترنت الأشياء في بناء المدن الذكية، من إدارة المرور الذكية إلى أنظمة الطاقة المتجددة والمباني الذكية.</p>
            <div style="margin-top:1.5rem; padding-top:1rem; border-top:1px solid var(--border); font-size:0.9rem; color:var(--text-sec); display:flex; justify-content:space-between;">
              <span>📅 18 مارس 2026</span>
              <span>✍️ Th.Tech</span>
            </div>
          </div>
        </article>

        <!-- مقال 6 -->
        <article style="background:var(--card); border-radius:15px; border:1px solid var(--border); overflow:hidden; transition:0.3s;">
          <img src="https://picsum.photos/seed/blockchain2026/600/400" alt="مقال" style="width:100%; height:220px; object-fit:cover;" />
          <div style="padding:2rem;">
            <span style="display:inline-block; background:var(--primary); color:white; padding:0.4rem 1.2rem; border-radius:50px; font-size:0.85rem; margin-bottom:1rem;">بلوك تشين</span>
            <h3 style="color:var(--text); margin-bottom:1rem; font-size:1.4rem;">تقنية البلوك تشين beyond العملات</h3>
            <p style="color:var(--text-sec); line-height:1.8; margin-bottom:1.5rem;">كيف تُستخدم تقنية البلوك تشين في مجالات متعددة مثل الرعاية الصحية، سلاسل التوريد، والتصويت الإلكتروني الآمن.</p>
            <div style="margin-top:1.5rem; padding-top:1rem; border-top:1px solid var(--border); font-size:0.9rem; color:var(--text-sec); display:flex; justify-content:space-between;">
              <span>📅 25 مارس 2026</span>
              <span>✍️ Th.Tech</span>
            </div>
          </div>
        </article>

      </div>
    </div>
  </main>
  <Footer />
</body>
</html>
