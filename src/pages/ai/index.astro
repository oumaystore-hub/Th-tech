---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <title>الذكاء الاصطناعي - Th.Tech</title>
</head>
<body>
  <Header />
  <main class="category-articles">
    <h1>🤖 مقالات الذكاء الاصطناعي</h1>
    
    <article class="article">
      <span class="badge">ذكاء اصطناعي</span>
      <h2>مستقبل الذكاء الاصطناعي في 2026</h2>
      <p>أحدث التطورات في النماذج التوليدية والوكلاء الأذكياء...</p>
      <ul>
        <li>النماذج التوليدية (Generative AI)</li>
        <li>الوكلاء الأذكياء (AI Agents)</li>
        <li>التطبيقات الطبية المتقدمة</li>
      </ul>
    </article>
    
    <article class="article">
      <span class="badge">تعلم الآلة</span>
      <h2>الشبكات العصبية العميقة</h2>
      <p>شرح مفصل لبنية الشبكات العصبية...</p>
    </article>
  </main>
  <Footer />
</body>
</html>

<style>
  :root { --bg: #f8fafc; --card: #fff; --text: #0f172a; --primary: #0284c7; }
  html.dark-mode { --bg: #0b1120; --card: #1e293b; --text: #f1f5f9; --primary: #38bdf8; }
  body { background: var(--bg); color: var(--text); font-family: system-ui; margin: 0; }
  .category-articles { max-width: 900px; margin: 0 auto; padding: 4rem 1.5rem; }
  .category-articles h1 { color: var(--primary); text-align: center; margin-bottom: 3rem; }
  .article { background: var(--card); padding: 2rem; border-radius: 12px; margin-bottom: 2rem; border: 1px solid rgba(2,132,199,0.2); }
  .badge { background: var(--primary); color: white; padding: 0.3rem 1rem; border-radius: 50px; font-size: 0.85rem; }
  .article h2 { margin: 1rem 0; }
  .article ul { padding-right: 1.5rem; }
</style>
