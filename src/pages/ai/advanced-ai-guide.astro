    .article h4 { font-size: 1.05rem !important; }
    .article-image { margin: 1.5rem 0 !important; }
    .article-image img { height: 200px !important; object-fit: cover !important; }
    .image-caption { padding: 0.8rem 1rem !important; font-size: 0.85rem !important; }
    .toc-btn { width: 50px !important; height: 50px !important; bottom: 15px !important; left: 15px !important; font-size: 1.6rem !important; }
