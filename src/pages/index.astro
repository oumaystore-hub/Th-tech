---
import { getCollection } from 'astro:content';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const posts = await getCollection('blog');
---

<html lang="ar" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TH Tech - الرئيسية</title>
  </head>
  <body>
    <Header />
    
    <main class="main">
      <section class="hero">
        <h1>مرحباً بك في TH Tech</h1>
        <p>بوابتك إلى عالم التكنولوجيا والذكاء الاصطناعي</p>
      </section>

      <section class="articles-section">
        <h2>أحدث المقالات</h2>
        <div class="articles-grid">
          {posts.slice(0, 6).map((post) => (
            <article class="article-card">
              <h3>
                <a href={`/articles/${post.slug}`}>{post.data.title}</a>
              </h3>
              <p>{post.data.description}</p>
              <div class="meta">
                <span class="category">{post.data.category}</span>
                <time>{new Date(post.data.pubDate).toLocaleDateString('ar-SA')}</time>
              </div>
            </article>
          ))}
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  .main {
    min-height: 70vh;
    padding: 2rem 1rem;    max-width: 1200px;
    margin: 0 auto;
  }

  .hero {
    text-align: center;
    padding: 3rem 0;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border-radius: 15px;
    margin-bottom: 3rem;
  }

  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .articles-section h2 {
    font-size: 2rem;
    margin-bottom: 2rem;
    text-align: center;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
  }

  .article-card {
    background: white;
    padding: 1.5rem;
    border-radius: 10px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    transition: transform 0.3s;
  }

  .article-card:hover {
    transform: translateY(-5px);
  }

  .article-card h3 a {
    color: #1a1a2e;
    text-decoration: none;
  }

  .article-card h3 a:hover {
    color: #3b82f6;
  }
  .meta {
    display: flex;
    justify-content: space-between;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid #e5e7eb;
    font-size: 0.9rem;
    color: #6b7280;
  }

  .category {
    background: #3b82f6;
    color: white;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.8rem;
  }
</style>
