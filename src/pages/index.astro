---
import { getCollection } from 'astro:content';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const posts = await getCollection('blog');
---

<html lang="ar" dir="rtl" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Th.Tech | الذكاء الاصطناعي والابتكار التقني</title>
</head>
<body>
  <Header />
  
  <section class="hero">
    <div class="hero-content">
      <div class="badge">🚀 مرحباً بك في المستقبل</div>
      <h1 class="title">
        اكتشف عالم <span class="gradient">الذكاء الاصطناعي</span><br />
        والابتكار التقني
      </h1>
      <p class="desc">
        منصّة متخصصة تُقدّم أحدث المقالات والشروحات في عالم البرمجة، 
        الذكاء الاصطناعي، والأدوات الرقمية المتقدمة
      </p>
      <div class="hero-buttons">
        <a href="/Th-tech/articles/" class="btn-primary">📚 تصفح المقالات</a>
        <a href="/Th-tech/about/" class="btn-secondary">ℹ️ من نحن</a>
      </div>
    </div>
  </section>

  <main class="container">
    <section class="section">
      <div class="section-header">
        <h2 class="section-title">🔥 أحدث المقالات</h2>
        <a href="/Th-tech/articles/" class="view-all">عرض الكل ←</a>
      </div>

      <div class="articles-grid">
        {posts.length > 0 ? posts.map(post => (
          <article class="article-card">
            <div class="card-content">
              <span class="category-badge">{post.data.category}</span>
              <h3 class="card-title">
                <a href={`/Th-tech/articles/${post.slug}/`}>{post.data.title}</a>              </h3>
              <p class="card-excerpt">{post.data.description}</p>
              <div class="card-meta">
                <span>📅 {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
                <span>✍️ {post.data.author}</span>
              </div>
            </div>
          </article>
        )) : <p class="empty">لا توجد مقالات بعد</p>}
      </div>
    </section>
  </main>

  <Footer />
</body>
</html>

<style>
  :root {
    --primary: #00d4ff;
    --secondary: #0099cc;
    --accent: #1e3a8a;
    --bg: #0a0e27;
    --card: rgba(30, 41, 59, 0.8);
    --text: #f1f5f9;
    --text-muted: #94a3b8;
    --font-base: 0.85rem;
  }
  [data-theme="light"] {
    --bg: #f0f9ff;
    --card: rgba(255, 255, 255, 0.9);
    --text: #0c1e3a;
    --text-muted: #64748b;
  }
  
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.7;
    font-size: var(--font-base);
  }

  .hero {
    text-align: center;
    padding: 5rem 1rem 3rem;
    background: radial-gradient(circle at top, rgba(0,212,255,0.1) 0%, var(--bg) 70%);
  }
  .badge {    display: inline-block;
    background: rgba(0, 212, 255, 0.15);
    border: 1px solid rgba(0, 212, 255, 0.3);
    padding: 0.6rem 1.2rem;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--primary);
    margin-bottom: 1.5rem;
  }
  .title {
    font-size: 2.2rem;
    margin-bottom: 1.2rem;
    line-height: 1.3;
  }
  .gradient {
    background: linear-gradient(135deg, #00d4ff, #0099cc);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .desc {
    font-size: 0.95rem;
    color: var(--text-muted);
    max-width: 650px;
    margin: 0 auto 2rem;
    line-height: 1.8;
  }
  .hero-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn-primary {
    background: linear-gradient(135deg, #00d4ff, #0099cc);
    color: #fff;
    padding: 0.9rem 2rem;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 700;
    transition: all 0.3s;
    display: inline-block;
    font-size: 0.9rem;
  }
  .btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(0, 212, 255, 0.4);
  }
  .btn-secondary {
    background: rgba(255,255,255,0.1);    color: var(--text);
    padding: 0.9rem 2rem;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 700;
    border: 1px solid rgba(0, 212, 255, 0.3);
    transition: all 0.3s;
    display: inline-block;
    font-size: 0.9rem;
  }
  .btn-secondary:hover {
    background: rgba(0, 212, 255, 0.15);
    transform: translateY(-3px);
  }

  .container { max-width: 1200px; margin: 0 auto; padding: 0 1rem; }
  .section { padding: 4rem 0; }
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2.5rem;
  }
  .section-title {
    font-size: 1.8rem;
    color: var(--primary);
  }
  .view-all {
    color: var(--primary);
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9rem;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }
  .article-card {
    background: var(--card);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(0, 212, 255, 0.2);
    border-radius: 14px;
    padding: 1.5rem;
    transition: all 0.3s;
  }
  .article-card:hover {
    transform: translateY(-5px);
    border-color: var(--primary);    box-shadow: 0 10px 30px rgba(0, 212, 255, 0.2);
  }
  .category-badge {
    background: rgba(0, 212, 255, 0.15);
    color: var(--primary);
    padding: 0.3rem 0.8rem;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 700;
    display: inline-block;
    margin-bottom: 0.8rem;
  }
  .card-title {
    font-size: 1.1rem;
    margin-bottom: 0.8rem;
    line-height: 1.4;
  }
  .card-title a {
    color: var(--text);
    text-decoration: none;
  }
  .card-title a:hover {
    color: var(--primary);
  }
  .card-excerpt {
    color: var(--text-muted);
    font-size: 0.85rem;
    line-height: 1.6;
    margin-bottom: 1rem;
  }
  .card-meta {
    display: flex;
    gap: 1rem;
    font-size: 0.75rem;
    color: var(--text-muted);
    padding-top: 1rem;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .empty {
    text-align: center;
    padding: 3rem;
    color: var(--text-muted);
    grid-column: 1 / -1;
  }

  @media (max-width: 768px) {
    .title { font-size: 1.6rem; }
    .section-title { font-size: 1.4rem; }
    .articles-grid { grid-template-columns: 1fr; }
  }</style>
