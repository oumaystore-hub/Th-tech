---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const posts = [
  {
    slug: 'test',
    title: 'مقال تجريبي',
    description: 'هذا مقال اختبار',
    category: 'تقنية',
    pubDate: new Date('2026-01-15'),
    author: 'Th.Tech'
  },
  {
    slug: 'ai-tools-2026',
    title: 'أدوات الذكاء الاصطناعي 2026',
    description: 'أفضل الأدوات',
    category: 'ذكاء اصطناعي',
    pubDate: new Date('2026-06-18'),
    author: 'Th.Tech'
  }
];
---

<html lang="ar" dir="rtl">
<head>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Th.Tech</title>
</head>
<body style="margin:0; font-family:'Segoe UI', sans-serif; background:#0a0e27; color:#fff;">
  <Header />
  
  <!-- Hero Section -->
  <section style="text-align:center; padding:3rem 1rem 2rem; background:radial-gradient(circle at top, rgba(0,212,255,0.1) 0%, #0a0e27 70%);">
    <div style="display:inline-block; background:rgba(0,212,255,0.15); border:1px solid rgba(0,212,255,0.3); padding:0.5rem 1rem; border-radius:50px; font-size:0.85rem; color:#00d4ff; margin-bottom:1rem;">🚀 مرحباً بك في المستقبل</div>
    <h1 style="font-size:clamp(1.5rem, 5vw, 2.5rem); margin:1rem 0; line-height:1.3;">اكتشف عالم <span style="background:linear-gradient(135deg, #00d4ff, #0099cc); -webkit-background-clip:text; -webkit-text-fill-color:transparent;">الذكاء الاصطناعي</span><br />والابتكار التقني</h1>
    <p style="color:#94a3b8; font-size:0.95rem; max-width:600px; margin:0 auto 1.5rem; line-height:1.6;">منصّة متخصصة تُقدّم أحدث المقالات والشروحات</p>
    <div style="display:flex; gap:0.8rem; justify-content:center; flex-wrap:wrap;">
      <a href="/Th-tech/articles/" style="background:linear-gradient(135deg, #00d4ff, #0099cc); color:#fff; padding:0.9rem 1.8rem; border-radius:10px; text-decoration:none; font-weight:700; font-size:0.9rem; display:inline-block;">📚 تصفح المقالات</a>
      <a href="/Th-tech/about/" style="background:rgba(255,255,255,0.1); color:#fff; padding:0.9rem 1.8rem; border-radius:10px; text-decoration:none; font-weight:700; border:1px solid rgba(0,212,255,0.3); font-size:0.9rem; display:inline-block;">ℹ️ من نحن</a>
    </div>
  </section>

  <!-- Articles Section -->
  <main style="max-width:1200px; margin:0 auto; padding:0 1rem 3rem;">
    <section style="padding:2rem 0;">
      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem; flex-wrap:wrap; gap:1rem;">
        <h2 style="color:#00d4ff; font-size:1.5rem; margin:0;">🔥 أحدث المقالات</h2>
        <a href="/Th-tech/articles/" style="color:#00d4ff; text-decoration:none; font-weight:700; font-size:0.9rem;">عرض الكل ←</a>
      </div>

      <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(min(100%, 300px), 1fr)); gap:1.2rem;">
        {posts.map(post => (
          <article style="background:#1e293b; padding:1.3rem; border-radius:12px; border:1px solid rgba(0,212,255,0.2); transition:0.3s;">
            <span style="background:rgba(0,212,255,0.2); color:#00d4ff; padding:0.3rem 0.8rem; border-radius:50px; font-size:0.75rem; display:inline-block; margin-bottom:0.8rem;">{post.category}</span>
            <h3 style="margin:0.5rem 0; font-size:1.1rem; line-height:1.4;"><a href={`/Th-tech/articles/${post.slug}/`} style="color:#fff; text-decoration:none;">{post.title}</a></h3>
            <p style="color:#94a3b8; font-size:0.85rem; line-height:1.6; margin-bottom:1rem;">{post.description}</p>
            <div style="display:flex; gap:1rem; font-size:0.75rem; color:#64748b; padding-top:0.8rem; border-top:1px solid rgba(255,255,255,0.1); flex-wrap:wrap;">
              <span>📅 {post.pubDate.toLocaleDateString('en-US', {year:'numeric', month:'short', day:'numeric'})}</span>
              <span>✍️ {post.author}</span>
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</body>
</html>
