---
import { getCollection } from 'astro:content';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const posts = await getCollection('blog');
---
<html lang="ar" dir="rtl" data-theme="dark">
<head><meta charset="UTF-8"/><title>Th.Tech</title></head>
<body style="font-family:sans-serif;background:#0f172a;color:#fff;margin:0">
<Header/>
<main style="max-width:800px;margin:0 auto;padding:2rem;text-align:center">
<h1 style="color:#3b82f6;font-size:2.5rem">Th.Tech</h1>
<p style="color:#94a3b8">منصة متخصصة في الذكاء الاصطناعي والتكنولوجيا</p>
<div style="margin-top:2rem">
{posts.length > 0 ? posts.map(p => (
<article style="background:#1e293b;padding:1.5rem;margin:1rem 0;border-radius:8px">
<h3><a href={`/articles/${p.slug}/`} style="color:#3b82f6">{p.data.title}</a></h3>
<p style="color:#94a3b8">{p.data.description}</p>
</article>
)) : <p>لا توجد مقالات بعد</p>}
</div>
</main><Footer/>
</body>
</html>
