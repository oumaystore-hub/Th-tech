---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Th.Tech - الرئيسية</title>
</head>
<body>
  <Header />
  <main>
    <section style="padding:6rem 1rem; text-align:center;">
      <div style="max-width:800px; margin:0 auto;">
        <span style="display:inline-block; background:var(--primary); color:white; padding:0.5rem 1.5rem; border-radius:50px; margin-bottom:1.5rem;">🚀 مرحباً بك في المستقبل</span>
        <h1 style="font-size:clamp(2rem,5vw,3rem); margin-bottom:1.5rem; line-height:1.2;">
          اكتشف عالم <span style="color:var(--primary);">الذكاء الاصطناعي</span><br/>والابتكار التقني
        </h1>
        <p style="font-size:1.2rem; color:var(--text-sec); margin-bottom:2.5rem;">منصة متخصصة تُقدّم أحدث المقالات والشروحات التقنية</p>
        <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
          <a href="/Th-tech/articles/" style="display:inline-block; background:var(--primary); color:white; padding:1rem 2rem; border-radius:10px; text-decoration:none; font-weight:bold;">📚 تصفح المقالات</a>
          <a href="/Th-tech/category/" style="display:inline-block; background:transparent; color:var(--text); border:2px solid var(--primary); padding:1rem 2rem; border-radius:10px; text-decoration:none; font-weight:bold;">📂 التصنيفات</a>
        </div>
      </div>
    </section>

    <section style="padding:4rem 1rem; background:var(--card);">
      <div style="max-width:1200px; margin:0 auto; text-align:center;">
        <h2 style="color:var(--primary); font-size:2rem; margin-bottom:3rem;">لماذا Th.Tech؟</h2>
        <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:2rem;">
          <div style="background:var(--bg); padding:2rem; border-radius:15px; border:1px solid var(--border);">
            <div style="font-size:3rem; margin-bottom:1rem;">🤖</div>
            <h3 style="color:var(--primary); margin-bottom:1rem;">ذكاء اصطناعي</h3>
            <p style="color:var(--text-sec);">أحدث التطورات في المجال</p>
          </div>
          <div style="background:var(--bg); padding:2rem; border-radius:15px; border:1px solid var(--border);">
            <div style="font-size:3rem; margin-bottom:1rem;">💻</div>
            <h3 style="color:var(--primary); margin-bottom:1rem;">برمجة</h3>
            <p style="color:var(--text-sec);">شروحات مفصلة ودروس عملية</p>
          </div>
          <div style="background:var(--bg); padding:2rem; border-radius:15px; border:1px solid var(--border);">
            <div style="font-size:3rem; margin-bottom:1rem;">🔒</div>
            <h3 style="color:var(--primary); margin-bottom:1rem;">أمن سيبراني</h3>
            <p style="color:var(--text-sec);">حماية بياناتك وخصوصيتك</p>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</body>
</html>
