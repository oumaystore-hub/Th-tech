---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const latestArticles = allArticles
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 6);
---

<BaseLayout title="Th-tech | المستقبل التقني">
  <Header />

  <section class="hero">
    <div class="glow-orb"></div>
    <div class="content">
      <div class="badge">🔥 محتوى تقني عملي</div>
      <h1>المعرفة التقنية<br /><span class="gradient">بلا حدود</span></h1>
      <p>منصة متخصصة في الذكاء الاصطناعي، الأداء العالي، واستراتيجيات الرقمنة الحديثة.</p>
      <div class="actions">
        <a href="/articles/الكل" class="btn primary">تصفح المقالات</a>
      </div>
    </div>
  </section>

  <section class="container">
    <div class="section-head">
      <h2>أحدث المقالات</h2>
      <a href="/articles/الكل" class="view-all">عرض الكل ←</a>
    </div>

    {latestArticles.length > 0 ? (
      <div class="grid">
        {latestArticles.map(p => (
          <article class="card">
            <div class="card-glow"></div>
            <div class="meta">
              <span class="tag">{p.data.category}</span>
              <time>{p.data.publishDate.toLocaleDateString('ar-EG')}</time>
            </div>
            <h3><a href={`/articles/${p.slug}`}>{p.data.title}</a></h3>
            <p>{p.data.description || 'مقال متخصص يغطي أحدث التطورات في هذا المجال...'}</p>
          </article>
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <p>لا توجد مقالات بعد. أضف ملفات .mdx إلى src/content/articles/</p>
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .hero { position: relative; padding: 8rem 1.5rem 6rem; text-align: center; overflow: hidden; }
  .glow-orb { position: absolute; top: -20%; left: 50%; transform: translateX(-50%); width: 600px; height: 600px; background: radial-gradient(circle, rgba(99,102,241,0.15) 0%, transparent 70%); z-index: -1; filter: blur(60px); }
  .badge { display: inline-block; padding: 0.5rem 1.2rem; background: rgba(99,102,241,0.1); border: 1px solid rgba(99,102,241,0.3); border-radius: 50px; color: var(--primary); font-size: 0.85rem; font-weight: 600; margin-bottom: 2rem; }
  .hero h1 { font-size: clamp(2.5rem, 5vw, 4rem); line-height: 1.1; margin-bottom: 1.5rem; font-weight: 800; }
  .gradient { background: linear-gradient(135deg, #6366f1, #06b6d4); -webkit-background-clip: text; color: transparent; }
  .hero p { font-size: 1.2rem; color: var(--muted); max-width: 600px; margin: 0 auto 3rem; }
  .actions { display: flex; gap: 1rem; justify-content: center; }
  .btn { padding: 1rem 2.5rem; border-radius: 50px; font-weight: 700; transition: all 0.3s; }
  .primary { background: var(--primary); color: white; box-shadow: var(--glow); }
  .primary:hover { transform: translateY(-3px); box-shadow: 0 0 30px rgba(99,102,241,0.5); }
  .container { max-width: 1200px; margin: 0 auto; padding: 4rem 1.5rem; }
  .section-head { display: flex; justify-content: space-between; align-items: end; margin-bottom: 3rem; }
  .section-head h2 { font-size: 2rem; }
  .view-all { color: var(--accent); font-weight: 600; }
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 2rem; }
  .card { position: relative; background: var(--surface); border: 1px solid var(--border); border-radius: 20px; padding: 2rem; transition: all 0.4s ease; overflow: hidden; }
  .card:hover { border-color: rgba(99,102,241,0.4); transform: translateY(-5px); }
  .card-glow { position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, var(--primary), transparent); opacity: 0; transition: 0.4s; }
  .card:hover .card-glow { opacity: 1; }
  .meta { display: flex; justify-content: space-between; margin-bottom: 1.2rem; font-size: 0.8rem; }
  .tag { color: var(--accent); font-weight: 700; text-transform: uppercase; letter-spacing: 1px; }
  time { color: var(--muted); }
  .card h3 { font-size: 1.3rem; margin-bottom: 0.8rem; line-height: 1.4; }
  .card h3 a { color: var(--text); }
  .card p { color: var(--muted); font-size: 0.95rem; line-height: 1.7; }
  .empty-state { text-align: center; padding: 4rem; color: var(--muted); background: var(--surface); border-radius: 20px; border: 1px dashed var(--border); }
</style>
