---
import Header from '../components/Header.astro';
---
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Th.Tech - الرئيسية</title>
</head>
<body style="margin:0; font-family:'Segoe UI',sans-serif; background:#020617; color:#fff;">
  <Header />
  
  <main style="max-width:1200px; margin:0 auto; padding:3rem 1rem; text-align:center;">
    <h1 style="color:#00d4ff; font-size:2.5rem; margin-bottom:1rem;">مرحباً بك في Th.Tech 🚀</h1>
    <p style="color:#94a3b8; font-size:1.2rem; margin-bottom:2rem;">منصة متخصصة في الذكاء الاصطناعي والتكنولوجيا</p>
    
    <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
      <a href="/Th-tech/articles/" style="display:inline-block; background:#00d4ff; color:#020617; padding:1rem 2rem; border-radius:8px; text-decoration:none; font-weight:bold;">تصفح المقالات </a>
    </div>
  </main>
</body>
</html>
