---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  
  <!-- SEO & Verification -->
  <title>Th.Tech - عالم الذكاء الاصطناعي والتكنولوجيا</title>
  <meta name="description" content="منصة Th.Tech المتخصصة في الذكاء الاصطناعي، البرمجة، الأمن السيبراني، والحوسبة السحابية. مقالات تقنية معمقة وشروحات عملية." />
  <meta name="keywords" content="ذكاء اصطناعي, برمجة, أمن سيبراني, حوسبة سحابية, تعلم آلي, بيانات, تقنية" />
  <meta name="author" content="Th-Tech Team" />
  <meta name="robots" content="index, follow" />
  <meta name="google-site-verification" content="GOxRhy_xfCo492sszjG7fICciSBqL6zPhI1e_B64KsI" />
  <link rel="canonical" href="https://oumaystore-hub.github.io/Th-tech/" />
  <link rel="icon" type="image/png" href="/Th-tech/logo1.png" />

  <!-- Open Graph & Twitter -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://oumaystore-hub.github.io/Th-tech/" />
  <meta property="og:title" content="Th.Tech - الذكاء الاصطناعي والتكنولوجيا" />
  <meta property="og:description" content="منصة متخصصة في الذكاء الاصطناعي والتكنولوجيا الحديثة. مقالات تقنية معمقة وشروحات عملية." />
  <meta property="og:image" content="https://oumaystore-hub.github.io/Th-tech/logo1.png" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Th.Tech - الذكاء الاصطناعي والتكنولوجيا" />
  <meta name="twitter:description" content="منصة متخصصة في الذكاء الاصطناعي والتكنولوجيا الحديثة" />
  <meta name="twitter:image" content="https://oumaystore-hub.github.io/Th-tech/logo1.png" />

  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-6QW7XVX75J"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-6QW7XVX75J');
  </script>
</head>
<body>
  <Header />

  <main class="main-wrapper">
    
    <!-- Hero Section -->
    <section class="hero section-anim">
      <div class="hero-bg"></div>
      <div class="container hero-content">
        <span class="hero-badge">🚀 مرحباً بك في المستقبل</span>
        <h1>اكتشف عالم <span class="highlight">الذكاء الاصطناعي</span><br />والابتكار التقني</h1>
        <p class="hero-desc">منصة متخصصة تُقدّم أحدث المقالات والشروحات التقنية في مجال الذكاء الاصطناعي، البرمجة، والأمن السيبراني.</p>
        
        <div class="hero-buttons">
          <a href="/Th-tech/category/" class="btn btn-primary">استكشف التصنيفات</a>
          <a href="/Th-tech/articles/" class="btn btn-outline">تصفح المقالات</a>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section class="features section-anim">
      <div class="container">
        <div class="section-header">
          <h2>لماذا <span class="highlight">Th.Tech</span>؟</h2>
          <p>محتوى يجمع بين العمق التقني والبساطة في الشرح</p>
        </div>
        
        <div class="features-grid">
          <div class="feature-card">
            <div class="icon-box">🤖</div>
            <h3>ذكاء اصطناعي متقدم</h3>
            <p>نواكب أحدث تطورات الـ AI ونماذج اللغة الكبيرة (LLMs) ونشرحها بأسلوب عملي.</p>
          </div>
          <div class="feature-card">
            <div class="icon-box">🔒</div>
            <h3>أمن سيبراني موثوق</h3>
            <p>شروحات حول حماية البيانات، الاختراق الأخلاقي، وأدوات الدفاع السيبراني الحديثة.</p>
          </div>
          <div class="feature-card">
            <div class="icon-box">💻</div>
            <h3>برمجة وهندسة برمجيات</h3>
            <p>من أساسيات البرمجة إلى بناء أنظمة معقدة باستخدام أحدث الأطر (Frameworks).</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Highlights Section -->
    <section class="highlights section-anim">
      <div class="container">
        <div class="section-header">
          <h2>مواضيع رائجة</h2>
          <p>تصفح أبرز المجالات التي يبحث عنها المطورون حالياً</p>
        </div>

        <div class="highlights-grid">
          <a href="/Th-tech/ai/" class="topic-card">
            <div class="topic-icon">🧠</div>
            <div class="topic-content">
              <h3>تعلم الآلة</h3>
              <span class="read-more">استكشف المقالات ←</span>
            </div>
          </a>
          <a href="/Th-tech/blockchain/" class="topic-card">
            <div class="topic-icon">🔗</div>
            <div class="topic-content">
              <h3>البلوك تشين</h3>
              <span class="read-more">استكشف المقالات ←</span>
            </div>
          </a>
          <a href="/Th-tech/data-science/" class="topic-card">
            <div class="topic-icon">📊</div>
            <div class="topic-content">
              <h3>علم البيانات</h3>
              <span class="read-more">استكشف المقالات ←</span>
            </div>
          </a>
          <a href="/Th-tech/cloud/" class="topic-card">
            <div class="topic-icon">☁️</div>
            <div class="topic-content">
              <h3>الحوسبة السحابية</h3>
              <span class="read-more">استكشف المقالات ←</span>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="cta section-anim">
      <div class="container">
        <div class="cta-box">
          <h2>🚀 هل أنت مستعد لتعلم شيء جديد؟</h2>
          <p>انضم إلى آلاف المطورين والمتخصصين الذين يقرأون Th.Tech يومياً.</p>
          <a href="/Th-tech/category/" class="btn btn-light">ابدأ التصفح الآن</a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</body>
</html>

<style>
  :root {
    --bg: #f8fafc;
    --card: #ffffff;
    --text: #0f172a;
    --text-sec: #64748b;
    --primary: #0284c7;
    --primary-dark: #0369a1;
    --accent: #0ea5e9;
    --border: rgba(2,132,199,0.15);
    --shadow: 0 4px 20px rgba(0,0,0,0.05);
    --radius: 16px;
  }

  html.dark-mode {
    --bg: #0b1120;
    --card: #1e293b;
    --text: #f1f5f9;
    --text-sec: #94a3b8;
    --primary: #38bdf8;
    --primary-dark: #0284c7;
    --accent: #7dd3fc;
    --border: rgba(56,189,248,0.15);
    --shadow: 0 4px 20px rgba(0,0,0,0.3);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Segoe UI', system-ui, sans-serif;
    line-height: 1.6;
    overflow-x: hidden;
  }
  
  .main-wrapper { overflow-x: hidden; }
  .container { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }
  .highlight { color: var(--primary); font-weight: 700; }
  .section-header { text-align: center; margin-bottom: 2.5rem; }
  .section-header h2 { font-size: clamp(1.8rem, 4vw, 2.2rem); margin-bottom: 0.5rem; }
  .section-header p { color: var(--text-sec); font-size: 1.05rem; }

  /* Animations */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .section-anim {
    opacity: 0;
    animation: fadeUp 0.7s ease-out forwards;
  }
  .section-anim:nth-child(1) { animation-delay: 0.1s; }
  .section-anim:nth-child(2) { animation-delay: 0.2s; }
  .section-anim:nth-child(3) { animation-delay: 0.3s; }
  .section-anim:nth-child(4) { animation-delay: 0.4s; }

  /* Hero */
  .hero {
    position: relative;
    padding: 4rem 0 3rem;
    text-align: center;
    background: var(--bg);
  }
  .hero-bg {
    position: absolute; top: 0; left: 0; right: 0; bottom: 0;
    background: radial-gradient(circle at 50% 30%, rgba(2,132,199,0.08) 0%, transparent 60%);
    z-index: 0;
  }
  .hero-content { position: relative; z-index: 1; }
  .hero-badge {
    display: inline-block;
    background: var(--primary);
    color: white;
    padding: 0.4rem 1.2rem;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 1.2rem;
    box-shadow: 0 4px 15px rgba(2,132,199,0.25);
    animation: pulse 3s infinite;
  }
  @keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.03); }
  }
  .hero h1 {
    font-size: clamp(2rem, 5vw, 2.8rem);
    line-height: 1.25;
    margin-bottom: 1rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }
  .hero-desc {
    font-size: 1.1rem;
    color: var(--text-sec);
    max-width: 650px;
    margin: 0 auto 2rem;
  }
  .hero-buttons { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

  .btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.85rem 1.8rem;
    border-radius: 12px;
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .btn-primary {
    background: var(--primary);
    color: white;
    box-shadow: 0 4px 15px rgba(2,132,199,0.25);
  }
  .btn-primary:hover { transform: translateY(-3px); background: var(--primary-dark); }
  .btn-outline {
    background: transparent;
    border: 2px solid var(--border);
    color: var(--text);
  }
  .btn-outline:hover { border-color: var(--primary); color: var(--primary); transform: translateY(-3px); }
  .btn-light {
    background: white;
    color: var(--primary);
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
  }
  .btn-light:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(0,0,0,0.15); }

  /* Features */
  .features { padding: 3rem 0; background: var(--card); }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .feature-card {
    background: var(--bg);
    padding: 2rem;
    border-radius: var(--radius);
    text-align: center;
    border: 1px solid var(--border);
    transition: all 0.35s;
  }
  .feature-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow);
    border-color: var(--primary);
  }
  .icon-box { font-size: 2.8rem; margin-bottom: 1rem; display: block; }
  .feature-card h3 { font-size: 1.25rem; margin-bottom: 0.8rem; }
  .feature-card p { color: var(--text-sec); font-size: 0.95rem; line-height: 1.6; }

  /* Highlights */
  .highlights { padding: 3rem 0; background: var(--bg); }
  .highlights-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.2rem;
  }
  .topic-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.5rem;
    display: flex; align-items: center; gap: 1.2rem;
    text-decoration: none;
    transition: all 0.3s;
  }
  .topic-card:hover {
    border-color: var(--primary);
    transform: translateY(-4px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.06);
  }
  .topic-icon { font-size: 2.2rem; flex-shrink: 0; }
  .topic-content h3 { font-size: 1.1rem; margin: 0 0 0.3rem; }
  .read-more { color: var(--primary); font-weight: 600; font-size: 0.85rem; }

  /* CTA */
  .cta { padding: 2.5rem 1.5rem 3rem; }
  .cta-box {
    background: linear-gradient(135deg, var(--primary), var(--primary-dark));
    color: white;
    border-radius: 20px;
    padding: 3rem 2rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .cta-box::before {
    content: ''; position: absolute; top: -40%; right: -15%; width: 300px; height: 300px;
    background: rgba(255,255,255,0.1); border-radius: 50%;
  }
  .cta-box h2 { font-size: 1.8rem; margin-bottom: 0.8rem; position: relative; z-index: 1; }
  .cta-box p { font-size: 1rem; margin-bottom: 1.5rem; opacity: 0.95; position: relative; z-index: 1; }

  /* Responsive */
  @media (max-width: 768px) {
    .hero { padding: 3rem 0 2.5rem; }
    .features, .highlights { padding: 2.5rem 0; }
    .highlights-grid { grid-template-columns: 1fr; }
    .cta-box { padding: 2.5rem 1.5rem; }
    .section-header { margin-bottom: 2rem; }
  }
</style>
