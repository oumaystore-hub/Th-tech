---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  
  <!-- SEO الأساسي -->
  <title>Th.Tech - عالم الذكاء الاصطناعي والتكنولوجيا</title>
  <meta name="description" content="منصة Th.Tech هي وجهتك الأولى لمقالات الذكاء الاصطناعي، البرمجة، الأمن السيبراني، والتقنيات الحديثة. شروحات عملية ومحتوى تقني موثوق." />
  <meta name="keywords" content="ذكاء اصطناعي, برمجة, أمن سيبراني, حوسبة سحابية, تعلم آلي, بيانات, تقنية, AI, Cyber Security" />
  <meta name="author" content="Th-Tech Team" />
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />
  
  <!-- Open Graph (فيسبوك / لينكد إن) -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://oumaystore-hub.github.io/Th-tech/" />
  <meta property="og:title" content="Th.Tech - عالم الذكاء الاصطناعي والتكنولوجيا" />
  <meta property="og:description" content="منصة متخصصة في الذكاء الاصطناعي والتكنولوجيا الحديثة. مقالات تقنية معمقة وشروحات عملية." />
  <meta property="og:image" content="https://oumaystore-hub.github.io/Th-tech/logo1.png" />
  <meta property="og:locale" content="ar_SA" />
  
  <!-- Twitter Card (تويتر / X) -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Th.Tech - الذكاء الاصطناعي والتكنولوجيا" />
  <meta name="twitter:description" content="منصة متخصصة في الذكاء الاصطناعي والتكنولوجيا الحديثة" />
  <meta name="twitter:image" content="https://oumaystore-hub.github.io/Th-tech/logo1.png" />
  
  <!-- Canonical URL -->
  <link rel="canonical" href="https://oumaystore-hub.github.io/Th-tech/" />
  
  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/Th-tech/logo1.png" />
</head>
<body>
  <Header />

  <main class="main-wrapper">
    
    <!-- Hero Section: القسم الرئيسي -->
    <section class="hero-section">
      <div class="hero-bg"></div>
      <div class="container hero-content">
        <span class="hero-badge">🚀 مرحباً بك في المستقبل</span>
        <h1>اكتشف عالم <span class="highlight">الذكاء الاصطناعي</span><br />والابتكار التقني</h1>
        <p class="hero-desc">منصة متخصصة تُقدّم أحدث المقالات والشروحات التقنية في مجال الذكاء الاصطناعي، البرمجة، والأمن السيبراني لمساعدتك على البقاء في المقدمة.</p>
        
        <div class="hero-buttons">
          <a href="/Th-tech/category/" class="btn btn-primary">
            استكشف التصنيفات 
          </a>
          <a href="/Th-tech/articles/" class="btn btn-outline">
            تصفح المقالات 
          </a>
        </div>
      </div>
    </section>

    <!-- Features Section: لماذا Th.Tech؟ -->
    <section class="features-section">
      <div class="container">
        <div class="section-header">
          <h2>لماذا <span class="highlight">Th.Tech</span>؟</h2>
          <p>نقدم لك محتوى يجمع بين العمق التقني والبساطة في الشرح</p>
        </div>
        
        <div class="features-grid">
          <div class="feature-card">
            <div class="icon-box">🤖</div>
            <h3>ذكاء اصطناعي متقدم</h3>
            <p>نواكب أحدث تطورات الـ AI ونماذج اللغة الكبيرة (LLMs) ونشرحها بأسلوب عملي.</p>
          </div>
          
          <div class="feature-card">
            <div class="icon-box">🔒</div>
            <h3>أمن سيبراني موثوق</h3>
            <p>شروحات حول حماية البيانات، الاختراق الأخلاقي، وأدوات الدفاع السيبراني الحديثة.</p>
          </div>
          
          <div class="feature-card">
            <div class="icon-box">💻</div>
            <h3>برمجة وهندسة برمجيات</h3>
            <p>من أساسيات البرمجة إلى بناء أنظمة معقدة باستخدام أحدث الأطر (Frameworks).</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Highlights Section: أبرز المواضيع -->
    <section class="highlights-section">
      <div class="container">
        <div class="section-header">
          <h2> مواضيع رائجة</h2>
          <p>تصفح أبرز المواضيع التي يبحث عنها القراء حالياً</p>
        </div>

        <div class="highlights-grid">
          <!-- Topic 1 -->
          <div class="topic-card">
            <div class="topic-icon">🧠</div>
            <div class="topic-content">
              <h3>تعلم الآلة</h3>
              <a href="/Th-tech/ai/" class="read-more">استكشف المقالات ←</a>
            </div>
          </div>

          <!-- Topic 2 -->
          <div class="topic-card">
            <div class="topic-icon">🔗</div>
            <div class="topic-content">
              <h3>البلوك تشين</h3>
              <a href="/Th-tech/blockchain/" class="read-more">استكشف المقالات ←</a>
            </div>
          </div>

          <!-- Topic 3 -->
          <div class="topic-card">
            <div class="topic-icon"></div>
            <div class="topic-content">
              <h3>علم البيانات</h3>
              <a href="/Th-tech/data-science/" class="read-more">استكشف المقالات ←</a>
            </div>
          </div>
          
           <!-- Topic 4 -->
           <div class="topic-card">
            <div class="topic-icon">️</div>
            <div class="topic-content">
              <h3>الحوسبة السحابية</h3>
              <a href="/Th-tech/cloud/" class="read-more">استكشف المقالات ←</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section: دعوة للانضمام -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-box">
          <h2>🚀 هل أنت مستعد لتعلم شيء جديد؟</h2>
          <p>انضم إلى آلاف المطورين والمتخصصين الذين يقرأون Th.Tech يومياً.</p>
          <div class="cta-buttons">
            <a href="/Th-tech/category/" class="btn btn-light">ابدأ التصفح الآن</a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</body>
</html>

<style>
  :root {
    --bg: #f8fafc;
    --card: #ffffff;
    --text: #0f172a;
    --text-sec: #64748b;
    --primary: #0284c7;
    --primary-dark: #0369a1;
    --accent: #0ea5e9;
    --border: rgba(2,132,199,0.15);
    --shadow: 0 4px 20px rgba(0,0,0,0.05);
  }

  html.dark-mode {
    --bg: #0b1120;
    --card: #1e293b;
    --text: #f1f5f9;
    --text-sec: #94a3b8;
    --primary: #38bdf8;
    --primary-dark: #0284c7;
    --accent: #7dd3fc;
    --border: rgba(56,189,248,0.15);
    --shadow: 0 4px 20px rgba(0,0,0,0.3);
  }

  * { box-sizing: border-box; }
  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family: 'Segoe UI', system-ui, sans-serif;
    line-height: 1.6;
  }
  
  .main-wrapper { overflow-x: hidden; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
  .highlight { color: var(--primary); }
  
  /* Hero Section */
  .hero-section {
    position: relative;
    padding: 6rem 0 5rem;
    text-align: center;
    background: var(--bg);
    overflow: hidden;
  }
  
  .hero-bg {
    position: absolute; top: 0; left: 0; right: 0; bottom: 0;
    background: radial-gradient(circle at 50% 50%, rgba(2,132,199,0.08) 0%, transparent 60%);
    z-index: 0;
  }
  
  .hero-content { position: relative; z-index: 1; }
  
  .hero-badge {
    display: inline-block;
    background: var(--primary);
    color: white;
    padding: 0.5rem 1.5rem;
    border-radius: 50px;
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    box-shadow: 0 4px 15px rgba(2,132,199,0.3);
  }
  
  .hero-section h1 {
    font-size: 3.2rem;
    line-height: 1.2;
    margin-bottom: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }
  
  .hero-desc {
    font-size: 1.25rem;
    color: var(--text-sec);
    max-width: 700px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }
  
  .hero-buttons {
    display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;
  }
  
  .btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 1rem 2rem;
    border-radius: 12px;
    font-weight: 700;
    font-size: 1.05rem;
    text-decoration: none;
    transition: all 0.3s;
  }
  
  .btn-primary {
    background: var(--primary);
    color: white;
    box-shadow: 0 5px 20px rgba(2,132,199,0.3);
  }
  .btn-primary:hover {
    transform: translateY(-3px);
    background: var(--primary-dark);
    box-shadow: 0 8px 25px rgba(2,132,199,0.4);
  }
  
  .btn-outline {
    background: transparent;
    border: 2px solid var(--border);
    color: var(--text);
  }
  .btn-outline:hover {
    border-color: var(--primary);
    color: var(--primary);
    transform: translateY(-3px);
  }
  
  .btn-light {
    background: white;
    color: var(--primary);
    box-shadow: 0 5px 20px rgba(0,0,0,0.1);
  }
  .btn-light:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.15);
  }

  /* Features Section */
  .features-section { padding: 5rem 0; background: var(--card); }
  .section-header { text-align: center; margin-bottom: 4rem; }
  .section-header h2 { font-size: 2.2rem; margin-bottom: 0.5rem; color: var(--text); }
  .section-header p { color: var(--text-sec); font-size: 1.1rem; }
  
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2.5rem;
  }
  
  .feature-card {
    background: var(--bg);
    padding: 2.5rem;
    border-radius: 20px;
    text-align: center;
    border: 1px solid var(--border);
    transition: all 0.4s;
  }
  .feature-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow);
    border-color: var(--primary);
  }
  .icon-box { font-size: 3.5rem; margin-bottom: 1.5rem; display: block; }
  .feature-card h3 { font-size: 1.4rem; margin-bottom: 1rem; color: var(--text); }
  .feature-card p { color: var(--text-sec); font-size: 1rem; line-height: 1.7; margin: 0; }

  /* Highlights Section */
  .highlights-section { padding: 5rem 0; background: var(--bg); }
  .highlights-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }
  .topic-card {
    background: var(--card);
    border: 2px solid var(--border);
    border-radius: 16px;
    padding: 2rem;
    display: flex; align-items: center; gap: 1.5rem;
    transition: all 0.3s;
    text-decoration: none;
  }
  .topic-card:hover {
    border-color: var(--primary);
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
  }
  .topic-icon { font-size: 2.5rem; flex-shrink: 0; }
  .topic-content h3 { font-size: 1.2rem; margin: 0 0 0.5rem; color: var(--text); }
  .read-more { color: var(--primary); font-weight: 600; font-size: 0.9rem; text-decoration: none; }
  .read-more:hover { text-decoration: underline; }

  /* CTA Section */
  .cta-section { padding: 4rem 1.5rem 6rem; }
  .cta-box {
    background: linear-gradient(135deg, var(--primary), var(--primary-dark));
    color: white;
    border-radius: 24px;
    padding: 4rem 2rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .cta-box::before {
    content: ''; position: absolute; top: -50%; right: -20%; width: 400px; height: 400px;
    background: rgba(255,255,255,0.1); border-radius: 50%;
  }
  .cta-box h2 { font-size: 2rem; margin-bottom: 1rem; position: relative; z-index: 1; }
  .cta-box p { font-size: 1.1rem; margin-bottom: 2rem; opacity: 0.9; position: relative; z-index: 1; }

  /* Mobile Responsive */
  @media (max-width: 768px) {
    .hero-section { padding: 4rem 0 3rem; }
    .hero-section h1 { font-size: 2.2rem; }
    .hero-desc { font-size: 1rem; }
    .features-grid, .highlights-grid { grid-template-columns: 1fr; }
    .cta-box { padding: 3rem 1.5rem; }
    .cta-box h2 { font-size: 1.5rem; }
  }
</style>
