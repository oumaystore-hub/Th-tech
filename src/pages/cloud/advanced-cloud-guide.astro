    .article h2 { font-size: 1.4rem !important; }
    .article h3 { font-size: 1.2rem !important; }
    .article h4 { font-size: 1.05rem !important; }
    .article-image { margin: 1.5rem 0 !important; }
    .article-image img { height: 200px !important; object-fit: cover !important; }
    .image-caption { padding: 0.8rem 1rem !important; font-size: 0.85rem !important; }
    .toc-btn { width: 50px !important; height: 50px !important; bottom: 15px !important; left: 15px !important; font-size: 1.6rem !important; }
    .back-to-top { width: 42px !important; height: 42px !important; bottom: 75px !important; left: 15px !important; font-size: 1.4rem !important; }
    .toc-modal { padding: 7rem 1rem 1rem !important; }
    .toc-box { max-width: 95% !important; border-radius: 16px !important; }
    .toc-head { padding: 1.2rem 1.5rem !important; }
    .toc-head h3 { font-size: 1.2rem !important; }
    .toc-nav { padding: 0.8rem !important; gap: 0.5rem !important; }
    .toc-item { padding: 0.9rem 1rem !important; font-size: 0.95rem !important; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // ✅ منطق الفهرس (يستخدم div بدلاً من a)
    var tocBtn = document.getElementById('tocBtn');
    var tocModal = document.getElementById('tocModal');
    var tocClose = document.getElementById('tocClose');
    var tocNav = document.getElementById('tocNav');
    
    if (tocBtn && tocModal && tocNav) {
      document.querySelectorAll('.article h3').forEach(function(h3) {
        var item = document.createElement('div');
        item.className = 'toc-item';
        item.textContent = h3.textContent;
        item.onclick = function(e) {
          e.preventDefault();
          h3.scrollIntoView({ behavior: 'smooth' });
          tocModal.classList.remove('active');
        };
        tocNav.appendChild(item);
      });

      tocBtn.onclick = function() { tocModal.classList.add('active'); };
      tocClose.onclick = function() { tocModal.classList.remove('active'); };
      tocModal.onclick = function(e) { if (e.target === tocModal) tocModal.classList.remove('active'); };
    }

    // ✅ منطق السهم المنبثق
    var backBtn = document.getElementById('backToTop');
    if (backBtn) {
      window.addEventListener('scroll', function() {
        if (window.scrollY > 400) {
          backBtn.classList.add('show');
        } else {
          backBtn.classList.remove('show');
        }
      }, { passive: true });

      backBtn.addEventListener('click', function() {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }
  });
</script>
