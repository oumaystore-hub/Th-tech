      <h4>8.3 GraphQL:</h4>
      <ul>
        <li><strong>Schema and Resolvers:</strong>
          <pre style="background:#1e293b;color:#e2e8f0;padding:1rem;border-radius:8px;overflow-x:auto;margin:1rem 0"><code>// schema.graphql
type Query {
    user(id: ID!): User
    users(limit: Int, offset: Int): [User!]!
    postsByUser(userId: ID!): [Post!]!
}

type Mutation {
    createUser(name: String!, email: String!): User!
    updateUser(id: ID!, name: String, email: String): User
    deleteUser(id: ID!): Boolean!
}

type User {
    id: ID!
    name: String!
    email: String!
    posts: [Post!]!
    createdAt: DateTime!
}

type Post {
    id: ID!
    title: String!
    content: String!
    author: User!
    publishedAt: DateTime
}

// resolvers.js
const resolvers = {
    Query: {
        user: async (_, { id }, { dataSources }) => {
            return dataSources.userAPI.getUserById(id);
        },
        users: async (_, { limit = 10, offset = 0 }, { dataSources }) => {
            return dataSources.userAPI.getUsers({ limit, offset });
        },
        postsByUser: async (_, { userId }, { dataSources }) => {
            return dataSources.postAPI.getPostsByUser(userId);
        }
    },
    Mutation: {
        createUser: async (_, args, { dataSources }) => {
            return dataSources.userAPI.createUser(args);
        },
        updateUser: async (_, { id, ...updates }, { dataSources }) => {
            return dataSources.userAPI.updateUser(id, updates);
        },
        deleteUser: async (_, { id }, { dataSources }) => {
            return dataSources.userAPI.deleteUser(id);
        }
    },
    User: {
        posts: async (user, _, { dataSources }) => {
            return dataSources.postAPI.getPostsByUser(user.id);
        }
    }
};</code></pre>
