      <h4>8.1 WebAssembly (Wasm):</h4>
      <ul>
        <li><strong>Example - Rust to WebAssembly:</strong>
          <pre style="background:#1e293b;color:#e2e8f0;padding:1rem;border-radius:8px;overflow-x:auto;margin:1rem 0"><code>// Rust code (lib.rs)
#[wasm_bindgen]
pub fn fibonacci(n: u32) -&gt; u32 {
    match n {
        0 =&gt; 0,
        1 =&gt; 1,
        _ =&gt; fibonacci(n - 1) + fibonacci(n - 2),
    }
}

#[wasm_bindgen]
pub fn calculate_primes(limit: u32) -&gt; Vec&lt;u32&gt; {
    let mut primes = Vec::new();
    for num in 2..=limit {
        if is_prime(num) {
            primes.push(num);
        }
    }
    primes
}

fn is_prime(n: u32) -&gt; bool {
    if n &lt; 2 {
        return false;
    }
    for i in 2..=(n as f64).sqrt() as u32 {
        if n % i == 0 {
            return false;
        }
    }
    true
}

// JavaScript usage
import init, { fibonacci, calculate_primes } from './pkg/myapp.js';

async function run() {
    await init();
    
    console.log(fibonacci(10)); // 55
    console.log(calculate_primes(100)); // [2, 3, 5, 7, 11, ...]
}</code></pre>
