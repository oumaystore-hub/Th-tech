      <h4>4.3 Database Optimization:</h4>
      <ul>
        <li><strong>Indexing:</strong>
          <pre style="background:#1e293b;color:#e2e8f0;padding:1rem;border-radius:8px;overflow-x:auto;margin:1rem 0"><code>-- بدون Index (Full Table Scan)
SELECT * FROM users WHERE email = 'john@example.com';
-- الوقت: O(n)

-- مع Index
CREATE INDEX idx_email ON users(email);
-- الوقت: O(log n)

-- Composite Index
CREATE INDEX idx_name_email ON users(last_name, first_name);</code></pre>
        </li>
        
        <li><strong>Query Optimization:</strong>
          <pre style="background:#1e293b;color:#e2e8f0;padding:1rem;border-radius:8px;overflow-x:auto;margin:1rem 0"><code>-- ❌ سيء - SELECT *
SELECT * FROM orders WHERE customer_id = 123;

-- ✅ جيد - تحديد الأعمدة المطلوبة فقط
SELECT id, order_date, total_amount 
FROM orders 
WHERE customer_id = 123;

-- ❌ سيء - N+1 Query Problem
SELECT * FROM users;
-- ثم لكل مستخدم: SELECT * FROM orders WHERE user_id = ?

-- ✅ جيد - JOIN
SELECT u.*, o.* 
FROM users u
LEFT JOIN orders o ON u.id = o.user_id;

-- ✅ استخدام LIMIT و OFFSET للتقسيم
SELECT * FROM products
ORDER BY created_at DESC
LIMIT 20 OFFSET 0; -- الصفحة الأولى</code></pre>
