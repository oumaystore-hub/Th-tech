      <h4>5.2 Authentication & Authorization:</h4>
      <ul>
        <li><strong>JWT Implementation:</strong>
          <pre style="background:#1e293b;color:#e2e8f0;padding:1rem;border-radius:8px;overflow-x:auto;margin:1rem 0"><code>import jwt from 'jsonwebtoken';
import bcrypt from 'bcrypt';

class AuthService {
    private readonly JWT_SECRET = process.env.JWT_SECRET!;
    private readonly JWT_EXPIRES_IN = '24h';
    
    async login(email: string, password: string): Promise<string> {
        const user = await this.userRepository.findByEmail(email);
        
        if (!user || !await bcrypt.compare(password, user.password)) {
            throw new UnauthorizedError('Invalid credentials');
        }
        
        const payload = {
            userId: user.id,
            email: user.email,
            role: user.role
        };
        
        return jwt.sign(payload, this.JWT_SECRET, {
            expiresIn: this.JWT_EXPIRES_IN
        });
    }
    
    verifyToken(token: string): any {
        try {
            return jwt.verify(token, this.JWT_SECRET);
        } catch (error) {
            throw new UnauthorizedError('Invalid or expired token');
        }
    }
}

// Middleware للتحقق من التوكن
function authMiddleware(req: Request, res: Response, next: NextFunction) {
    const authHeader = req.headers.authorization;
    
    if (!authHeader || !authHeader.startsWith('Bearer ')) {
        return res.status(401).json({ error: 'No token provided' });
    }
    
    const token = authHeader.split(' ')[1];
    
    try {
        const authService = new AuthService();
        const decoded = authService.verifyToken(token);
        req.user = decoded;
        next();
    } catch (error) {
        res.status(401).json({ error: 'Invalid token' });
    }
}

// استخدام Middleware
app.get('/api/profile', authMiddleware, (req, res) => {
    res.json({ user: req.user });
});</code></pre>
