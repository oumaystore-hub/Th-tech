    .article h2 { font-size: 1.4rem; }
    .article h3 { font-size: 1.2rem; }
    .article h4 { font-size: 1.05rem; }
    .article-image { margin: 1.5rem 0; }
    .article-image img { height: 200px; object-fit: cover; }
    .image-caption { padding: 0.8rem 1rem; font-size: 0.85rem; }
    .toc-btn { width: 50px; height: 50px; bottom: 15px; left: 15px; font-size: 1.6rem; }
    .back-to-top { width: 42px; height: 42px; bottom: 75px; left: 15px; font-size: 1.4rem; }
