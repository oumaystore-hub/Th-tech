      <h2>البرمجة المتقدمة: الدليل الشامل من الأساسيات إلى الاحتراف</h2>
      <div class="meta">📅 18 يوليو 2026 | ⏱️ 1000+ دقيقة قراءة</div>
      <p class="intro">هذا الدليل الشامل والمفصل جداً (أكثر من 1000 دقيقة قراءة) هو مرجع متكامل لمهندسي البرمجيات، مطوري Full-Stack، ومعماريي الأنظمة. يغطي كل جوانب البرمجة المتقدمة: من مبادئ التصميم والأنماط المعمارية، إلى هندسة الميكروسيرفيسز، الأداء الأمثل، الأمان المتقدم، الاختبار الشامل، CI/CD، وأفضل الممارسات من الواقع. يتضمن عشرات الأمثلة العملية، دراسات حالة، وأكواد جاهزة للتطبيق.</p>
      
      <div class="article-image">
        <img src="https://images.unsplash.com/photo-1461749280684-dccba630e2f6?w=900&h=400&fit=crop" alt="Advanced Programming" />
        <p class="image-caption">هندسة البرمجيات المتقدمة - بناء أنظمة معقدة قابلة للصيانة والتوسع</p>
      </div>

      <h3>📐 الجزء الأول: مبادئ التصميم المتقدمة (SOLID Deep Dive)</h3>
      <p>مبادئ SOLID هي الأساس الذي تُبنى عليه أي برمجيات احترافية. فهمها العميق يميز المهندس المحترف عن المبتدئ:</p>
      
      <h4>1.1 Single Responsibility Principle (SRP) - بالتفصيل:</h4>
      <ul>
        <li><strong>التعريف الدقيق:</strong> "يجب أن يكون للكلاس سبب واحد فقط للتغيير" - Robert C. Martin</li>
        <li><strong>لماذا مهم:</strong>
          <br/>• يقلل الـ Coupling بين المكونات.
          <br/>• يسهل الصيانة (تعديل في مكان واحد فقط).
          <br/>• يحسن إمكانية إعادة الاستخدام.
          <br/>• يجعل الكود أكثر قابلية للاختبار.</li>
        <li><strong>مثال عملي (قبل وبعد):</strong>
          <pre style="background:#1e293b;color:#e2e8f0;padding:1rem;border-radius:8px;overflow-x:auto;margin:1rem 0"><code>// ❌ مثال سيء - ينتهك SRP
class UserService {
    saveUser(user) {
        // التحقق من البيانات
        if (!user.email || !user.password) {
            throw new Error('Invalid data');
        }
        
        // حفظ في قاعدة البيانات
        db.users.insert(user);
        
        // إرسال بريد ترحيبي
        emailService.send(user.email, 'Welcome!');
        
        // تسجيل في نظام التحليلات
        analytics.track('user_registered', user);
    }
}

// ✅ مثال جيد - تطبيق SRP
class UserValidator {
    validate(user) {
        if (!user.email || !user.password) {
            throw new Error('Invalid data');
        }
    }
}

class UserRepository {
    save(user) {
        db.users.insert(user);
    }
}

class EmailNotifier {
    sendWelcomeEmail(email) {
        emailService.send(email, 'Welcome!');
    }
}

class AnalyticsTracker {
    trackUserRegistration(user) {
        analytics.track('user_registered', user);
    }
}

class UserService {
    constructor(validator, repository, notifier, tracker) {
        this.validator = validator;
        this.repository = repository;
        this.notifier = notifier;
        this.tracker = tracker;
    }
    
    saveUser(user) {
        this.validator.validate(user);
        this.repository.save(user);
        this.notifier.sendWelcomeEmail(user.email);
        this.tracker.trackUserRegistration(user);
    }
}</code></pre>
        </li>
      </ul>

      <h4>1.2 Open/Closed Principle (OCP) - بالتفصيل:</h4>
      <ul>
        <li><strong>التعريف:</strong> "يجب أن تكون الكيانات البرمجية مفتوحة للتوسعة، مغلقة للتعديل"</li>
        <li><strong>كيفية التطبيق:</strong>
          <br/>• استخدام الـ Interfaces و Abstract Classes.
          <br/>• Strategy Pattern.
          <br/>• Plugin Architecture.</li>
        <li><strong>مثال عملي:</strong>
          <pre style="background:#1e293b;color:#e2e8f0;padding:1rem;border-radius:8px;overflow-x:auto;margin:1rem 0"><code>// ✅ تطبيق OCP باستخدام Strategy Pattern
class PaymentProcessor {
    constructor(paymentStrategy) {
        this.paymentStrategy = paymentStrategy;
    }
    
    processPayment(amount) {
        return this.paymentStrategy.pay(amount);
    }
}

// استراتيجيات دفع مختلفة - يمكن إضافة المزيد دون تعديل الكود الأصلي
class CreditCardPayment {
    pay(amount) {
        console.log(`Processing $${amount} via Credit Card`);
        // منطق الدفع ببطاقة الائتمان
    }
}

class PayPalPayment {
    pay(amount) {
        console.log(`Processing $${amount} via PayPal`);
        // منطق الدفع عبر PayPal
    }
}

class CryptoPayment {
    pay(amount) {
        console.log(`Processing $${amount} via Cryptocurrency`);
        // منطق الدفع بالعملات الرقمية
    }
}

// يمكن إضافة استراتيجية جديدة (مثل Apple Pay) دون تعديل أي كود موجود
class ApplePayPayment {
    pay(amount) {
        console.log(`Processing $${amount} via Apple Pay`);
    }
}

// الاستخدام
const processor = new PaymentProcessor(new CreditCardPayment());
processor.processPayment(100);</code></pre>
        </li>
      </ul>

      <h4>1.3 Liskov Substitution Principle (LSP) - بالتفصيل:</h4>
      <ul>
        <li><strong>التعريف:</strong> "يجب أن تكون الكائنات الفرعية قابلة للاستبدال بكائنات الأبوية دون تغيير في سلوك البرنامج"</li>
        <li><strong>مثال على انتهاك LSP:</strong>
          <pre style="background:#1e293b;color:#e2e8f0;padding:1rem;border-radius:8px;overflow-x:auto;margin:1rem 0"><code>// ❌ انتهاك LSP
class Bird {
    fly() {
        console.log('Flying...');
    }
}

class Penguin extends Bird {
    fly() {
        throw new Error('Penguins cannot fly!');
    }
}

function makeBirdFly(bird) {
    bird.fly(); // سيفشل مع Penguin
}

// ✅ الحل الصحيح
class Bird {
    move() {
        // تنفيذ افتراضي
    }
}

class FlyingBird extends Bird {
    fly() {
        console.log('Flying...');
    }
    
    move() {
        this.fly();
    }
}

class SwimmingBird extends Bird {
    swim() {
        console.log('Swimming...');
    }
    
    move() {
        this.swim();
    }
}

class Penguin extends SwimmingBird {
    // Penguin يسبح فقط
}</code></pre>
        </li>
      </ul>

      <h4>1.4 Interface Segregation Principle (ISP) - بالتفصيل:</h4>
      <ul>
        <li><strong>المبدأ:</strong> "لا تجبر الكلاسات على تنفيذ واجهات لا تستخدمها"</li>
        <li><strong>مثال عملي:</strong>
          <pre style="background:#1e293b;color:#e2e8f0;padding:1rem;border-radius:8px;overflow-x:auto;margin:1rem 0"><code>// ❌ واجهة كبيرة (Fat Interface)
class Worker {
    work() {}
    eat() {}
    sleep() {}
}

class HumanWorker implements Worker {
    work() { console.log('Working'); }
    eat() { console.log('Eating'); }
    sleep() { console.log('Sleeping'); }
}

class RobotWorker implements Worker {
    work() { console.log('Working'); }
    eat() { 
        // Robots don't eat! لكن مضطرين لتنفيذها
        throw new Error('Not implemented');
    }
    sleep() {
        // Robots don't sleep!
        throw new Error('Not implemented');
    }
}

// ✅ الحل: واجهات صغيرة ومحددة
class Workable {
    work() {}
}

class Eatable {
    eat() {}
}

class Sleepable {
    sleep() {}
}

class HumanWorker implements Workable, Eatable, Sleepable {
    work() { console.log('Working'); }
    eat() { console.log('Eating'); }
    sleep() { console.log('Sleeping'); }
}

class RobotWorker implements Workable {
    work() { console.log('Working'); }
    // Robot لا يحتاج لتطبيق Eatable أو Sleepable
}</code></pre>
        </li>
      </ul>

      <h4>1.5 Dependency Inversion Principle (DIP) - بالتفصيل:</h4>
      <ul>
        <li><strong>المبدأ:</strong> "اعتمد على التجريدات، وليس على التفاصيل"</li>
        <li><strong>الفوائد:</strong>
          <br/>• يقلل الـ Coupling.
          <br/>• يسهل الاختبار (Mocking).
          <br/>• يجعل الكود أكثر مرونة.</li>
        <li><strong>مثال عملي مع Dependency Injection:</strong>
          <pre style="background:#1e293b;color:#e2e8f0;padding:1rem;border-radius:8px;overflow-x:auto;margin:1rem 0"><code>// ✅ تطبيق DIP مع Dependency Injection
// التجريد (Interface)
interface Database {
    connect(): void;
    query(sql: string): any[];
    disconnect(): void;
}

// التطبيق التفصيلي (Concrete Implementation)
class MySQLDatabase implements Database {
    connect() {
        console.log('Connecting to MySQL...');
    }
    
    query(sql: string): any[] {
        console.log(`Executing MySQL query: ${sql}`);
        return [];
    }
    
    disconnect() {
        console.log('Disconnecting from MySQL...');
    }
}

class MongoDB implements Database {
    connect() {
        console.log('Connecting to MongoDB...');
    }
    
    query(sql: string): any[] {
        console.log(`Executing MongoDB query: ${sql}`);
        return [];
    }
    
    disconnect() {
        console.log('Disconnecting from MongoDB...');
    }
}

// الكلاس الذي يعتمد على التجريد
class UserRepository {
    constructor(private database: Database) {
        // يعتمد على Interface، ليس على تطبيق محدد
    }
    
    findById(id: number) {
        this.database.connect();
        const result = this.database.query(`SELECT * FROM users WHERE id = ${id}`);
        this.database.disconnect();
        return result;
    }
}

// الاستخدام - يمكن تغيير قاعدة البيانات بسهولة
const mysqlRepo = new UserRepository(new MySQLDatabase());
const mongoRepo = new UserRepository(new MongoDB());

// في الاختبار، يمكن استخدام Mock
class MockDatabase implements Database {
    connect() {}
    query(sql: string) { return [{id: 1, name: 'Test'}]; }
    disconnect() {}
}

const testRepo = new UserRepository(new MockDatabase());</code></pre>
        </li>
      </ul>

      <div class="article-image">
        <img src="https://images.unsplash.com/photo-1555066931-4365d14bab8c?w=900&h=350&fit=crop" alt="SOLID Principles" />
        <p class="image-caption">مبادئ SOLID - الأساس لبناء برمجيات قابلة للصيانة والتوسع</p>
      </div>

      <h3>🎨 الجزء الثاني: أنماط التصميم المتقدمة (Design Patterns Deep Dive)</h3>
      <p>أنماط التصميم هي حلول مجربة ومختبرة لمشاكل متكررة في البرمجة:</p>
      
      <h4>2.1 الأنماط الإنشائية (Creational Patterns):</h4>
      <ul>
        <li><strong>Singleton Pattern:</strong>
          <pre style="background:#1e293b;color:#e2e8f0;padding:1rem;border-radius:8px;overflow-x:auto;margin:1rem 0"><code>class DatabaseConnection {
    private static instance: DatabaseConnection;
    
    private constructor() {
        // Private constructor prevents direct instantiation
    }
    
    public static getInstance(): DatabaseConnection {
        if (!DatabaseConnection.instance) {
            DatabaseConnection.instance = new DatabaseConnection();
        }
        return DatabaseConnection.instance;
    }
    
    public query(sql: string) {
        console.log(`Executing: ${sql}`);
    }
}

// الاستخدام
const db1 = DatabaseConnection.getInstance();
const db2 = DatabaseConnection.getInstance();
console.log(db1 === db2); // true - نفس الكائن</code></pre>
        </li>
        
        <li><strong>Factory Pattern:</strong>
          <pre style="background:#1e293b;color:#e2e8f0;padding:1rem;border-radius:8px;overflow-x:auto;margin:1rem 0"><code>// Factory Pattern لإنشاء كائنات معقدة
class Vehicle {
    constructor(type: string) {
        this.type = type;
    }
    
    drive() {
        console.log(`Driving ${this.type}`);
    }
}

class VehicleFactory {
    static createVehicle(type: string): Vehicle {
        switch(type.toLowerCase()) {
            case 'car':
                return new Car();
            case 'motorcycle':
                return new Motorcycle();
            case 'truck':
                return new Truck();
            default:
                throw new Error('Unknown vehicle type');
        }
    }
}

class Car extends Vehicle {
    constructor() {
        super('Car');
    }
}

class Motorcycle extends Vehicle {
    constructor() {
        super('Motorcycle');
    }
}

class Truck extends Vehicle {
    constructor() {
        super('Truck');
    }
}

// الاستخدام
const car = VehicleFactory.createVehicle('car');
car.drive();</code></pre>
        </li>
        
        <li><strong>Builder Pattern:</strong>
          <pre style="background:#1e293b;color:#e2e8f0;padding:1rem;border-radius:8px;overflow-x:auto;margin:1rem 0"><code>// Builder Pattern للكائنات المعقدة
class Computer {
    private cpu: string;
    private ram: string;
    private storage: string;
    private gpu?: string;
    private wifi?: boolean;
    
    constructor(builder: ComputerBuilder) {
        this.cpu = builder.cpu;
        this.ram = builder.ram;
        this.storage = builder.storage;
        this.gpu = builder.gpu;
        this.wifi = builder.wifi;
    }
    
    displaySpecs() {
        console.log(`CPU: ${this.cpu}`);
        console.log(`RAM: ${this.ram}`);
        console.log(`Storage: ${this.storage}`);
        if (this.gpu) console.log(`GPU: ${this.gpu}`);
        if (this.wifi) console.log(`WiFi: ${this.wifi}`);
    }
}

class ComputerBuilder {
    public cpu: string;
    public ram: string;
    public storage: string;
    public gpu?: string;
    public wifi?: boolean;
    
    setCpu(cpu: string) {
        this.cpu = cpu;
        return this;
    }
    
    setRam(ram: string) {
        this.ram = ram;
        return this;
    }
    
    setStorage(storage: string) {
        this.storage = storage;
        return this;
    }
    
    setGpu(gpu: string) {
        this.gpu = gpu;
        return this;
    }
    
    setWifi(wifi: boolean) {
        this.wifi = wifi;
        return this;
    }
    
    build(): Computer {
        return new Computer(this);
    }
}

// الاستخدام
const gamingPC = new ComputerBuilder()
    .setCpu('Intel i9')
    .setRam('32GB')
    .setStorage('1TB SSD')
    .setGpu('RTX 3080')
    .setWifi(true)
    .build();

gamingPC.displaySpecs();</code></pre>
        </li>
      </ul>

      <h4>2.2 الأنماط الهيكلية (Structural Patterns):</h4>
      <ul>
        <li><strong>Adapter Pattern:</strong>
          <pre style="background:#1e293b;color:#e2e8f0;padding:1rem;border-radius:8px;overflow-x:auto;margin:1rem 0"><code>// Adapter Pattern للتوافق بين واجهات مختلفة
// الواجهة القديمة
interface OldPayment {
    makePayment(amount: number): boolean;
}

// الواجهة الجديدة
interface NewPayment {
    processPayment(amount: number, currency: string): boolean;
}

// الكلاس القديم
class LegacyPayment implements OldPayment {
    makePayment(amount: number): boolean {
        console.log(`Processing payment of $${amount}`);
        return true;
    }
}

// Adapter
class PaymentAdapter implements NewPayment {
    constructor(private legacyPayment: LegacyPayment) {}
    
    processPayment(amount: number, currency: string): boolean {
        // تحويل العملة إذا لزم الأمر
        const convertedAmount = this.convertCurrency(amount, currency);
        return this.legacyPayment.makePayment(convertedAmount);
    }
    
    private convertCurrency(amount: number, currency: string): number {
        if (currency === 'USD') return amount;
        if (currency === 'EUR') return amount * 1.1;
        return amount;
    }
}

// الاستخدام
const legacy = new LegacyPayment();
const adapter = new PaymentAdapter(legacy);
adapter.processPayment(100, 'EUR');</code></pre>
        </li>
        
        <li><strong>Decorator Pattern:</strong>
          <pre style="background:#1e293b;color:#e2e8f0;padding:1rem;border-radius:8px;overflow-x:auto;margin:1rem 0"><code>// Decorator Pattern لإضافة وظائف ديناميكياً
interface Coffee {
    cost(): number;
    description(): string;
}

class SimpleCoffee implements Coffee {
    cost(): number {
        return 5;
    }
    
    description(): string {
        return 'Simple coffee';
    }
}

// Decorator أساسي
abstract class CoffeeDecorator implements Coffee {
    protected coffee: Coffee;
    
    constructor(coffee: Coffee) {
        this.coffee = coffee;
    }
    
    cost(): number {
        return this.coffee.cost();
    }
    
    description(): string {
        return this.coffee.description();
    }
}

// Decorators محددة
class MilkDecorator extends CoffeeDecorator {
    cost(): number {
        return this.coffee.cost() + 2;
    }
    
    description(): string {
        return this.coffee.description() + ', milk';
    }
}

class SugarDecorator extends CoffeeDecorator {
    cost(): number {
        return this.coffee.cost() + 1;
    }
    
    description(): string {
        return this.coffee.description() + ', sugar';
    }
}

class WhipCreamDecorator extends CoffeeDecorator {
    cost(): number {
        return this.coffee.cost() + 3;
    }
    
    description(): string {
        return this.coffee.description() + ', whip cream';
    }
}

// الاستخدام
let coffee: Coffee = new SimpleCoffee();
coffee = new MilkDecorator(coffee);
coffee = new SugarDecorator(coffee);
coffee = new WhipCreamDecorator(coffee);

console.log(coffee.description()); // Simple coffee, milk, sugar, whip cream
console.log(coffee.cost()); // 11</code></pre>
        </li>
      </ul>

      <h4>2.3 الأنماط السلوكية (Behavioral Patterns):</h4>
      <ul>
        <li><strong>Observer Pattern:</strong>
          <pre style="background:#1e293b;color:#e2e8f0;padding:1rem;border-radius:8px;overflow-x:auto;margin:1rem 0"><code>// Observer Pattern للإشعارات والتحديثات
interface Observer {
    update(message: string): void;
}

interface Subject {
    addObserver(observer: Observer): void;
    removeObserver(observer: Observer): void;
    notifyObservers(message: string): void;
}

class NewsAgency implements Subject {
    private observers: Observer[] = [];
    private news: string = '';
    
    addObserver(observer: Observer): void {
        this.observers.push(observer);
    }
    
    removeObserver(observer: Observer): void {
        const index = this.observers.indexOf(observer);
        if (index &gt; -1) {
            this.observers.splice(index, 1);
        }
    }
    
    notifyObservers(message: string): void {
        this.observers.forEach(observer =&gt; observer.update(message));
    }
    
    setNews(news: string): void {
        this.news = news;
        this.notifyObservers(news);
    }
}

class NewsChannel implements Observer {
    constructor(private name: string) {}
    
    update(message: string): void {
        console.log(`${this.name} received news: ${message}`);
    }
}

// الاستخدام
const agency = new NewsAgency();

const cnn = new NewsChannel('CNN');
const bbc = new NewsChannel('BBC');
const aljazeera = new NewsChannel('Al Jazeera');

agency.addObserver(cnn);
agency.addObserver(bbc);
agency.addObserver(aljazeera);

agency.setNews('Breaking: Major tech announcement!');
// CNN received news: Breaking: Major tech announcement!
// BBC received news: Breaking: Major tech announcement!
// Al Jazeera received news: Breaking: Major tech announcement!</code></pre>
        </li>
        
        <li><strong>Strategy Pattern:</strong>
          <pre style="background:#1e293b;color:#e2e8f0;padding:1rem;border-radius:8px;overflow-x:auto;margin:1rem 0"><code>// Strategy Pattern لتبديل الخوارزميات
interface SortingStrategy {
    sort(data: number[]): number[];
}

class BubbleSort implements SortingStrategy {
    sort(data: number[]): number[] {
        console.log('Using Bubble Sort');
        const arr = [...data];
        for (let i = 0; i &lt; arr.length; i++) {
            for (let j = 0; j &lt; arr.length - i - 1; j++) {
                if (arr[j] &gt; arr[j + 1]) {
                    [arr[j], arr[j + 1]] = [arr[j + 1], arr[j]];
                }
            }
        }
        return arr;
    }
}

class QuickSort implements SortingStrategy {
    sort(data: number[]): number[] {
        console.log('Using Quick Sort');
        const arr = [...data];
        if (arr.length &lt;= 1) return arr;
        
        const pivot = arr[arr.length - 1];
        const left = [];
        const right = [];
        
        for (let i = 0; i &lt; arr.length - 1; i++) {
            if (arr[i] &lt; pivot) {
                left.push(arr[i]);
            } else {
                right.push(arr[i]);
            }
        }
        
        return [...this.sort(left), pivot, ...this.sort(right)];
    }
}

class MergeSort implements SortingStrategy {
    sort(data: number[]): number[] {
        console.log('Using Merge Sort');
        if (data.length &lt;= 1) return data;
        
        const mid = Math.floor(data.length / 2);
        const left = this.sort(data.slice(0, mid));
        const right = this.sort(data.slice(mid));
        
        return this.merge(left, right);
    }
    
    private merge(left: number[], right: number[]): number[] {
        const result: number[] = [];
        let i = 0, j = 0;
        
        while (i &lt; left.length &amp;&amp; j &lt; right.length) {
            if (left[i] &lt; right[j]) {
                result.push(left[i++]);
            } else {
                result.push(right[j++]);
            }
        }
        
        return result.concat(left.slice(i)).concat(right.slice(j));
    }
}

class Sorter {
    constructor(private strategy: SortingStrategy) {}
    
    setStrategy(strategy: SortingStrategy): void {
        this.strategy = strategy;
    }
    
    sort(data: number[]): number[] {
        return this.strategy.sort(data);
    }
}

// الاستخدام
const sorter = new Sorter(new BubbleSort());
sorter.sort([5, 2, 8, 1, 9]);

sorter.setStrategy(new QuickSort());
sorter.sort([5, 2, 8, 1, 9]);

sorter.setStrategy(new MergeSort());
sorter.sort([5, 2, 8, 1, 9]);</code></pre>
