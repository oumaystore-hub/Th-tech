  <main style="max-width:950px;margin:0 auto;padding:3rem 1.5rem">
    <div style="text-align:center;padding:3rem 2rem;margin-bottom:3rem;background:linear-gradient(135deg,#0284c7,#00d4ff);border-radius:16px;color:white">
      <h1 style="font-size:2.5rem;margin:0 0 1rem"> الدليل الشامل لمطور Full-Stack</h1>
      <p style="font-size:1.2rem;opacity:0.95">من الصفر إلى الاحتراف: هندسة البرمجيات الحديثة</p>
    </div>

    <article style="background:#fff;border:2px solid #e2e8f0;border-radius:16px;padding:3rem 2.5rem;margin-bottom:3rem;box-shadow:0 4px 20px rgba(0,0,0,0.05)">
      <span style="display:inline-block;background:#0284c7;color:white;padding:0.5rem 1.5rem;border-radius:50px;font-size:0.9rem;margin-bottom:1.5rem;font-weight:600">تطوير الويب المتقدم</span>
