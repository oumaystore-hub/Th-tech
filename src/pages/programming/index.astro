---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <title>البرمجة - Th.Tech</title>
</head>
<body>
  <Header />
  <main class="category-articles">
    <div class="page-header">
      <h1>💻 البرمجة والتطوير</h1>
      <p>لغات البرمجة، أطر العمل، وهندسة البرمجيات</p>
    </div>

    <button class="toc-btn" id="tocBtn">📑</button>
    <div class="toc-modal" id="tocModal">
      <div class="toc-box">
        <div class="toc-head">
          <h3>فهرس المقالات</h3>
          <button class="toc-close" id="tocClose">✕</button>
        </div>
        <nav class="toc-nav" id="tocNav"></nav>
      </div>
    </div>

    <article class="article" id="art1">
      <span class="badge">OOP</span>
      <h2>البرمجة الكائنية المتقدمة</h2>
      <div class="meta">📅 25 يونيو 2026 | ⏱️ 22 دقيقة</div>
      <p class="intro">البرمجة الكائنية (OOP) أحد أهم الركائز في هندسة البرمجيات الحديثة.</p>
      
      <h3>1. المبادئ الأربعة</h3>
      <ul>
        <li><strong>التغليف:</strong> حماية البيانات الداخلية</li>
        <li><strong>الوراثة:</strong> إعادة استخدام الكود</li>
        <li><strong>تعدد الأشكال:</strong> استجابات مختلفة لنفس الاستدعاء</li>
        <li><strong>التجريد:</strong> إخفاء التعقيدات</li>
      </ul>

      <h3>2. مبادئ SOLID</h3>
      <ul>
        <li><strong>S:</strong> مسؤولية واحدة</li>
        <li><strong>O:</strong> مفتوح للتوسيع، مغلق للتعديل</li>
        <li><strong>L:</strong> استبدال الكائنات الفرعية</li>
        <li><strong>I:</strong> واجهات متخصصة</li>
        <li><strong>D:</strong> الاعتماد على التجريدات</li>
      </ul>

      <h3>3. أنماط التصميم</h3>
      <ul>
        <li>Singleton، Factory، Builder</li>
        <li>Adapter، Decorator، Facade</li>
        <li>Observer، Strategy، Command</li>
      </ul>
    </article>

    <article class="article" id="art2">
      <span class="badge">لغات البرمجة</span>
      <h2>Python vs JavaScript</h2>
      <div class="meta">📅 28 يونيو 2026 | ⏱️ 16 دقيقة</div>
      <p class="intro">مقارنة شاملة بين أشهر لغتي البرمجة للمبتدئين.</p>
      
      <h3>Python</h3>
      <ul>
        <li>بناء جملة بسيط</li>
        <li>مكتبات ضخمة في الذكاء الاصطناعي</li>
        <li>مثالي للبيانات والأتمتة</li>
      </ul>

      <h3>JavaScript</h3>
      <ul>
        <li>تعمل في المتصفح والخادم</li>
        <li>إطار عمل غني (React, Vue)</li>
        <li>ضرورية لتطوير الويب</li>
      </ul>
    </article>

    <article class="article" id="art3">
      <span class="badge">React</span>
      <h2>React.js: دليل شامل</h2>
      <div class="meta">📅 1 يوليو 2026 | ⏱️ 20 دقيقة</div>
      <p class="intro">أشهر مكتبة JavaScript لبناء واجهات المستخدم.</p>
      
      <h3>المفاهيم الأساسية</h3>
      <ul>
        <li><strong>المكونات:</strong> وحدات قابلة لإعادة الاستخدام</li>
        <li><strong>الحالة:</strong> البيانات الديناميكية</li>
        <li><strong>الخصائص:</strong> البيانات الثابتة</li>
      </ul>

      <h3>Hooks</h3>
      <ul>
        <li>useState، useEffect</li>
        <li>useContext، useReducer</li>
      </ul>
    </article>
  </main>
  <Footer />
</body>
</html>

<style>
  :root { --bg: #f8fafc; --card: #fff; --text: #0f172a; --text-sec: #64748b; --primary: #0284c7; --border: rgba(2,132,199,0.2); }
  html.dark-mode { --bg: #0b1120; --card: #1e293b; --text: #f1f5f9; --text-sec: #94a3b8; --primary: #38bdf8; --border: rgba(56,189,248,0.2); }
  body { background: var(--bg); color: var(--text); font-family: system-ui, sans-serif; margin: 0; }
  .category-articles { max-width: 900px; margin: 0 auto; padding: 4rem 1.5rem 6rem; }
  .page-header { text-align: center; margin-bottom: 3rem; padding-bottom: 2rem; border-bottom: 2px solid var(--border); }
  .page-header h1 { color: var(--primary); font-size: 2.2rem; margin-bottom: 0.5rem; }
  .page-header p { color: var(--text-sec); font-size: 1.1rem; }
  .toc-btn { position: fixed; bottom: 30px; left: 30px; width: 55px; height: 55px; background: linear-gradient(135deg, var(--primary), #00d4ff); border: none; border-radius: 50%; color: white; font-size: 1.6rem; cursor: pointer; box-shadow: 0 0 20px rgba(2,132,199,0.6); z-index: 998; transition: all 0.3s; }
  .toc-btn:hover { transform: scale(1.1); box-shadow: 0 0 30px rgba(2,132,199,0.8); }
  .toc-modal { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 999; align-items: center; justify-content: center; }
  .toc-modal.active { display: flex; }
  .toc-box { background: var(--card); width: 90%; max-width: 500px; border-radius: 16px; padding: 2rem; border: 2px solid var(--border); }
  .toc-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 2px solid var(--border); }
  .toc-head h3 { color: var(--primary); margin: 0; }
  .toc-close { background: none; border: none; color: var(--text-sec); font-size: 1.8rem; cursor: pointer; }
  .toc-close:hover { color: #ef4444; }
  .toc-nav { display: flex; flex-direction: column; gap: 0.6rem; max-height: 60vh; overflow-y: auto; }
  .toc-nav a { display: block; background: var(--bg); color: var(--text); text-decoration: none; padding: 1rem 1.2rem; margin-bottom: 0.6rem; border-radius: 8px; border-right: 4px solid transparent; transition: all 0.3s; font-size: 0.95rem; }
  .toc-nav a:hover { background: rgba(2,132,199,0.1); border-right-color: var(--primary); color: var(--primary); transform: translateX(-5px); }
  .article { background: var(--card); border: 2px solid var(--border); border-radius: 16px; padding: 2.5rem 2rem; margin-bottom: 3rem; }
  .badge { display: inline-block; background: var(--primary); color: white; padding: 0.4rem 1.2rem; border-radius: 50px; font-size: 0.85rem; margin-bottom: 1rem; }
  .article h2 { color: var(--text); font-size: 1.6rem; margin-bottom: 0.5rem; }
  .meta { color: var(--text-sec); font-size: 0.9rem; margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1px dashed var(--border); }
  .intro { font-size: 1.1rem; color: var(--text-sec); margin-bottom: 2rem; padding: 1.5rem; background: rgba(2,132,199,0.05); border-right: 4px solid var(--primary); border-radius: 8px; line-height: 1.8; }
  .article h3 { color: var(--primary); margin: 2rem 0 1rem; font-size: 1.3rem; }
  .article ul { padding-right: 1.5rem; margin-bottom: 1rem; }
  .article li { margin-bottom: 0.7rem; line-height: 1.7; color: var(--text-sec); }
  .article li strong { color: var(--primary); }
  @media (max-width: 768px) { .category-articles { padding: 3rem 1rem 4rem; } .article { padding: 2rem 1.5rem; } .toc-btn { width: 50px; height: 50px; bottom: 20px; left: 20px; } }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('tocBtn');
    const modal = document.getElementById('tocModal');
    const close = document.getElementById('tocClose');
    const nav = document.getElementById('tocNav');
    document.querySelectorAll('.article h2').forEach(h2 => {
      const art = h2.closest('.article');
      const link = document.createElement('a');
      link.href = '#' + art.id;
      link.textContent = h2.textContent;
      link.onclick = (e) => { e.preventDefault(); art.scrollIntoView({behavior:'smooth'}); modal.classList.remove('active'); };
      nav.appendChild(link);
    });
    btn.onclick = () => modal.classList.add('active');
    close.onclick = () => modal.classList.remove('active');
    modal.onclick = (e) => { if(e.target === modal) modal.classList.remove('active'); };
  });
</script>
