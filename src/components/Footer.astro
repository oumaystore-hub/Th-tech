        <div class="social-links">
          <a href="#">𝕏</a>
          <a href="#">GH</a>
          <a href="#">in</a>
        </div>
      </div>

      <!-- روابط -->
      <div class="footer-col">
        <h4>روابط سريعة</h4>
        <ul>
          <li><a href="/Th-tech/">الرئيسية</a></li>
          <li><a href="/Th-tech/articles/">المقالات</a></li>
          <li><a href="/Th-tech/category/">التصنيفات</a></li>
        </ul>
      </div>

      <!-- تصنيفات -->
      <div class="footer-col">
        <h4>التصنيفات</h4>
        <ul>
          <li><a href="/Th-tech/ai/">ذكاء اصطناعي</a></li>
          <li><a href="/Th-tech/programming/">برمجة</a></li>
          <li><a href="/Th-tech/security/">أمن سيبراني</a></li>
        </ul>
      </div>

      <!-- تواصل -->
      <div class="footer-col">
        <h4>تواصل معنا</h4>
        <ul class="contact-list">
          <li>📧 info@thtech.com</li>
