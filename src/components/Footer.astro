<footer class="footer">
  <div class="footer-inner">
    <div class="footer-grid">
      <!-- القسم 1: الشعار والوصف -->
      <div class="footer-brand">
        <img src="/Th-tech/logo1.png" alt="Th-Tech" class="footer-logo" />
        <p>منصة متخصصة في الذكاء الاصطناعي والتكنولوجيا الحديثة. نُقدّم محتوى تقني موثوق وشروحات عملية.</p>
        <div class="social-links">
          <a href="#" aria-label="Twitter">𝕏</a>
          <a href="#" aria-label="GitHub">GH</a>
          <a href="#" aria-label="LinkedIn">in</a>
        </div>
      </div>
      
      <!-- القسم 2: روابط سريعة -->
      <div class="footer-col">
        <h4>روابط سريعة</h4>
        <ul>
          <li><a href="/Th-tech/">الرئيسية</a></li>
          <li><a href="/Th-tech/articles/">المقالات</a></li>
          <li><a href="/Th-tech/category/">التصنيفات</a></li>
          <li><a href="/Th-tech/contact/">اتصل بنا</a></li>
        </ul>
      </div>
      
      <!-- القسم 3: تواصل معنا -->
      <div class="footer-col">
        <h4>تواصل معنا</h4>
        <ul class="contact-list">
          <li>📧 info@thtech.com</li>
          <li> الرياض، السعودية</li>
          <li>🌐 www.thtech.com</li>
        </ul>
      </div>
    </div>
    
    <div class="footer-bottom">
      <p>&copy; 2026 Th-Tech. جميع الحقوق محفوظة.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #020617;
    border-top: 2px solid rgba(56, 189, 248, 0.2);
    padding: 3rem 0 1.5rem;
    margin-top: 4rem;
    color: #cbd5e1;
  }
  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: 2.5rem;
    margin-bottom: 2rem;
  }
  .footer-brand {
    text-align: right;
  }
  .footer-logo {
    height: 50px;
    width: auto;
    margin-bottom: 1rem;
    filter: drop-shadow(0 0 8px rgba(56, 189, 248, 0.4));
  }
  .footer-brand p {
    font-size: 0.95rem;
    line-height: 1.6;
    color: #94a3b8;
    margin-bottom: 1.2rem;
  }
  .social-links {
    display: flex;
    gap: 0.8rem;
  }
  .social-links a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: rgba(56, 189, 248, 0.1);
    border: 1px solid rgba(56, 189, 248, 0.2);
    border-radius: 8px;
    color: #38bdf8;
    text-decoration: none;
    font-weight: 700;
    transition: all 0.3s;
  }
  .social-links a:hover {
    background: #38bdf8;
    color: #020617;
    transform: translateY(-2px);
  }
  .footer-col h4 {
    color: #38bdf8;
    font-size: 1.1rem;
    margin-bottom: 1rem;
    font-weight: 700;
  }
  .footer-col ul {
    list-style: none;
    padding: 0;
  }
  .footer-col ul li {
    margin-bottom: 0.6rem;
  }
  .footer-col ul li a, .contact-list li {
    color: #94a3b8;
    text-decoration: none;
    font-size: 0.95rem;
    transition: 0.3s;
  }
  .footer-col ul li a:hover {
    color: #38bdf8;
    padding-right: 4px;
  }
  .footer-bottom {
    text-align: center;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    font-size: 0.85rem;
    color: #64748b;
  }
  @media (max-width: 768px) {
    .footer-grid { grid-template-columns: 1fr; gap: 2rem; text-align: center; }
    .footer-brand { text-align: center; }
    .social-links { justify-content: center; }
    .footer { padding: 2.5rem 0 1rem; }
  }
</style>
