<footer class="footer">
  <div class="container">
    <div class="footer-content">
      <div class="footer-brand">
        <img src="/logo1.png" alt="Th-Tech Logo" class="footer-logo" />
        <p>منصة متخصصة في الذكاء الاصطناعي والتكنولوجيا الحديثة.</p>
        <div class="social-links">
          <a href="#">𝕏</a>
          <a href="#">GH</a>
          <a href="#">in</a>
        </div>
      </div>
      
      <div class="footer-section">
        <h4>روابط سريعة</h4>
        <ul>
          <li><a href="/Th-tech/">الرئيسية</a></li>
          <li><a href="/Th-tech/articles/">المقالات</a></li>
          <li><a href="/Th-tech/category/">التصنيفات</a></li>
        </ul>
      </div>
      
      <div class="footer-section">
        <h4>تواصل معنا</h4>
        <ul class="contact-info">
          <li>📧 info@thtech.com</li>
          <li>📍 السعودية</li>
        </ul>
      </div>
    </div>
    
    <div class="footer-bottom">
      <p>&copy; 2026 Th-Tech. جميع الحقوق محفوظة.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #020617;
    border-top: 2px solid rgba(2,132,199,0.3);
    padding: 2.5rem 0 1.5rem;
    margin-top: 4rem;
    color: #cbd5e1;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .footer-content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .footer-brand {
    text-align: center;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    margin-bottom: 1.5rem;
  }

  .footer-logo {
    height: 60px;
    width: auto;
    margin-bottom: 1rem;
    filter: drop-shadow(0 0 10px rgba(56,189,248,0.4));
  }

  .footer-brand p {
    max-width: 600px;
    margin: 0 auto 1.5rem;
    line-height: 1.6;
    font-size: 0.95rem;
    color: #94a3b8;
  }

  .social-links {
    display: flex;
    gap: 0.8rem;
    justify-content: center;
  }

  .social-links a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: rgba(56,189,248,0.1);
    border: 2px solid rgba(56,189,248,0.3);
    border-radius: 10px;
    color: #38bdf8;
    text-decoration: none;
    font-weight: bold;
    transition: all 0.3s;
  }

  .social-links a:hover {
    background: #38bdf8;
    color: #020617;
    transform: translateY(-3px);
  }

  .footer-section h4 {
    color: #38bdf8;
    margin-bottom: 1rem;
    font-size: 1.1rem;
    font-weight: 700;
  }

  .footer-section ul {
    list-style: none;
    padding: 0;
  }

  .footer-section ul li {
    margin-bottom: 0.6rem;
  }

  .footer-section ul li a {
    color: #94a3b8;
    text-decoration: none;
    transition: all 0.3s;
  }

  .footer-section ul li a:hover {
    color: #38bdf8;
    padding-right: 5px;
  }

  .contact-info li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.6rem;
    color: #94a3b8;
    font-size: 0.95rem;
  }

  .footer-bottom {
    text-align: center;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  .footer-bottom p {
    color: #64748b;
    font-size: 0.9rem;
  }

  @media (max-width: 768px) {
    .footer-content { grid-template-columns: 1fr; gap: 1.5rem; }
    .container { padding: 0 1.5rem; }
    .footer { padding: 2rem 0 1rem; margin-top: 3rem; }
    .footer-logo { height: 50px; }
  }
</style>
