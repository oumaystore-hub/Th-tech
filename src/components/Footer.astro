<style>
  .site-footer {
    background: #020617;
    border-top: 3px solid var(--primary);
    color: #cbd5e1;
    padding: 4rem 0 2rem;
    margin-top: 5rem;
    font-family: system-ui, sans-serif;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.2fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .brand-col {
    text-align: right;
  }

  .footer-logo-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    text-decoration: none;
  }

  .footer-logo {
    height: 60px;
    width: auto;
    filter: drop-shadow(0 0 10px rgba(56, 189, 248, 0.3));
    transition: transform 0.3s;
  }
  
  .footer-logo:hover {
    transform: scale(1.05);
  }

  .footer-desc {
    font-size: 0.95rem;
    line-height: 1.8;
    color: #94a3b8;
    margin-bottom: 1.5rem;
    max-width: 300px;
  }

  /* أيقونات التواصل الاجتماعي SVG */
  .social-icons {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    color: #38bdf8;
    text-decoration: none;
    transition: all 0.3s;
  }

  .social-btn svg {
    width: 20px;
    height: 20px;
    fill: currentColor;
  }

  .social-btn:hover {
    background: var(--primary);
    color: white;
    transform: translateY(-3px);
    border-color: var(--primary);
    box-shadow: 0 4px 12px rgba(2, 132, 199, 0.3);
  }

  /* العناوين والقوائم */
  .footer-title {
    color: #f8fafc;
    font-size: 1.15rem;
    margin-bottom: 1.5rem;
    font-weight: 700;
    position: relative;
    display: inline-block;
  }
  
  .footer-title::after {
    content: '';
    position: absolute;
    bottom: -8px;
    right: 0;
    width: 40px;
    height: 2px;
    background: var(--primary);
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links li {
    margin-bottom: 0.8rem;
  }

  .footer-links a {
    color: #94a3b8;
    text-decoration: none;
    transition: all 0.3s;
    font-size: 0.95rem;
    display: inline-block;
  }

  .footer-links a:hover {
    color: var(--primary);
    padding-right: 5px;
  }

  /* قائمة التواصل */
  .contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .contact-list li {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 1rem;
    font-size: 0.95rem;
    color: #94a3b8;
  }

  .contact-list .icon {
    font-size: 1.2rem;
  }
  
  .contact-list a {
    color: #94a3b8;
    text-decoration: none;
    transition: 0.3s;
  }
  
  .contact-list a:hover {
    color: var(--primary);
  }

  /* شريط الحقوق السفلي */
  .footer-bottom {
    text-align: center;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-bottom p {
    margin: 0;
    font-size: 0.9rem;
    color: #64748b;
  }
  
  .footer-bottom strong {
    color: #cbd5e1;
  }

  .made-with {
    font-size: 0.85rem !important;
    opacity: 0.7;
  }

  /* التجاوب مع الهاتف */
  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      text-align: center;
    }

    .brand-col {
      text-align: center;
    }

    .social-icons {
      justify-content: center;
    }
    
    .footer-title::after {
      right: 50%;
      transform: translateX(50%);
    }

    .contact-list li {
      justify-content: center;
    }
    
    .site-footer {
      padding: 3rem 0 1.5rem;
    }
  }
</style>
