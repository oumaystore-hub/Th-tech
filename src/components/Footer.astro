---
import Logo from './Logo.astro';
---

<footer class="footer">
  <div class="container">
    <div class="content">
      <div class="brand">
        <a href="/" class="footer-logo-link">
          <Logo width="100" height="85" />
        </a>
        <p>منصة عربية متخصصة في التقنية والذكاء الاصطناعي.</p>
      </div>

      <div class="links">
        <h4>روابط سريعة</h4>
        <a href="/">الرئيسية</a>
        <a href="/articles/all">المقالات</a>
        <a href="#">سياسة الخصوصية</a>
      </div>

      <div class="social-section">
        <h4>تابعنا</h4>
        <div class="socials">
          <a href="#" aria-label="Twitter" class="social-icon">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="#" aria-label="GitHub" class="social-icon">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>
          <a href="#" aria-label="LinkedIn" class="social-icon">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <div class="copyright">
      &copy; {new Date().getFullYear()} Th-Tech. جميع الحقوق محفوظة.
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--surface);
    border-top: 1px solid var(--border);
    padding: 4rem 0 2rem; margin-top: 4rem;
  }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }

  .content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 3rem; margin-bottom: 3rem;
  }

  .brand { display: flex; flex-direction: column; gap: 1rem; }
  .footer-logo-link { display: inline-flex; transition: transform 0.3s; }
  .footer-logo-link:hover { transform: scale(1.05); }
  .brand p { color: var(--muted); font-size: 0.9rem; line-height: 1.6; }

  .links h4, .social-section h4 {
    color: var(--text); margin-bottom: 1rem; font-size: 1rem;
  }
  .links { display: flex; flex-direction: column; gap: 0.8rem; }
  .links a { color: var(--muted); transition: 0.2s; font-size: 0.9rem; }
  .links a:hover { color: var(--primary); padding-right: 5px; }

  .socials { display: flex; gap: 1rem; }
  .social-icon {
    color: var(--muted); transition: all 0.3s;
    display: flex; align-items: center; justify-content: center;
    width: 40px; height: 40px; border-radius: 50%;
    background: var(--bg); border: 1px solid var(--border);
  }
  .social-icon svg { width: 20px; height: 20px; }
  .social-icon:hover {
    color: white; background: var(--primary);
    border-color: var(--primary); transform: translateY(-3px);
  }

  .copyright {
    text-align: center; color: var(--muted);
    font-size: 0.8rem; border-top: 1px solid var(--border); padding-top: 2rem;
  }
</style>
