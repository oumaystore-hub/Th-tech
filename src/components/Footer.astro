<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <!-- القسم 1: الشعار والوصف -->
      <div class="footer-brand">
        <img src="/logo1.png" alt="Th-Tech Logo" class="footer-logo" />
        <p>منصة متخصصة في الذكاء الاصطناعي والتكنولوجيا الحديثة.</p>
        <div class="social-links">
          <a href="#" aria-label="Twitter">𝕏</a>
          <a href="#" aria-label="GitHub">GH</a>
          <a href="#" aria-label="LinkedIn">in</a>
        </div>
      </div>
      
      <!-- القسم 2: روابط سريعة -->
      <div class="footer-section">
        <h4>روابط سريعة</h4>
        <ul>
          <li><a href="/Th-tech/">الرئيسية</a></li>
          <li><a href="/Th-tech/articles/">المقالات</a></li>
          <li><a href="/Th-tech/category/">التصنيفات</a></li>
          <li><a href="/Th-tech/contact/">اتصل بنا</a></li>
        </ul>
      </div>
      
      <!-- القسم 3: تواصل معنا -->
      <div class="footer-section">
        <h4>تواصل معنا</h4>
        <ul class="contact-info">
          <li>📧 info@thtech.com</li>
          <li>📍 السعودية</li>
        </ul>
      </div>
    </div>
    
    <!-- حقوق النشر -->
    <div class="footer-bottom">
      <p>&copy; 2026 Th-Tech. جميع الحقوق محفوظة.</p>
    </div>
  </div>
</footer>

<style>
  /* تنسيق الفوتر المضغوط */
  .footer {
    background: #020617;
    border-top: 2px solid rgba(56, 189, 248, 0.3);
    padding: 3rem 0 1.5rem; /* تقليل المساحة العمودية */
    margin-top: 4rem;
    color: #cbd5e1;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
    margin-bottom: 2rem;
  }

  /* تنسيق الشعار في الفوتر */
  .footer-brand {
    text-align: center; /* توسيط الشعار في العمود */
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-logo {
    height: 60px; /* حجم مناسب للشعار */
    width: auto;
    margin-bottom: 1rem;
    filter: drop-shadow(0 0 10px rgba(56, 189, 248, 0.4));
  }

  .footer-brand p {
    color: #94a3b8;
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .social-links {
    display: flex;
    justify-content: center;
    gap: 0.8rem;
  }

  .social-links a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 35px;
    height: 35px;
    background: rgba(56, 189, 248, 0.1);
    border: 1px solid rgba(56, 189, 248, 0.3);
    border-radius: 8px;
    color: #38bdf8;
    text-decoration: none;
    font-weight: bold;
    transition: all 0.3s;
  }

  .social-links a:hover {
    background: #38bdf8;
    color: #020617;
    transform: translateY(-2px);
  }

  .footer-section h4 {
    color: #38bdf8;
    margin-bottom: 1rem;
    font-size: 1.1rem;
    font-weight: 700;
  }

  .footer-section ul {
    list-style: none;
    padding: 0;
  }

  .footer-section ul li {
    margin-bottom: 0.5rem;
  }

  .footer-section ul li a {
    color: #94a3b8;
    text-decoration: none;
    transition: 0.3s;
    font-size: 0.95rem;
  }

  .footer-section ul li a:hover {
    color: #38bdf8;
    padding-right: 5px;
  }

  .contact-info li {
    color: #94a3b8;
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
  }

  .footer-bottom {
    text-align: center;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    font-size: 0.9rem;
    color: #64748b;
  }

  /* التجاوب مع الهاتف */
  @media (max-width: 768px) {
    .footer { padding: 2rem 0 1rem; }
    .footer-brand { padding-bottom: 1rem; margin-bottom: 1rem; border-bottom: none; }
    .footer-logo { height: 50px; }
  }
</style>
