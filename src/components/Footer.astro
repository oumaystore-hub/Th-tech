<style>
  .site-footer {
    background: var(--card);
    border-top: 1px solid var(--border);
    padding: 1.5rem 0 1rem;
    color: var(--text-sec);
    font-family: system-ui, sans-serif;
    font-size: 0.85rem;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* العلوي: شعار وأيقونات */
  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .footer-logo {
    height: 30px;
    width: auto;
  }

  .social-icons {
    display: flex;
    gap: 0.5rem;
  }

  .social-btn {
    width: 28px;
    height: 28px;
    background: var(--bg);
    color: var(--primary);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    font-size: 0.7rem;
    font-weight: bold;
    transition: 0.3s;
  }

  .social-btn:hover {
    background: var(--primary);
    color: white;
  }

  /* الأوسط: قسمين متجاورين (مثل الكتاب) */
  .footer-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 1rem 0;
    margin-bottom: 1rem;
  }

  .split-col {
    text-align: center; /* توسيط النص */
  }

  .split-col h4 {
    color: var(--text);
    margin-bottom: 0.8rem;
    font-size: 0.95rem;
  }

  .split-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .split-col a {
    color: var(--text-sec);
    text-decoration: none;
    transition: 0.3s;
  }

  .split-col a:hover {
    color: var(--primary);
  }

  /* السفلي: تواصل صغير */
  .footer-bottom {
    text-align: center;
  }

  .contact-mini {
    margin-bottom: 0.5rem;
    font-size: 0.8rem;
    color: var(--text-sec);
  }

  .dot {
    margin: 0 0.5rem;
    color: var(--primary);
  }

  .footer-bottom p {
    margin: 0;
    font-size: 0.75rem;
    opacity: 0.7;
  }

  /* للهاتف */
  @media (max-width: 768px) {
    .footer-split {
      grid-template-columns: 1fr; /* عمود واحد في الهاتف */
      gap: 1.5rem;
      text-align: center;
    }
    .footer-top {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>
