<style>
  .site-footer {
    background: var(--card);
    border-top: 1px solid var(--border);
    padding: 1.2rem 0 0.8rem;
    color: var(--text-sec);
    font-family: system-ui, sans-serif;
    font-size: 0.85rem;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* العلوي */
  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.2rem;
  }

  .footer-logo {
    height: 30px;
    width: auto;
  }

  .social-icons {
    display: flex;
    gap: 0.5rem;
  }

  .social-btn {
    width: 28px;
    height: 28px;
    background: var(--bg);
    color: var(--primary);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    font-size: 0.7rem;
    font-weight: bold;
    transition: all 0.3s;
  }

  .social-btn:hover {
    background: var(--primary);
    color: #ffffff;
    transform: translateY(-2px);
  }

  /* الصف الأفقي المطلوب */
  .footer-row {
    display: grid;
    grid-template-columns: 1fr 1fr; /* عمودين متساويين أفقيًا */
    gap: 2rem;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 1rem 0;
    margin-bottom: 1rem;
  }

  .footer-col {
    text-align: right; /* محاذاة لليمين */
  }

  .footer-col h4 {
    color: var(--text);
    margin: 0 0 0.8rem;
    font-size: 0.95rem;
    font-weight: 700;
  }

  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .footer-col a {
    color: var(--text-sec);
    text-decoration: none;
    transition: 0.3s;
    font-size: 0.85rem;
  }

  .footer-col a:hover {
    color: var(--primary);
  }

  /* السفلي */
  .footer-bottom {
    text-align: center;
    font-size: 0.8rem;
  }

  .contact-line {
    display: block;
    margin-bottom: 0.4rem;
    color: var(--text-sec);
  }

  .footer-bottom p {
    margin: 0;
    opacity: 0.7;
    font-size: 0.75rem;
  }

  /* للهاتف: يتحول لعمود واحد للحفاظ على القراءة */
  @media (max-width: 600px) {
    .footer-row {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      text-align: center;
    }
    .footer-col { text-align: center; }
    .footer-top {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>
