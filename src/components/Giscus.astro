<div id="giscus-container" class="giscus-wrapper"></div>

<script is:inline>
  // ⚠️ استبدل القيم أدناه بعد تفعيل Giscus على مستودعك
  const config = {
    src: "https://giscus.app/client.js",
    "data-repo": "oumaystore-hub/Th-tech",
    "data-repo-id": "R_kgDOxxxxxxxxxx", // ← استبدل بـ Repo ID
    "data-category": "General",
    "data-category-id": "DIC_kwDOxxxxxxxxxx", // ← استبدل بـ Category ID
    "data-mapping": "pathname",
    "data-strict": "0",
    "data-reactions-enabled": "1",
    "data-emit-metadata": "0",
    "data-input-position": "bottom",
    "data-theme": "preferred_color_scheme",
    "data-lang": "ar",
    crossorigin: "anonymous",
    async: true
  };

  const script = document.createElement('script');
  Object.entries(config).forEach(([key, value]) => {
    script.setAttribute(key, value);
  });
  document.getElementById('giscus-container').appendChild(script);
</script>

<style>
  .giscus-wrapper {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
</style>
