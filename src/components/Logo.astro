---
// يمكنك تعديل هذا لوضع صورتك الخاصة
const { size = 'medium' } = Astro.props;
---
<a href="/" class={`logo logo-${size}`}>
  <!-- إذا كان لديك صورة شعار، استبدل السطر التالي بـ: -->
  <!-- <img src="/your-logo.png" alt="Th.Tech" /> -->
  <span class="logo-text">Th<span class="dot">.</span><span class="tech">Tech</span></span>
</a>

<style>
  .logo {
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    font-weight: 900;
    transition: transform 0.3s ease;
  }
  .logo:hover {
    transform: scale(1.05);
  }
  .logo-text {
    font-size: 1.8rem;
    background: linear-gradient(135deg, #667eea 0%, #3b82f6 50%, #8b5cf6 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .dot {
    color: #f59e0b;
    -webkit-text-fill-color: #f59e0b;
  }
  .tech {
    background: linear-gradient(135deg, #8b5cf6, #ec4899);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .logo-small .logo-text { font-size: 1.4rem; }
  .logo-medium .logo-text { font-size: 1.8rem; }
  .logo-large .logo-text { font-size: 2.2rem; }
</style>
