---
const { size = 'medium' } = Astro.props;
---
<a href="/" class={`logo logo-${size}`}>
  <span class="logo-text">Th.Tech</span>
</a>

<style>
  .logo { text-decoration: none; display: inline-flex; align-items: center; }
  .logo-text { 
    font-weight: 900; 
    color: #fff; 
    letter-spacing: -1px;
    font-size: 1.5rem;
  }
  .logo-small .logo-text { font-size: 1.2rem; }
  .logo-medium .logo-text { font-size: 1.5rem; }
  .logo-large .logo-text { font-size: 1.8rem; }
</style>
