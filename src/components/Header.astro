---
---
<header class="site-header">
  <div class="container">
    <!-- الشعار: تم تعديل الكود لضمان عدم ظهور الخلفية البيضاء -->
    <a href="/Th-tech/" class="logo-link">
      <img src="/Th-tech/logo.png" alt="Th-tech" class="logo-img">
    </a>

    <nav class="desktop-nav">
      <a href="/Th-tech/" class="nav-item">الرئيسية</a>
      <a href="/Th-tech/articles/" class="nav-item">المقالات</a>
      <a href="/Th-tech/contact/" class="nav-item">اتصل بنا</a>
    </nav>

    <div class="header-tools">
      <button id="search-btn" class="icon-btn"></button>
      <button id="theme-btn" class="icon-btn"></button>
      <button id="menu-btn" class="icon-btn hamburger-btn">☰</button>
    </div>
  </div>

  <div id="search-panel" class="search-panel">
    <div class="search-box">
      <input type="text" placeholder="ابحث عن مقال..." class="search-input">
      <button onclick="document.getElementById('search-panel').classList.remove('active')" class="close-search">✕</button>
    </div>
  </div>

  <nav id="mobile-menu" class="mobile-menu">
    <a href="/Th-tech/" class="mobile-link">🏠 الرئيسية</a>
    <a href="/Th-tech/articles/" class="mobile-link">📚 المقالات</a>
    <a href="/Th-tech/category/" class="mobile-link highlight">📂 التصنيفات</a>
    <a href="/Th-tech/contact/" class="mobile-link">📧 اتصل بنا</a>
  </nav>
</header>

<style>
  :root {
    --bg-dark: #020617;
    --bg-card: #0f172a;
    --text-main: #f1f5f9;
    --primary: #00d4ff;
    --border: rgba(0, 212, 255, 0.25);
  }

  body { margin: 0; font-family: 'Segoe UI', system-ui, sans-serif; background: var(--bg-dark); color: var(--text-main); }
  
  .site-header {    background: #020617; /* لون ثابت بدلاً من الشفافية لحل مشكلة الشعار */
    border-bottom: 1px solid var(--border);
    position: sticky; top: 0; z-index: 1000; padding: 0.5rem 0;
  }

  .container { max-width: 1200px; margin: 0 auto; padding: 0 1rem; display: flex; justify-content: space-between; align-items: center; height: 70px; }

  /* إصلاح الشعار - الحل الجذري */
  .logo-link {
    display: flex;
    align-items: center;
    background: transparent;
    padding: 0;
    border-radius: 0;
  }
  
  .logo-img {
    height: 50px;
    width: auto;
    display: block;
    background: transparent;
    /* استخدام فلتر لإزالة أي ألوان فاتحة جداً (أبيض/رمادي) وجعلها شفافة */
    filter: brightness(1.1) contrast(1.2) drop-shadow(0 0 10px rgba(0, 212, 255, 0.6));
  }

  .desktop-nav { display: flex; gap: 2rem; }
  .nav-item { color: var(--text-main); text-decoration: none; font-weight: 600; font-size: 1rem; transition: 0.3s; }
  .nav-item:hover { color: var(--primary); }

  .header-tools { display: flex; gap: 0.6rem; align-items: center; }
  .icon-btn {
    background: transparent; border: 1px solid var(--border); color: var(--primary);
    width: 42px; height: 42px; border-radius: 10px; cursor: pointer;
    font-size: 1.2rem; display: flex; align-items: center; justify-content: center; transition: 0.3s;
  }
  .icon-btn:hover { background: var(--border); transform: translateY(-2px); }
  .hamburger-btn { display: none; }

  .search-panel { display: none; background: var(--bg-card); padding: 1rem; border-top: 1px solid var(--border); }
  .search-panel.active { display: block; animation: slide 0.3s; }
  .search-box { max-width: 600px; margin: 0 auto; display: flex; gap: 0.5rem; }
  .search-input { flex: 1; padding: 0.8rem; border: 1px solid var(--primary); border-radius: 8px; background: var(--bg-dark); color: var(--text-main); }
  .close-search { background: #ef4444; color: white; border: none; padding: 0 1.2rem; border-radius: 8px; cursor: pointer; }

  .mobile-menu {
    display: none; flex-direction: column; background: var(--bg-card); border-top: 1px solid var(--border);
    padding: 1rem; position: absolute; top: 70px; left: 0; right: 0; width: 100%; box-shadow: 0 10px 30px rgba(0,0,0,0.5);
  }
  .mobile-menu.active { display: flex; }
  .mobile-link { color: var(--text-main); text-decoration: none; padding: 1rem 0; border-bottom: 1px solid var(--border); font-weight: 600; }  .mobile-link.highlight { color: var(--primary); font-weight: 800; }

  @media (max-width: 768px) {
    .desktop-nav { display: none; }
    .hamburger-btn { display: flex; }
    .logo-img { height: 40px; }
  }
  @keyframes slide { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
</style>

<script is:inline>
  const html = document.documentElement;
  const themeBtn = document.getElementById('theme-btn');
  const saved = localStorage.getItem('theme') || 'dark';
  html.setAttribute('data-theme', saved);
  themeBtn.textContent = saved === 'light' ? '☀️' : '🌙';

  themeBtn.addEventListener('click', () => {
    const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    themeBtn.textContent = next === 'light' ? '☀️' : '🌙';
  });

  document.getElementById('menu-btn').addEventListener('click', () => document.getElementById('mobile-menu').classList.toggle('active'));
  document.getElementById('search-btn').addEventListener('click', () => document.getElementById('search-panel').classList.add('active'));
</script>
