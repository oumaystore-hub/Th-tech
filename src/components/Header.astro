---
<header style="background:#020617; border-bottom:2px solid #00d4ff; padding:1rem;">
  <div style="max-width:1200px; margin:0 auto; display:flex; justify-content:space-between; align-items:center;">
    <a href="/Th-tech/" style="text-decoration:none;">
      <img src="/logo1.png" alt="Th-tech" style="height:50px;">
    </a>
    <nav style="display:flex; gap:2rem;">
      <a href="/Th-tech/" style="color:#fff; text-decoration:none;">الرئيسية</a>
      <a href="/Th-tech/articles/" style="color:#fff; text-decoration:none;">المقالات</a>
      <a href="/Th-tech/contact/" style="color:#fff; text-decoration:none;">اتصل بنا</a>
    </nav>
    <div style="display:flex; gap:0.5rem;">
      <button id="theme-btn" style="background:#00d4ff; border:none; padding:0.5rem 1rem; border-radius:5px; cursor:pointer;">🌙</button>
    </div>
  </div>
</header>
<script>
  const btn = document.getElementById('theme-btn');
  btn.addEventListener('click', () => {
    document.body.style.filter = document.body.style.filter === 'invert(1)' ? '' : 'invert(1)';
  });
</script>
