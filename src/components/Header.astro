---
---
<header class="site-header">
  <div class="container">
    <!-- الشعار -->
    <a href="/Th-tech/" class="logo-link">
      <img src="/Th-tech/logo.png" alt="Th-tech Logo" class="logo-img">
    </a>

    <!-- قائمة الحاسوب -->
    <nav class="desktop-nav">
      <a href="/Th-tech/" class="nav-item">الرئيسية</a>
      <a href="/Th-tech/articles/" class="nav-item">المقالات</a>
      <a href="/Th-tech/contact/" class="nav-item">اتصل بنا</a>
    </nav>

    <!-- أدوات التحكم -->
    <div class="header-tools">
      <button id="search-btn" class="icon-btn" aria-label="بحث">🔍</button>
      <button id="theme-btn" class="icon-btn" aria-label="تبديل الوضع"></button>
      <button id="menu-btn" class="icon-btn hamburger-btn" aria-label="القائمة">☰</button>
    </div>
  </div>

  <!-- شريط البحث المنزلق -->
  <div id="search-panel" class="search-panel">
    <div class="search-box">
      <input type="text" placeholder="ابحث عن مقال..." class="search-input">
      <button onclick="document.getElementById('search-panel').classList.remove('active')" class="close-search">✕</button>
    </div>
  </div>

  <!-- قائمة الهاتف -->
  <nav id="mobile-menu" class="mobile-menu">
    <a href="/Th-tech/" class="mobile-link">🏠 الرئيسية</a>
    <a href="/Th-tech/articles/" class="mobile-link">📚 المقالات</a>
    <a href="/Th-tech/category/" class="mobile-link highlight">📂 التصنيفات</a>
    <a href="/Th-tech/contact/" class="mobile-link"> اتصل بنا</a>
  </nav>
</header>

<style>
  :root {
    --bg-dark: #0B1120;       /* أزرق فضائي عميق */
    --bg-light: #F8FAFC;      /* أبيض مائل للرمادي */
    --text-dark: #E2E8F0;     /* أبيض ناعم */
    --text-light: #0F172A;    /* كحلي غامق */
    --primary: #38BDF8;       /* سماوي تقني */
    --border: rgba(56, 189, 248, 0.3);  }

  body { margin: 0; font-family: 'Segoe UI', system-ui, sans-serif; background: var(--bg-dark); color: var(--text-dark); transition: 0.3s; }
  [data-theme="light"] body { background: var(--bg-light); color: var(--text-light); }

  .site-header {
    background: rgba(11, 17, 32, 0.95);
    backdrop-filter: blur(10px);
    border-bottom: 2px solid var(--border);
    position: sticky; top: 0; z-index: 1000; padding: 0.5rem 0;
  }
  [data-theme="light"] .site-header { background: rgba(248, 250, 252, 0.95); border-color: rgba(2, 132, 199, 0.3); }

  .container { max-width: 1200px; margin: 0 auto; padding: 0 1rem; display: flex; justify-content: space-between; align-items: center; height: 60px; }

  /* الشعار - محاولة دمج الخلفية البيضاء */
  .logo-img { height: 50px; width: auto; mix-blend-mode: screen; filter: drop-shadow(0 0 5px rgba(56,189,248,0.5)); }
  [data-theme="light"] .logo-img { mix-blend-mode: normal; filter: none; }

  .desktop-nav { display: flex; gap: 1.5rem; }
  .nav-item { color: var(--text-dark); text-decoration: none; font-weight: 600; font-size: 0.95rem; transition: 0.3s; }
  .nav-item:hover { color: var(--primary); }
  [data-theme="light"] .nav-item { color: var(--text-light); }

  .header-tools { display: flex; gap: 0.5rem; align-items: center; }
  .icon-btn {
    background: transparent; border: 1px solid var(--border); color: var(--primary);
    width: 40px; height: 40px; border-radius: 8px; cursor: pointer;
    font-size: 1.2rem; display: flex; align-items: center; justify-content: center; transition: 0.3s;
  }
  .icon-btn:hover { background: var(--border); transform: scale(1.05); }
  .hamburger-btn { display: none; }

  .search-panel { display: none; background: var(--bg-dark); padding: 1rem; border-top: 1px solid var(--border); animation: slideDown 0.3s ease; }
  .search-panel.active { display: block; }
  .search-box { max-width: 600px; margin: 0 auto; display: flex; gap: 0.5rem; }
  .search-input { flex: 1; padding: 0.8rem; border: 1px solid var(--border); border-radius: 8px; background: #1E293B; color: #fff; }
  .close-search { background: #EF4444; color: white; border: none; padding: 0 1rem; border-radius: 8px; cursor: pointer; }

  .mobile-menu {
    display: none; flex-direction: column; background: #1E293B; border-top: 1px solid var(--border);
    padding: 1rem; position: absolute; top: 60px; left: 0; right: 0; width: 100%; box-shadow: 0 10px 20px rgba(0,0,0,0.5);
  }
  .mobile-menu.active { display: flex; }
  .mobile-link { color: #fff; text-decoration: none; padding: 0.8rem 0; border-bottom: 1px solid var(--border); font-weight: 600; }
  .mobile-link:last-child { border-bottom: none; }
  .mobile-link.highlight { color: var(--primary); }

  @media (max-width: 768px) {
    .desktop-nav { display: none; }    .hamburger-btn { display: flex; }
    .logo-img { height: 40px; }
  }
  @keyframes slideDown { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
</style>

<script is:inline>
  // 1. الوضع الليلي
  const themeBtn = document.getElementById('theme-btn');
  const html = document.documentElement;
  const savedTheme = localStorage.getItem('theme') || 'dark';
  html.setAttribute('data-theme', savedTheme);
  themeBtn.textContent = savedTheme === 'light' ? '☀️' : '🌙';

  themeBtn.addEventListener('click', () => {
    const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    themeBtn.textContent = next === 'light' ? '☀️' : '🌙';
  });

  // 2. القائمة المتنقلة
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  menuBtn.addEventListener('click', () => mobileMenu.classList.toggle('active'));

  // 3. البحث
  document.getElementById('search-btn').addEventListener('click', () => {
    document.getElementById('search-panel').classList.add('active');
  });
</script>
