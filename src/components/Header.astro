---
---
<header class="site-header">
  <div class="container">
    <a href="/Th-tech/" class="logo">
      <img src="/logo1.png" alt="Th-tech" class="logo-img" />
    </a>
    
    <nav class="nav-links">
      <a href="/Th-tech/" class="nav-link">الرئيسية</a>
      <a href="/Th-tech/articles/" class="nav-link">المقالات</a>
      <a href="/Th-tech/category/" class="nav-link">التصنيفات</a>
      <a href="/Th-tech/contact/" class="nav-link">اتصل بنا</a>
    </nav>

    <div class="header-tools">
      <button id="search-btn" class="tool-btn">🔍</button>
      <button id="theme-btn" class="tool-btn">🌙</button>
      <button id="menu-btn" class="tool-btn hamburger">☰</button>
    </div>
  </div>

  <div id="search-panel" class="search-panel">
    <div class="search-container">
      <input type="text" placeholder="ابحث عن مقال..." class="search-input" />
      <button id="close-search" class="close-btn">✕</button>
    </div>
  </div>

  <nav id="mobile-menu" class="mobile-menu">
    <a href="/Th-tech/" class="mobile-link">🏠 الرئيسية</a>
    <a href="/Th-tech/articles/" class="mobile-link">📚 المقالات</a>
    <a href="/Th-tech/category/" class="mobile-link">📂 التصنيفات</a>
    <a href="/Th-tech/contact/" class="mobile-link">📧 اتصل بنا</a>
  </nav>
</header>

<!-- زر قائمة العناوين العائم -->
<div class="toc-float-btn" id="tocBtn" title="قائمة العناوين">📑</div>

<style>
  :root {
    --bg: #f8fafc;
    --card: #ffffff;
    --text: #0f172a;
    --text-sec: #64748b;
    --primary: #0284c7;
    --border: rgba(2,132,199,0.2);
  }

  html.dark-mode {
    --bg: #0b1120;
    --card: #1e293b;
    --text: #f1f5f9;
    --text-sec: #94a3b8;
    --primary: #38bdf8;
    --border: rgba(56,189,248,0.2);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  
  body {
    background-color: var(--bg);
    color: var(--text);
    font-family: system-ui, sans-serif;
    transition: background-color 0.4s, color 0.4s;
  }
  
  .site-header {
    background: var(--card);
    border-bottom: 3px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 1000;
    padding: 0.5rem 0;
  }
  
  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 110px;
  }
  
  .logo {
    flex-shrink: 0;
    margin-left: 15px;
  }
  .logo-img {
    height: 70px;
    width: auto;
    display: block;
    filter: drop-shadow(0 2px 8px rgba(2,132,199,0.3));
  }
  
  .nav-links { display: flex; gap: 2rem; }
  .nav-link {
    color: var(--text);
    text-decoration: none;
    font-weight: 700;
    font-size: 1.1rem;
    transition: color 0.3s;
  }
  .nav-link:hover { color: var(--primary); }
  
  .header-tools { display: flex; gap: 1rem; }
  .tool-btn {
    background: var(--primary);
    border: 2px solid var(--border);
    color: white;
    width: 50px;
    height: 50px;
    border-radius: 12px;
    cursor: pointer;
    font-size: 1.4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s;
  }
  .tool-btn:hover { transform: scale(1.1); }
  .hamburger { display: none; }
  
  .search-panel, .mobile-menu { display: none; }
  .search-panel.active, .mobile-menu.active { display: block; }
  
  .search-panel {
    position: absolute; top: 110px; left: 0; right: 0;
    background: var(--card); padding: 1.5rem;
    border-bottom: 2px solid var(--border); z-index: 999;
  }
  .search-container { max-width: 600px; margin: 0 auto; display: flex; gap: 1rem; }
  .search-input {
    flex: 1; padding: 1rem; border-radius: 10px;
    border: 2px solid var(--border); background: var(--bg); color: var(--text);
  }
  .close-btn { background: #ef4444; color: white; border: none; padding: 0 1.5rem; border-radius: 10px; cursor: pointer; font-weight: bold; }
  
  .mobile-menu {
    position: absolute; top: 110px; left: 0; right: 0;
    background: var(--card); padding: 1.5rem;
    border-bottom: 2px solid var(--border);
    display: none; flex-direction: column; z-index: 999;
  }
  .mobile-menu.active { display: flex; }
  .mobile-link {
    color: var(--text); text-decoration: none; padding: 1.2rem;
    border-bottom: 1px solid var(--border); font-weight: 700; font-size: 1.05rem;
  }
  .mobile-link:last-child { border-bottom: none; }

  /* زر قائمة العناوين العائم المتوهج */
  .toc-float-btn {
    position: fixed;
    bottom: 30px;
    left: 30px;
    width: 65px;
    height: 65px;
    background: linear-gradient(135deg, var(--primary), #00d4ff);
    border: none;
    border-radius: 50%;
    color: white;
    font-size: 1.8rem;
    cursor: pointer;
    box-shadow: 0 0 20px rgba(2,132,199,0.6), 0 0 40px rgba(2,132,199,0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 998;
    transition: all 0.3s;
    animation: pulse-glow 2s ease-in-out infinite;
  }
  
  .toc-float-btn:hover {
    transform: scale(1.15) rotate(10deg);
    box-shadow: 0 0 30px rgba(2,132,199,0.8), 0 0 60px rgba(2,132,199,0.6);
  }
  
  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 0 20px rgba(2,132,199,0.6), 0 0 40px rgba(2,132,199,0.4); }
    50% { box-shadow: 0 0 30px rgba(2,132,199,0.8), 0 0 60px rgba(2,132,199,0.6); }
  }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .hamburger { display: flex; }
    .logo-img { height: 50px; }
    .logo { margin-left: 10px; }
    .container { height: 80px; padding: 0 1.5rem; }
    .tool-btn { width: 45px; height: 45px; font-size: 1.2rem; }
    .search-panel, .mobile-menu { top: 80px; }
    .toc-float-btn {
      width: 55px;
      height: 55px;
      bottom: 20px;
      left: 20px;
      font-size: 1.5rem;
    }
  }
</style>

<script is:inline>
  function toggleTheme() {
    const html = document.documentElement;
    const btn = document.getElementById('theme-btn');
    html.classList.toggle('dark-mode');
    if (html.classList.contains('dark-mode')) {
      localStorage.setItem('theme', 'dark');
      btn.textContent = '☀️';
    } else {
      localStorage.setItem('theme', 'light');
      btn.textContent = '🌙';
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('theme-btn');
    const html = document.documentElement;
    const savedTheme = localStorage.getItem('theme');

    if (savedTheme === 'dark') {
      html.classList.add('dark-mode');
      btn.textContent = '☀️';
    } else {
      html.classList.remove('dark-mode');
      btn.textContent = '🌙';
    }

    if (btn) {
      btn.addEventListener('click', toggleTheme);
    }

    const menuBtn = document.getElementById('menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    if (menuBtn && mobileMenu) {
      menuBtn.addEventListener('click', () => {
        mobileMenu.classList.toggle('active');
        menuBtn.textContent = mobileMenu.classList.contains('active') ? '✕' : '☰';
      });
    }

    const searchBtn = document.getElementById('search-btn');
    const searchPanel = document.getElementById('search-panel');
    const closeSearch = document.getElementById('close-search');
    if (searchBtn && searchPanel) {
      searchBtn.addEventListener('click', () => searchPanel.classList.add('active'));
      if (closeSearch) closeSearch.addEventListener('click', () => searchPanel.classList.remove('active'));
    }

    // زر قائمة العناوين - التمرير السلس للمقالات
    const tocBtn = document.getElementById('tocBtn');
    if (tocBtn) {
      tocBtn.addEventListener('click', () => {
        const articlesSection = document.querySelector('.articles-container') || document.querySelector('main');
        if (articlesSection) {
          articlesSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    }
  });
</script>
