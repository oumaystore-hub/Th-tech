---
---
<header class="site-header">
  <div class="container">
    <a href="/Th-tech/" class="logo">
      <img src="/Th-tech/logo1.png" alt="Th-tech" class="logo-img" />
    </a>
    
    <nav class="nav-links">
      <a href="/Th-tech/" class="nav-link">
        <span class="icon">🏠</span>
        <span>الرئيسية</span>
      </a>
      <a href="/Th-tech/articles/" class="nav-link">
        <span class="icon">📚</span>
        <span>المقالات</span>
      </a>
      <a href="/Th-tech/category/" class="nav-link">
        <span class="icon">📑</span>
        <span>التصنيفات</span>
      </a>
      <a href="/Th-tech/contact/" class="nav-link">
        <span class="icon">✉️</span>
        <span>اتصل بنا</span>
      </a>
    </nav>

    <div class="header-tools">
      <button id="search-btn" class="tool-btn" title="بحث متقدم">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35"></path>
        </svg>
      </button>
      <button id="theme-btn" class="tool-btn" title="الوضع الليلي">
        <svg id="moon-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
        <svg id="sun-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none">
          <circle cx="12" cy="12" r="5"></circle>
          <line x1="12" y1="1" x2="12" y2="3"></line>
          <line x1="12" y1="21" x2="12" y2="23"></line>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
          <line x1="1" y1="12" x2="3" y2="12"></line>
          <line x1="21" y1="12" x2="23" y2="12"></line>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
      </button>
      <button id="menu-btn" class="tool-btn hamburger" title="القائمة">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <!-- لوحة البحث المتقدمة -->
  <div id="search-panel" class="search-panel">
    <div class="search-container">
      <div class="search-icon-wrapper">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35"></path>
        </svg>
      </div>
      <input type="text" id="searchInput" placeholder="ابحث في المقالات، التصنيفات، الكلمات المفتاحية..." class="search-input" />
      <button id="close-search" class="close-btn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <div id="searchResults" class="search-results-box"></div>
    <div id="searchStats" class="search-stats"></div>
  </div>

  <!-- القائمة المتنقلة -->
  <nav id="mobile-menu" class="mobile-menu">
    <a href="/Th-tech/" class="mobile-link">
      <span class="icon">🏠</span>
      <span>الرئيسية</span>
    </a>
    <a href="/Th-tech/articles/" class="mobile-link">
      <span class="icon">📚</span>
      <span>المقالات</span>
    </a>
    <a href="/Th-tech/category/" class="mobile-link">
      <span class="icon">📑</span>
      <span>التصنيفات</span>
    </a>
    <a href="/Th-tech/contact/" class="mobile-link">
      <span class="icon">✉️</span>
      <span>اتصل بنا</span>
    </a>
  </nav>
</header>

<style>
  :root {
    --bg: #f8fafc;
    --card: #ffffff;
    --text: #0f172a;
    --text-sec: #64748b;
    --primary: #0284c7;
    --primary-light: #38bdf8;
    --border: rgba(2,132,199,0.2);
    --shadow: rgba(0,0,0,0.1);
  }

  html.dark-mode {
    --bg: #0b1120;
    --card: #1e293b;
    --text: #f1f5f9;
    --text-sec: #94a3b8;
    --primary: #38bdf8;
    --primary-light: #0ea5e9;
    --border: rgba(56,189,248,0.2);
    --shadow: rgba(0,0,0,0.3);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  
  body {
    background-color: var(--bg);
    color: var(--text);
    font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
  }
  
  .site-header {
    background: var(--card);
    border-bottom: 2px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 1000;
    padding: 0.5rem 0;
    box-shadow: 0 2px 20px var(--shadow);
    backdrop-filter: blur(10px);
  }
  
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 80px;
  }
  
  .logo {
    flex-shrink: 0;
    margin-left: 2rem;
    transition: transform 0.3s;
  }
  
  .logo:hover {
    transform: scale(1.05);
  }
  
  .logo-img {
    height: 50px;
    width: auto;
    display: block;
  }
  
  .nav-links {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }
  
  .nav-link {
    color: var(--text);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.3s;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .nav-link .icon {
    font-size: 1.2rem;
  }
  
  .nav-link:hover {
    color: var(--primary);
    background: rgba(2,132,199,0.1);
    transform: translateY(-2px);
  }
  
  .header-tools {
    display: flex;
    gap: 0.8rem;
    align-items: center;
  }
  
  .tool-btn {
    background: linear-gradient(135deg, var(--primary), var(--primary-light));
    border: none;
    color: white;
    width: 45px;
    height: 45px;
    border-radius: 12px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 2px 8px rgba(2,132,199,0.3);
  }
  
  .tool-btn:hover {
    transform: translateY(-3px) scale(1.05);
    box-shadow: 0 6px 20px rgba(2,132,199,0.4);
  }
  
  .tool-btn:active {
    transform: scale(0.95);
  }
  
  .hamburger {
    display: none;
  }
  
  /* لوحة البحث المتقدمة */
  .search-panel {
    display: none;
    position: absolute;
    top: 80px;
    left: 0;
    right: 0;
    background: var(--card);
    padding: 2rem 1.5rem;
    border-bottom: 2px solid var(--border);
    z-index: 999;
    box-shadow: 0 10px 40px var(--shadow);
    animation: slideDown 0.3s ease;
  }
  
  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .search-panel.active {
    display: block !important;
  }
  
  .search-container {
    max-width: 700px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--bg);
    padding: 0.8rem 1.5rem;
    border-radius: 16px;
    border: 2px solid var(--border);
    transition: all 0.3s;
  }
  
  .search-container:focus-within {
    border-color: var(--primary);
    box-shadow: 0 0 0 4px rgba(2,132,199,0.1);
    transform: translateY(-2px);
  }
  
  .search-icon-wrapper {
    color: var(--primary);
    flex-shrink: 0;
  }
  
  .search-input {
    flex: 1;
    border: none;
    background: transparent;
    color: var(--text);
    font-size: 1.05rem;
    outline: none;
  }
  
  .search-input::placeholder {
    color: var(--text-sec);
  }
  
  .close-btn {
    background: #ef4444;
    color: white;
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s;
    flex-shrink: 0;
  }
  
  .close-btn:hover {
    background: #dc2626;
    transform: rotate(90deg) scale(1.1);
  }

  /* صندوق نتائج البحث */
  .search-results-box {
    max-width: 700px;
    margin: 15px auto 0;
    background: var(--card);
    border-radius: 12px;
    max-height: 400px;
    overflow-y: auto;
    box-shadow: 0 4px 20px var(--shadow);
    border: 1px solid var(--border);
  }

  .search-result-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 15px 20px;
    text-decoration: none;
    color: var(--text);
    border-bottom: 1px solid var(--border);
    transition: all 0.3s;
    background: var(--card);
  }

  .search-result-link:hover {
    background: linear-gradient(135deg, rgba(2,132,199,0.1), rgba(56,189,248,0.1));
    color: var(--primary);
    padding-right: 25px;
    transform: translateX(5px);
  }

  .search-result-link:last-child {
    border-bottom: none;
  }

  .result-title {
    font-weight: 600;
    font-size: 1rem;
  }

  .result-category {
    font-size: 0.85rem;
    color: var(--text-sec);
    background: var(--bg);
    padding: 4px 10px;
    border-radius: 6px;
  }

  .result-highlight {
    background: linear-gradient(120deg, rgba(2,132,199,0.3), rgba(56,189,248,0.3));
    padding: 2px 6px;
    border-radius: 4px;
    font-weight: 700;
  }

  .no-results {
    padding: 40px 20px;
    text-align: center;
    color: var(--text-sec);
    font-size: 1.05rem;
  }

  .search-stats {
    max-width: 700px;
    margin: 10px auto 0;
    text-align: center;
    color: var(--text-sec);
    font-size: 0.9rem;
    padding: 0.5rem;
  }

  .mobile-menu {
    display: none;
    position: absolute;
    top: 80px;
    left: 0;
    right: 0;
    background: var(--card);
    padding: 1.5rem;
    border-bottom: 2px solid var(--border);
    flex-direction: column;
    z-index: 999;
    box-shadow: 0 10px 40px var(--shadow);
    animation: slideDown 0.3s ease;
  }
  
  .mobile-menu.active {
    display: flex;
  }
  
  .mobile-link {
    color: var(--text);
    text-decoration: none;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--border);
    font-weight: 600;
    font-size: 1.05rem;
    transition: all 0.3s;
    border-radius: 10px;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  
  .mobile-link:hover {
    background: var(--bg);
    color: var(--primary);
    padding-right: 2rem;
  }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .hamburger { display: flex; }
    .container { height: 70px; padding: 0 1.5rem; }
    .tool-btn { width: 40px; height: 40px; }
    .search-panel, .mobile-menu { top: 70px; }
    .search-container { padding: 0.6rem 1rem; }
    .search-input { font-size: 0.95rem; }
  }
</style>

<script>
  // قاعدة بيانات شاملة للمحتوى - مع روابط صحيحة
  const siteContent = {
    articles: [
      { title: "الذكاء الاصطناعي", url: "/Th-tech/ai/", category: "تصنيف", keywords: ["ai", "machine learning", "تعلم آلي"] },
      { title: "الشبكات", url: "/Th-tech/networks/", category: "تصنيف", keywords: ["network", "router", "switch"] },
      { title: "البرمجة", url: "/Th-tech/programming/", category: "تصنيف", keywords: ["code", "software", "development"] },
      { title: "الأمن السيبراني", url: "/Th-tech/security/", category: "تصنيف", keywords: ["security", "cyber", "hacking"] },
      { title: "علم البيانات", url: "/Th-tech/data-science/", category: "تصنيف", keywords: ["data", "analytics", "statistics"] },
      { title: "DevOps", url: "/Th-tech/devops/", category: "تصنيف", keywords: ["devops", "ci/cd", "automation"] },
      { title: "IoT", url: "/Th-tech/iot/", category: "تصنيف", keywords: ["internet of things", "smart devices"] },
      { title: "Cloud", url: "/Th-tech/cloud/", category: "تصنيف", keywords: ["cloud computing", "aws", "azure"] },
      { title: "Blockchain", url: "/Th-tech/blockchain/", category: "تصنيف", keywords: ["blockchain", "crypto", "bitcoin"] },
      { title: "Mobile", url: "/Th-tech/mobile/", category: "تصنيف", keywords: ["mobile", "android", "ios"] },
      { title: "دليل الشبكات المتقدم", url: "/Th-tech/networks/advanced-network-guide/", category: "مقال", keywords: ["bgp", "ospf", "sd-wan"] },
      { title: "دليل البرمجة المتقدم", url: "/Th-tech/programming/advanced-programming-guide/", category: "مقال", keywords: ["solid", "design patterns", "clean code"] },
    ],
    
    // كلمات مفتاحية عامة
    generalKeywords: [
      { word: "tutorial", title: "دروس تعليمية", url: "/Th-tech/articles/" },
      { word: "guide", title: "أدلة شاملة", url: "/Th-tech/articles/" },
      { word: "beginner", title: "للمبتدئين", url: "/Th-tech/category/" },
      { word: "advanced", title: "مستوى متقدم", url: "/Th-tech/category/" },
    ]
  };

  // تبديل الوضع الليلي
  function toggleTheme() {
    const html = document.documentElement;
    const btn = document.getElementById('theme-btn');
    const moonIcon = document.getElementById('moon-icon');
    const sunIcon = document.getElementById('sun-icon');
    
    html.classList.toggle('dark-mode');
    
    if (html.classList.contains('dark-mode')) {
      localStorage.setItem('theme', 'dark');
      moonIcon.style.display = 'none';
      sunIcon.style.display = 'block';
      btn.setAttribute('title', 'الوضع النهاري');
    } else {
      localStorage.setItem('theme', 'light');
      moonIcon.style.display = 'block';
      sunIcon.style.display = 'none';
      btn.setAttribute('title', 'الوضع الليلي');
    }
  }

  // تمييز النص المطابق
  function highlightText(text, query) {
    if (!query) return text;
    const regex = new RegExp(`(${query})`, 'gi');
    return text.replace(regex, '<span class="result-highlight">$1</span>');
  }

  // البحث المتقدم
  function performAdvancedSearch(query) {
    const results = [];
    const queryLower = query.toLowerCase().trim();
    
    // البحث في المقالات
    siteContent.articles.forEach(article => {
      const titleMatch = article.title.toLowerCase().includes(queryLower);
      const categoryMatch = article.category.toLowerCase().includes(queryLower);
      const keywordMatch = article.keywords.some(k => k.toLowerCase().includes(queryLower));
      
      if (titleMatch || categoryMatch || keywordMatch) {
        results.push({
          ...article,
          matchType: titleMatch ? 'عنوان' : (categoryMatch ? 'تصنيف' : 'كلمة مفتاحية')
        });
      }
    });
    
    // البحث في الكلمات العامة
    siteContent.generalKeywords.forEach(item => {
      if (item.word.toLowerCase().includes(queryLower) || item.title.includes(queryLower)) {
        results.push({
          title: item.title,
          url: item.url,
          category: 'كلمة مفتاحية',
          matchType: 'عام'
        });
      }
    });
    
    return results;
  }

  // التهيئة عند التحميل
  document.addEventListener('DOMContentLoaded', () => {
    // الوضع المحفوظ
    const savedTheme = localStorage.getItem('theme');
    const themeBtn = document.getElementById('theme-btn');
    const moonIcon = document.getElementById('moon-icon');
    const sunIcon = document.getElementById('sun-icon');
    
    if (savedTheme === 'dark') {
      document.documentElement.classList.add('dark-mode');
      moonIcon.style.display = 'none';
      sunIcon.style.display = 'block';
      themeBtn.setAttribute('title', 'الوضع النهاري');
    }

    // أزرار التحكم
    themeBtn.addEventListener('click', toggleTheme);

    // القائمة المتنقلة
    const menuBtn = document.getElementById('menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    
    menuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('active');
      menuBtn.innerHTML = mobileMenu.classList.contains('active') 
        ? '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>'
        : '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>';
    });

    // البحث المتقدم
    const searchBtn = document.getElementById('search-btn');
    const searchPanel = document.getElementById('search-panel');
    const closeSearch = document.getElementById('close-search');
    const searchInput = document.getElementById('searchInput');
    const searchResults = document.getElementById('searchResults');
    const searchStats = document.getElementById('searchStats');
    
    searchBtn.addEventListener('click', () => {
      searchPanel.classList.add('active');
      setTimeout(() => searchInput.focus(), 100);
    });
    
    closeSearch.addEventListener('click', () => {
      searchPanel.classList.remove('active');
      searchInput.value = '';
      searchResults.innerHTML = '';
      searchStats.textContent = '';
    });

    // البحث عند الكتابة
    let searchTimeout;
    searchInput.addEventListener('input', function(e) {
      clearTimeout(searchTimeout);
      const query = e.target.value.trim();
      
      if (query.length < 2) {
        searchResults.innerHTML = '';
        searchStats.textContent = '';
        return;
      }
      
      // تأخير بسيط لتحسين الأداء
      searchTimeout = setTimeout(() => {
        const results = performAdvancedSearch(query);
        
        if (results.length > 0) {
          searchResults.innerHTML = results.map(r => `
            <a href="${r.url}" class="search-result-link">
              <span class="result-title">${highlightText(r.title, query)}</span>
              <span class="result-category">${r.category}</span>
            </a>
          `).join('');
          
          searchStats.textContent = `🔍 تم العثور على ${results.length} نتيجة لـ "${query}"`;
        } else {
          searchResults.innerHTML = '<div class="no-results">😕 لم يتم العثور على نتائج. جرب كلمات أخرى</div>';
          searchStats.textContent = '';
        }
      }, 300);
    });

    // إغلاق عند الضغط على Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        searchPanel.classList.remove('active');
        mobileMenu.classList.remove('active');
        searchInput.value = '';
        searchResults.innerHTML = '';
      }
    });

    // إغلاق عند النقر خارج اللوحة
    document.addEventListener('click', (e) => {
      if (!searchPanel.contains(e.target) && !searchBtn.contains(e.target)) {
        searchPanel.classList.remove('active');
      }
    });
  });
</script>
