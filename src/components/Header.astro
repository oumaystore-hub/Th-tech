---
---
<header class="site-header">
  <div class="container">
    <a href="/Th-tech/" class="logo">
      <!-- النص يظهر دائماً بدلاً من الصورة المفقودة حالياً -->
      <div class="text-logo">Th-<span class="highlight">tech</span></div>
    </a>
    
    <nav class="nav-links">
      <a href="/Th-tech/" class="nav-link">الرئيسية</a>
      <a href="/Th-tech/articles/" class="nav-link">المقالات</a>
      <a href="/Th-tech/category/" class="nav-link">التصنيفات</a>
      <a href="/Th-tech/contact/" class="nav-link">اتصل بنا</a>
    </nav>

    <div class="header-tools">
      <button id="search-btn" class="tool-btn" aria-label="بحث"></button>
      <button id="theme-btn" class="tool-btn" aria-label="تبديل الوضع">🌙</button>
      <button id="menu-btn" class="tool-btn hamburger" aria-label="القائمة">☰</button>
    </div>
  </div>

  <div id="search-panel" class="search-panel">
    <div class="search-container">
      <input type="text" placeholder="ابحث عن مقال..." class="search-input" />
      <button id="close-search" class="close-btn">✕</button>
    </div>
  </div>

  <nav id="mobile-menu" class="mobile-menu">
    <a href="/Th-tech/" class="mobile-link">🏠 الرئيسية</a>
    <a href="/Th-tech/articles/" class="mobile-link">📚 المقالات</a>
    <a href="/Th-tech/category/" class="mobile-link"> التصنيفات</a>
    <a href="/Th-tech/contact/" class="mobile-link"> اتصل بنا</a>
  </nav>
</header>

<style>
  :root {
    --bg: #f8fafc; --card: #ffffff; --text: #0f172a; --text-sec: #64748b;
    --primary: #0284c7; --border: rgba(2,132,199,0.2);
  }
  [data-theme="dark"] {
    --bg: #0b1120; --card: #1e293b; --text: #f1f5f9; --text-sec: #94a3b8;
    --primary: #38bdf8; --border: rgba(56,189,248,0.2);
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { background:var(--bg); color:var(--text); font-family:system-ui,sans-serif; transition:0.3s; }
  
  .site-header { background:var(--card); border-bottom:2px solid var(--border); position:sticky; top:0; z-index:1000; padding:0.5rem 0; }
  .container { max-width:1200px; margin:0 auto; padding:0 1rem; display:flex; justify-content:space-between; align-items:center; height:60px; }
  
  /* شعار نصي احترافي */
  .text-logo { font-size:1.8rem; font-weight:900; color:var(--text); text-decoration:none; }
  .text-logo .highlight { color:var(--primary); }
  
  .nav-links { display:flex; gap:1.5rem; }
  .nav-link { color:var(--text); text-decoration:none; font-weight:600; transition:0.3s; }
  .nav-link:hover { color:var(--primary); }
  
  .header-tools { display:flex; gap:0.5rem; }
  .tool-btn { background:transparent; border:1px solid var(--border); color:var(--primary); width:40px; height:40px; border-radius:8px; cursor:pointer; font-size:1.2rem; display:flex; align-items:center; justify-content:center; transition:0.3s; }
  .tool-btn:hover { background:var(--primary); color:white; }
  .hamburger { display:none; }
  
  .search-panel, .mobile-menu { display:none; }
  .search-panel.active, .mobile-menu.active { display:block; }
  .search-panel { position:absolute; top:60px; left:0; right:0; background:var(--card); padding:1rem; border-bottom:1px solid var(--border); z-index:999; }
  .search-container { max-width:600px; margin:0 auto; display:flex; gap:0.5rem; }
  .search-input { flex:1; padding:0.8rem; border-radius:8px; border:1px solid var(--border); background:var(--bg); color:var(--text); }
  .close-btn { background:#ef4444; color:white; border:none; padding:0 1rem; border-radius:8px; cursor:pointer; }
  
  .mobile-menu { position:absolute; top:60px; left:0; right:0; background:var(--card); padding:1rem; border-bottom:1px solid var(--border); display:none; flex-direction:column; z-index:999; }
  .mobile-menu.active { display:flex; }
  .mobile-link { color:var(--text); text-decoration:none; padding:1rem; border-bottom:1px solid var(--border); font-weight:600; }
  .mobile-link:last-child { border-bottom:none; }

  @media (max-width:768px) { .nav-links { display:none; } .hamburger { display:flex; } }
</style>

<script is:inline>
  window.addEventListener('load', () => {
    const html = document.documentElement;
    const themeBtn = document.getElementById('theme-btn');
    const saved = localStorage.getItem('theme') || 'light';
    html.setAttribute('data-theme', saved);
    themeBtn.textContent = saved === 'dark' ? '🌙' : '☀️';
    
    themeBtn.onclick = () => {
      const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
      html.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
      themeBtn.textContent = next === 'dark' ? '🌙' : '☀️';
    };

    const menuBtn = document.getElementById('menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    menuBtn.onclick = () => {
      mobileMenu.classList.toggle('active');
      menuBtn.textContent = mobileMenu.classList.contains('active') ? '✕' : '☰';
    };

    const searchBtn = document.getElementById('search-btn');
    const searchPanel = document.getElementById('search-panel');
    searchBtn.onclick = () => searchPanel.classList.add('active');
    document.getElementById('close-search').onclick = () => searchPanel.classList.remove('active');
  });
</script>
