---
---
<header class="site-header">
  <div class="container">
    <!-- الشعار كنص أنيق بدلاً من الصورة -->
    <a href="/Th-tech/" class="logo-link">
      <span class="logo-text">Th-<span class="tech">tech</span></span>
    </a>

    <nav class="desktop-nav">
      <a href="/Th-tech/" class="nav-item">الرئيسية</a>
      <a href="/Th-tech/articles/" class="nav-item">المقالات</a>
      <a href="/Th-tech/contact/" class="nav-item">اتصل بنا</a>
    </nav>

    <div class="header-tools">
      <button id="search-btn" class="icon-btn">🔍</button>
      <button id="theme-btn" class="icon-btn">🌙</button>
      <button id="menu-btn" class="icon-btn hamburger-btn">☰</button>
    </div>
  </div>

  <div id="search-panel" class="search-panel">
    <div class="search-box">
      <input type="text" placeholder="ابحث عن مقال..." class="search-input">
      <button onclick="document.getElementById('search-panel').classList.remove('active')" class="close-search">✕</button>
    </div>
  </div>

  <nav id="mobile-menu" class="mobile-menu">
    <a href="/Th-tech/" class="mobile-link">🏠 الرئيسية</a>
    <a href="/Th-tech/articles/" class="mobile-link">📚 المقالات</a>
    <a href="/Th-tech/category/" class="mobile-link highlight">📂 التصنيفات</a>
    <a href="/Th-tech/contact/" class="mobile-link">📧 اتصل بنا</a>
  </nav>
</header>

<style>
  :root {
    --bg-dark: #020617;
    --primary: #00d4ff;
    --secondary: #1e3a8a;
  }

  body { margin: 0; font-family: 'Segoe UI', system-ui, sans-serif; background: var(--bg-dark); color: #f1f5f9; }
  
  .site-header {
    background: #020617;
    border-bottom: 2px solid rgba(0, 212, 255, 0.3);    position: sticky; top: 0; z-index: 1000; padding: 0.5rem 0;
  }

  .container { max-width: 1200px; margin: 0 auto; padding: 0 1rem; display: flex; justify-content: space-between; align-items: center; height: 65px; }

  /* الشعار النصي - تصميم احترافي */
  .logo-text {
    font-size: 2rem;
    font-weight: 800;
    color: #1e3a8a;
    text-decoration: none;
    text-shadow: 0 0 20px rgba(0, 212, 255, 0.5);
    letter-spacing: -1px;
  }
  .tech {
    color: #00d4ff;
    background: linear-gradient(135deg, #00d4ff, #0099cc);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    position: relative;
  }
  .tech::after {
    content: '';
    position: absolute;
    top: -5px;
    right: -5px;
    left: -5px;
    bottom: -5px;
    background: linear-gradient(135deg, #00d4ff, #0099cc);
    filter: blur(10px);
    opacity: 0.5;
    z-index: -1;
  }

  .desktop-nav { display: flex; gap: 2rem; }
  .nav-item { color: #f1f5f9; text-decoration: none; font-weight: 600; transition: 0.3s; }
  .nav-item:hover { color: #00d4ff; }

  .header-tools { display: flex; gap: 0.6rem; }
  .icon-btn {
    background: transparent; border: 1px solid rgba(0, 212, 255, 0.3); color: #00d4ff;
    width: 42px; height: 42px; border-radius: 10px; cursor: pointer;
    font-size: 1.2rem; display: flex; align-items: center; justify-content: center;
  }
  .hamburger-btn { display: none; }

  .search-panel { display: none; background: #0f172a; padding: 1rem; border-top: 1px solid rgba(0, 212, 255, 0.3); }
  .search-panel.active { display: block; }
  .search-box { max-width: 600px; margin: 0 auto; display: flex; gap: 0.5rem; }
  .search-input { flex: 1; padding: 0.8rem; border: 1px solid #00d4ff; border-radius: 8px; background: #020617; color: #fff; }  .close-search { background: #ef4444; color: white; border: none; padding: 0 1.2rem; border-radius: 8px; cursor: pointer; }

  .mobile-menu {
    display: none; flex-direction: column; background: #0f172a; border-top: 1px solid rgba(0, 212, 255, 0.3);
    padding: 1rem; position: absolute; top: 65px; left: 0; right: 0; width: 100%;
  }
  .mobile-menu.active { display: flex; }
  .mobile-link { color: #f1f5f9; text-decoration: none; padding: 1rem 0; border-bottom: 1px solid rgba(255,255,255,0.1); }
  .mobile-link.highlight { color: #00d4ff; }

  @media (max-width: 768px) {
    .desktop-nav { display: none; }
    .hamburger-btn { display: flex; }
    .logo-text { font-size: 1.6rem; }
  }
</style>

<script is:inline>
  const html = document.documentElement;
  const themeBtn = document.getElementById('theme-btn');
  const saved = localStorage.getItem('theme') || 'dark';
  html.setAttribute('data-theme', saved);
  themeBtn.textContent = saved === 'light' ? '☀️' : '🌙';

  themeBtn.addEventListener('click', () => {
    const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    themeBtn.textContent = next === 'light' ? '☀️' : '🌙';
  });

  document.getElementById('menu-btn').addEventListener('click', () => document.getElementById('mobile-menu').classList.toggle('active'));
  document.getElementById('search-btn').addEventListener('click', () => document.getElementById('search-panel').classList.add('active'));
</script>
