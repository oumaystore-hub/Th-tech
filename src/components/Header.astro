---
---
<header class="site-header">
  <div class="container">
    <a href="/Th-tech/" class="logo">
      <img src="/Th-tech/logo1.png" alt="Th-tech" class="logo-img" />
    </a>
    
    <nav class="nav-links">
      <a href="/Th-tech/" class="nav-link">الرئيسية</a>
      <a href="/Th-tech/articles/" class="nav-link">المقالات</a>
      <a href="/Th-tech/category/" class="nav-link">التصنيفات</a>
      <a href="/Th-tech/contact/" class="nav-link">اتصل بنا</a>
    </nav>

    <div class="header-tools">
      <button id="search-btn" class="tool-btn">🔍</button>
      <button id="theme-btn" class="tool-btn">🌙</button>
      <button id="menu-btn" class="tool-btn hamburger">☰</button>
    </div>
  </div>

  <div id="search-panel" class="search-panel">
    <div class="search-container">
      <input type="text" placeholder="ابحث عن مقال..." class="search-input" />
      <button id="close-search" class="close-btn">✕</button>
    </div>
  </div>

  <nav id="mobile-menu" class="mobile-menu">
    <a href="/Th-tech/" class="mobile-link">🏠 الرئيسية</a>
    <a href="/Th-tech/articles/" class="mobile-link">📚 المقالات</a>
    <a href="/Th-tech/category/" class="mobile-link">📂 التصنيفات</a>
    <a href="/Th-tech/contact/" class="mobile-link">📧 اتصل بنا</a>
  </nav>
</header>

<style>
  :root { --bg: #f8fafc; --card: #ffffff; --text: #0f172a; --text-sec: #64748b; --primary: #0284c7; --border: rgba(2,132,199,0.2); }
  html.dark-mode { --bg: #0b1120; --card: #1e293b; --text: #f1f5f9; --text-sec: #94a3b8; --primary: #38bdf8; --border: rgba(56,189,248,0.2); }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { background: var(--bg); color: var(--text); font-family: system-ui, sans-serif; transition: 0.3s; }
  .site-header { background: var(--card); border-bottom: 2px solid var(--border); position: sticky; top: 0; z-index: 1000; padding: 0.5rem 0; }
  .container { max-width: 1400px; margin: 0 auto; padding: 0 2rem; display: flex; align-items: center; justify-content: space-between; height: 90px; }
  .logo-img { height: 65px; width: auto; display: block; }
  .nav-links { display: flex; gap: 2rem; }
  .nav-link { color: var(--text); text-decoration: none; font-weight: 700; font-size: 1.05rem; transition: 0.3s; }
  .nav-link:hover { color: var(--primary); }
  .header-tools { display: flex; gap: 0.8rem; }
  .tool-btn { background: var(--primary); border: none; color: white; width: 44px; height: 44px; border-radius: 10px; cursor: pointer; font-size: 1.3rem; display: flex; align-items: center; justify-content: center; transition: 0.3s; }
  .tool-btn:hover { transform: scale(1.05); filter: brightness(1.1); }
  .hamburger { display: none; }
  .search-panel, .mobile-menu { display: none; }
  .search-panel.active, .mobile-menu.active { display: block; }
  .search-panel { position: absolute; top: 90px; left: 0; right: 0; background: var(--card); padding: 1.5rem; border-bottom: 2px solid var(--border); z-index: 999; }
  .search-container { max-width: 600px; margin: 0 auto; display: flex; gap: 0.8rem; }
  .search-input { flex: 1; padding: 0.9rem; border-radius: 8px; border: 2px solid var(--border); background: var(--bg); color: var(--text); }
  .close-btn { background: #ef4444; color: white; border: none; padding: 0 1.2rem; border-radius: 8px; cursor: pointer; }
  .mobile-menu { position: absolute; top: 90px; left: 0; right: 0; background: var(--card); padding: 1.5rem; border-bottom: 2px solid var(--border); display: none; flex-direction: column; z-index: 999; }
  .mobile-menu.active { display: flex; }
  .mobile-link { color: var(--text); text-decoration: none; padding: 1rem; border-bottom: 1px solid var(--border); font-weight: 600; }
  .mobile-link:last-child { border-bottom: none; }
  @media (max-width: 768px) { .nav-links { display: none; } .hamburger { display: flex; } .logo-img { height: 45px; } .container { height: 70px; padding: 0 1.5rem; } .tool-btn { width: 40px; height: 40px; font-size: 1.1rem; } .search-panel, .mobile-menu { top: 70px; } }
</style>

<script is:inline>
  function toggleTheme() {
    const html = document.documentElement;
    const btn = document.getElementById('theme-btn');
    html.classList.toggle('dark-mode');
    const isDark = html.classList.contains('dark-mode');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    btn.textContent = isDark ? '☀️' : '🌙';
  }
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('theme-btn');
    const html = document.documentElement;
    const saved = localStorage.getItem('theme') === 'dark';
    if(saved) { html.classList.add('dark-mode'); btn.textContent = '☀️'; }
    btn.addEventListener('click', toggleTheme);
    document.getElementById('menu-btn').addEventListener('click', function() {
      const menu = document.getElementById('mobile-menu');
      menu.classList.toggle('active');
      this.textContent = menu.classList.contains('active') ? '✕' : '☰';
    });
    const searchBtn = document.getElementById('search-btn');
    const searchPanel = document.getElementById('search-panel');
    searchBtn.addEventListener('click', () => searchPanel.classList.add('active'));
    document.getElementById('close-search').addEventListener('click', () => searchPanel.classList.remove('active'));
  });
</script>
