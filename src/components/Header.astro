---
---
<header style="background:rgba(11,17,32,0.98); border-bottom:2px solid rgba(56,189,248,0.3); position:sticky; top:0; z-index:1000; padding:0.5rem 0;">
  <div style="max-width:1200px; margin:0 auto; padding:0 1rem; display:flex; align-items:center; justify-content:space-between;">
    
    <!-- الشعار -->
    <a href="/Th-tech/" style="text-decoration:none;">
      <img src="/Th-tech/logo.png" alt="Logo" style="height:55px; width:auto; filter:drop-shadow(0 0 5px rgba(56,189,248,0.5));">
    </a>

    <!-- قائمة الحاسوب -->
    <nav style="display:flex; gap:1.5rem;" id="desktop-links">
      <a href="/Th-tech/" style="color:#E2E8F0; text-decoration:none; font-weight:600;">الرئيسية</a>
      <a href="/Th-tech/articles/" style="color:#E2E8F0; text-decoration:none; font-weight:600;">المقالات</a>
      <a href="/Th-tech/contact/" style="color:#E2E8F0; text-decoration:none; font-weight:600;">اتصل بنا</a>
    </nav>

    <!-- الأزرار -->
    <div style="display:flex; gap:0.5rem;">
      <button onclick="document.getElementById('search-box').style.display='flex'; document.getElementById('search-input').focus()" style="background:transparent; border:1px solid rgba(56,189,248,0.3); color:#38BDF8; width:40px; height:40px; border-radius:8px; cursor:pointer; font-size:1.2rem;">🔍</button>
      <button id="theme-toggle" onclick="toggleTheme()" style="background:transparent; border:1px solid rgba(56,189,248,0.3); color:#38BDF8; width:40px; height:40px; border-radius:8px; cursor:pointer; font-size:1.2rem;">🌙</button>
      <button onclick="document.getElementById('mobile-menu').style.display=document.getElementById('mobile-menu').style.display==='flex'?'none':'flex'" style="display:none; background:transparent; border:1px solid rgba(56,189,248,0.3); color:#38BDF8; width:40px; height:40px; border-radius:8px; cursor:pointer; font-size:1.2rem;" id="menu-btn">☰</button>
    </div>
  </div>

  <!-- البحث -->
  <div id="search-box" style="display:none; background:#1E293B; padding:1rem; border-top:1px solid rgba(56,189,248,0.2);">
    <div style="max-width:600px; margin:0 auto; display:flex; gap:0.5rem;">
      <input type="text" id="search-input" placeholder="ابحث..." style="flex:1; padding:0.8rem; border:1px solid rgba(56,189,248,0.3); border-radius:8px; background:#0B1120; color:#fff;">
      <button onclick="document.getElementById('search-box').style.display='none'" style="background:#EF4444; color:white; border:none; padding:0 1rem; border-radius:8px; cursor:pointer;">✕</button>
    </div>
  </div>

  <!-- قائمة الهاتف -->
  <nav id="mobile-menu" style="display:none; flex-direction:column; background:#1E293B; padding:1rem; border-top:1px solid rgba(56,189,248,0.2);">
    <a href="/Th-tech/" style="color:#E2E8F0; text-decoration:none; padding:0.8rem 0; border-bottom:1px solid rgba(56,189,248,0.2);">🏠 الرئيسية</a>
    <a href="/Th-tech/articles/" style="color:#E2E8F0; text-decoration:none; padding:0.8rem 0; border-bottom:1px solid rgba(56,189,248,0.2);">📚 المقالات</a>
    <a href="/Th-tech/category/" style="color:#E2E8F0; text-decoration:none; padding:0.8rem 0; border-bottom:1px solid rgba(56,189,248,0.2);">📂 التصنيفات</a>
    <a href="/Th-tech/contact/" style="color:#E2E8F0; text-decoration:none; padding:0.8rem 0;">📧 اتصل بنا</a>
  </nav>
</header>

<script>
  // الوضع الليلي - يعمل 100%
  function toggleTheme() {
    const html = document.documentElement;
    const btn = document.getElementById('theme-toggle');
    const current = html.getAttribute('data-theme');
    const next = current === 'light' ? 'dark' : 'light';
    
    html.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    btn.textContent = next === 'light' ? '☀️' : '🌙';
  }

  // تحميل الوضع المحفوظ
  const saved = localStorage.getItem('theme') || 'dark';
  document.documentElement.setAttribute('data-theme', saved);
  document.getElementById('theme-toggle').textContent = saved === 'light' ? '☀️' : '🌙';

  // إظهار/إخفاء زر الهاتف
  function checkWidth() {
    const btn = document.getElementById('menu-btn');
    const desktop = document.getElementById('desktop-links');
    if(window.innerWidth <= 768) {
      btn.style.display = 'flex';
      desktop.style.display = 'none';
    } else {
      btn.style.display = 'none';
      desktop.style.display = 'flex';
    }
  }
  checkWidth();
  window.addEventListener('resize', checkWidth);
</script>
